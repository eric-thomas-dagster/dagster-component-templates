{
  "component_type": "dagster_component_templates.GreatExpectationsCheckComponent",
  "description": "Run a Great Expectations expectation suite as a Dagster asset check.",
  "category": "check",
  "icon": "CheckCircle",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetCheckResult",
      "description": "Asset check result"
    }
  },
  "attributes": {
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key to attach this check to",
      "required": true
    },
    "ge_context_root_dir": {
      "type": "string",
      "label": "Ge Context Root Dir",
      "description": "Path to the Great Expectations project root",
      "required": true,
      "ui:widget": "textarea"
    },
    "datasource_name": {
      "type": "string",
      "label": "Datasource Name",
      "description": "GE datasource name",
      "required": true
    },
    "data_asset_name": {
      "type": "string",
      "label": "Data Asset Name",
      "description": "GE data asset name",
      "required": true
    },
    "expectation_suite_name": {
      "type": "string",
      "label": "Expectation Suite Name",
      "description": "GE expectation suite name",
      "required": true
    },
    "severity": {
      "type": "string",
      "label": "Severity",
      "description": "WARN or ERROR",
      "required": false,
      "default": "ERROR"
    }
  },
  "tags": [
    "check",
    "great",
    "expectations"
  ]
}