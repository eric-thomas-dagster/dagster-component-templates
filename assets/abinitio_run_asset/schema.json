{
  "type": "dagster_component_templates.AbInitioRunAssetComponent",
  "name": "Ab Initio Run Asset",
  "category": "assets",
  "description": "Submit an Ab Initio graph or job on demand and surface it as a Dagster asset materialization",
  "icon": "Play",
  "attributes": {
    "asset_key": {"type": "string", "required": true, "label": "Asset Key", "placeholder": "abinitio/etl/load_orders"},
    "job_path": {"type": "string", "required": true, "label": "Job Path", "placeholder": "/prod/etl/load_orders"},
    "eme_url_env_var": {"type": "string", "required": false, "label": "EME URL Env Var"},
    "username_env_var": {"type": "string", "required": false, "label": "Username Env Var"},
    "password_env_var": {"type": "string", "required": false, "label": "Password Env Var"},
    "resource_key": {"type": "string", "required": false, "label": "Resource Key"},
    "parameters": {"type": "object", "required": false, "label": "Graph Parameters"},
    "poll_interval_seconds": {"type": "number", "default": 15.0},
    "timeout_seconds": {"type": "integer", "default": 3600},
    "group_name": {"type": "string", "default": "abinitio"}
  },
  "dependencies": {"pip": ["requests>=2.28.0"]},
  "tags": ["assets", "abinitio", "etl", "enterprise", "batch"]
}
