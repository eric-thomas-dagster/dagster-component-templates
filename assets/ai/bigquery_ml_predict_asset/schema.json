{
  "component_type": "dagster_component_templates.BigQueryMLPredictAssetComponent",
  "description": "Run ML.PREDICT / ML.FORECAST / ML.EXPLAIN_PREDICT / ML.DETECT_ANOMALIES against a BQML model and return a DataFrame.",
  "category": "ai",
  "icon": "si:googlebigquery",
  "x-dagster-io": {"outputs": {"type": "DataFrame", "description": "Prediction rows from BQML."}},
  "attributes": {
    "asset_name": {"type": "string", "label": "Asset Name", "required": true},
    "credentials": {"type": "object", "label": "Credentials (dict)", "required": false, "default": null},
    "credentials_path": {"type": "string", "label": "Credentials Path", "required": false, "default": null},
    "project_id": {"type": "string", "label": "Project ID", "required": false, "default": null},
    "location": {"type": "string", "label": "Location", "required": false, "default": null},
    "model_id": {"type": "string", "label": "Model ID", "required": true},
    "operation": {"type": "string", "label": "Operation", "required": false, "default": "predict", "description": "predict | forecast | explain_predict | detect_anomalies"},
    "input_query": {"type": "string", "label": "Input Query", "required": false, "default": null, "ui:widget": "textarea"},
    "input_table_id": {"type": "string", "label": "Input Table ID", "required": false, "default": null},
    "options": {"type": "object", "label": "Options", "required": false, "default": null},
    "threshold": {"type": "number", "label": "Threshold", "required": false, "default": null},
    "keep_input_columns": {"type": "boolean", "label": "Keep Input Columns", "required": false, "default": true},
    "upstream_asset_key": {"type": "string", "label": "Upstream Asset Key", "required": false, "default": null},
    "deps": {"type": "array", "label": "Deps", "required": false, "items": {"type": "string"}},
    "description": {"type": "string", "label": "Description", "required": false, "default": null, "ui:widget": "textarea"},
    "group_name": {"type": "string", "label": "Group Name", "required": false, "default": null},
    "tags": {"type": "object", "label": "Tags", "required": false},
    "owners": {"type": "array", "label": "Owners", "required": false, "items": {"type": "string"}}
  },
  "tags": ["ai", "ml", "google", "bigquery", "bqml", "prediction", "forecasting", "inference"],
  "name": "BigQuery ML Predict"
}
