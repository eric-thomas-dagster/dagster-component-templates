{
  "component_type": "dagster_component_templates.DocumentAiExtractorComponent",
  "description": "Cloud Document AI structured document parsing. Use a deployed processor (FORM_PARSER, INVOICE_PROCESSOR, OCR_PROCESSOR, LAYOUT_PARSER, custom CDE, etc.) to extract text, form fields, entities, and tables from documents (PDF / image). For flat OCR on photos, prefer vision_api_asset (DOCUMENT_TEXT_DETECTION).",
  "category": "ai",
  "icon": "si:googlecloud",
  "x-dagster-io": {
    "outputs": {
      "type": "DataFrame",
      "description": "Upstream DataFrame with doc_text / doc_form_fields / doc_entities / doc_tables / doc_page_count columns added per the toggles."
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": true
    },
    "credentials": {
      "type": "object",
      "label": "Credentials (dict)",
      "required": false,
      "default": null
    },
    "credentials_path": {
      "type": "string",
      "label": "Credentials Path",
      "required": false,
      "default": null
    },
    "project_id": {
      "type": "string",
      "label": "Project ID",
      "required": false,
      "default": null
    },
    "location": {
      "type": "string",
      "label": "Location",
      "required": false,
      "default": "us",
      "description": "Document AI region: us | eu"
    },
    "processor_id": {
      "type": "string",
      "label": "Processor ID",
      "required": true,
      "description": "Deployed processor's UUID-style id from the console."
    },
    "processor_version": {
      "type": "string",
      "label": "Processor Version",
      "required": false,
      "default": null
    },
    "document_column": {
      "type": "string",
      "label": "Document Column",
      "required": true,
      "x-dagster-widget": "column"
    },
    "mime_type_column": {
      "type": "string",
      "label": "MIME Type Column",
      "required": false,
      "default": null,
      "description": "Column with explicit MIME type per row. Default: auto-detect from extension.",
      "x-dagster-widget": "column"
    },
    "extract_text": {
      "type": "boolean",
      "label": "Extract Text",
      "required": false,
      "default": true
    },
    "extract_form_fields": {
      "type": "boolean",
      "label": "Extract Form Fields",
      "required": false,
      "default": true
    },
    "extract_entities": {
      "type": "boolean",
      "label": "Extract Entities",
      "required": false,
      "default": true
    },
    "extract_tables": {
      "type": "boolean",
      "label": "Extract Tables",
      "required": false,
      "default": false
    },
    "output_prefix": {
      "type": "string",
      "label": "Output Prefix",
      "required": false,
      "default": "doc_"
    },
    "rate_limit_delay": {
      "type": "number",
      "label": "Rate Limit Delay",
      "required": false,
      "default": 0.0
    },
    "max_retries": {
      "type": "integer",
      "label": "Max Retries",
      "required": false,
      "default": 3
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null,
      "ui:widget": "textarea"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    }
  },
  "tags": [
    "ai",
    "document-ai",
    "google",
    "ocr",
    "form-parser",
    "invoice",
    "receipt",
    "structured-extraction"
  ],
  "name": "Cloud Document AI"
}
