{
  "component_type": "dagster_component_templates.GeminiLLMComponent",
  "description": "Native (no-LiteLLM) per-row text generation with Google Gemini text models. Drop-in peer of openai_llm / anthropic_llm \u2014 same field shape so providers swap by changing `type:` and the api_key env var. For multi-vendor workflows use litellm_inference_asset.",
  "category": "ai",
  "icon": "si:google",
  "x-dagster-io": {
    "outputs": {
      "type": "DataFrame",
      "description": "Upstream DataFrame with an added text-response column (and an _error column on failed rows)."
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true,
      "description": "Output asset name"
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": true,
      "description": "Upstream DataFrame asset \u2014 one row per Gemini call"
    },
    "api_key_env_var": {
      "type": "string",
      "label": "API Key Env Var",
      "required": false,
      "default": "GEMINI_API_KEY",
      "description": "Env var holding the API key (falls back to GOOGLE_API_KEY)"
    },
    "text_model": {
      "type": "string",
      "label": "Text Model",
      "required": false,
      "default": "gemini-2.5-flash",
      "description": "Gemini text model id (gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash-lite, gemini-flash-latest, etc.)"
    },
    "system_prompt": {
      "type": "string",
      "label": "System Prompt",
      "required": false,
      "default": null,
      "ui:widget": "textarea"
    },
    "user_prompt_template": {
      "type": "string",
      "label": "User Prompt Template",
      "required": false,
      "default": null,
      "description": "Static template with {column} placeholders. Set this OR input_column.",
      "ui:widget": "textarea"
    },
    "input_column": {
      "type": "string",
      "label": "Input Column",
      "required": false,
      "default": null,
      "description": "Column whose value becomes the per-row prompt. Set this OR user_prompt_template.",
      "x-dagster-widget": "column"
    },
    "output_column": {
      "type": "string",
      "label": "Output Column",
      "required": false,
      "default": "gemini_response",
      "description": "Column for the model's text response",
      "x-dagster-widget": "column"
    },
    "max_output_tokens": {
      "type": "integer",
      "label": "Max Output Tokens",
      "required": false,
      "default": 1024
    },
    "temperature": {
      "type": "number",
      "label": "Temperature",
      "required": false,
      "default": 0.0,
      "description": "Temperature (0.0\u20132.0). 0 = deterministic."
    },
    "top_p": {
      "type": "number",
      "label": "Top-P",
      "required": false,
      "default": null
    },
    "top_k": {
      "type": "integer",
      "label": "Top-K",
      "required": false,
      "default": null
    },
    "rate_limit_delay": {
      "type": "number",
      "label": "Rate Limit Delay",
      "required": false,
      "default": 0.2,
      "description": "Seconds between API calls"
    },
    "max_retries": {
      "type": "integer",
      "label": "Max Retries",
      "required": false,
      "default": 3,
      "description": "Retries on transient errors (5xx, 429)"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null,
      "ui:widget": "textarea"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false,
      "default": null,
      "enum": [
        "daily",
        "hourly",
        "weekly",
        "monthly",
        "static",
        "multi",
        "dynamic"
      ],
      "ui:widget": "select"
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "required": false,
      "default": null
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "required": false,
      "default": null
    },
    "dynamic_partition_name": {
      "type": "string",
      "label": "Dynamic Partition Name",
      "required": false,
      "default": null
    },
    "partition_dimensions": {
      "type": "array",
      "label": "Partition Dimensions",
      "required": false
    }
  },
  "tags": [
    "ai",
    "llm",
    "text-generation",
    "gemini",
    "google",
    "completion",
    "summarization",
    "classification"
  ],
  "name": "Gemini LLM"
}
