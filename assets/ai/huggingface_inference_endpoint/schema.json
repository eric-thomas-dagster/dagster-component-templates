{
  "component_type": "dagster_community_components.HuggingfaceInferenceEndpointComponent",
  "description": "Call a dedicated HuggingFace Inference Endpoint (paid, scaled, per-model). Different from the shared public Inference API.",
  "category": "ai",
  "icon": "si:huggingface",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Per-input endpoint results in metadata"
    }
  },
  "attributes": {
    "asset_key": { "type": "string", "label": "Asset Key", "required": true },
    "task": { "type": "string", "label": "Task", "required": true },
    "inputs": { "type": "array", "items": { "type": "string" }, "label": "Inputs", "required": true, "ui:widget": "list" },
    "endpoint_name": { "type": "string", "label": "Endpoint Name", "description": "Named endpoint in your HF account", "required": false, "default": null },
    "endpoint_url": { "type": "string", "label": "Endpoint URL", "description": "Direct endpoint URL (alt to endpoint_name)", "required": false, "default": null },
    "namespace": { "type": "string", "label": "Namespace", "description": "Org / username if endpoint is in another account", "required": false, "default": null },
    "hf_token_env_var": { "type": "string", "label": "HF Token Env Var", "description": "Env var with HF token (required)", "required": true, "ui:widget": "env_var" },
    "call_kwargs": { "type": "object", "label": "Call Kwargs", "required": false, "ui:widget": "key-value" },
    "group_name": { "type": "string", "label": "Group Name", "required": false, "default": "huggingface" },
    "description": { "type": "string", "label": "Description", "required": false },
    "owners": { "type": "array", "items": { "type": "string" }, "label": "Owners", "required": false, "ui:widget": "list" },
    "asset_tags": { "type": "object", "label": "Asset Tags", "required": false, "ui:widget": "key-value" },
    "kinds": { "type": "array", "items": { "type": "string" }, "label": "Kinds", "required": false, "ui:widget": "list" },
    "deps": { "type": "array", "items": { "type": "string" }, "label": "Deps", "required": false, "ui:widget": "list" }
  },
  "tags": [
    "ai",
    "huggingface",
    "inference-endpoints",
    "dedicated"
  ],
  "name": "HuggingFace Inference Endpoint"
}
