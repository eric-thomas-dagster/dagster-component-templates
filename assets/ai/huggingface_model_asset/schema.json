{
  "component_type": "dagster_community_components.HuggingfaceModelAssetComponent",
  "description": "Observe a HuggingFace Hub model's metadata as a Dagster source asset — downloads, likes, pipeline tag, last_modified, license.",
  "category": "ai",
  "icon": "si:huggingface",
  "x-dagster-io": {
    "outputs": {
      "type": "ObserveResult",
      "description": "Model metadata snapshot"
    }
  },
  "attributes": {
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Dagster asset key (e.g. 'hf/models/bert-large').",
      "required": true
    },
    "model_id": {
      "type": "string",
      "label": "Model ID",
      "description": "HuggingFace Hub model id.",
      "required": true
    },
    "revision": {
      "type": "string",
      "label": "Revision",
      "description": "Optional revision (branch / tag / commit).",
      "required": false,
      "default": null
    },
    "hf_token_env_var": {
      "type": "string",
      "label": "HF Token Env Var",
      "description": "Env var with HF token (required for gated / private models).",
      "required": false,
      "default": null,
      "ui:widget": "env_var"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": "huggingface"
    },
    "description": { "type": "string", "label": "Description", "required": false },
    "owners": { "type": "array", "items": { "type": "string" }, "label": "Owners", "required": false, "ui:widget": "list" },
    "asset_tags": { "type": "object", "label": "Asset Tags", "required": false, "ui:widget": "key-value" },
    "kinds": { "type": "array", "items": { "type": "string" }, "label": "Kinds", "required": false, "ui:widget": "list" },
    "deps": { "type": "array", "items": { "type": "string" }, "label": "Deps", "required": false, "ui:widget": "list" }
  },
  "tags": [
    "ai",
    "huggingface",
    "model",
    "observation"
  ],
  "name": "HuggingFace Model (observed)"
}
