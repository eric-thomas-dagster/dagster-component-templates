{
  "component_type": "dagster_community_components.IterativeCatalogAgentComponent",
  "description": "Iterative + catalog. Planner runs per step, sees REAL columns/preview from prior step's materialization, picks next component from the live registry. Handles customer-built data with unknown schemas — schema is discovered at runtime from the actual output.",
  "category": "ai",
  "icon": "Sparkles",
  "x-dagster-io": {
    "inputs": {"type": "none"},
    "outputs": {"type": "multi_asset", "description": "Emits N step assets + 1 synthesis."}
  },
  "attributes": {
    "step_asset_prefix": {"type": "string", "required": false, "default": "catalog_step"},
    "synthesis_asset_name": {"type": "string", "required": true},
    "task": {"type": "string", "required": true},
    "manifest_url": {"type": "string", "required": false},
    "manifest_path": {"type": "string", "required": false},
    "include_categories": {"type": "array", "required": false},
    "include_tags": {"type": "array", "required": false},
    "include_ids": {"type": "array", "required": false},
    "max_catalog_entries": {"type": "integer", "required": false, "default": 40},
    "max_iterations": {"type": "integer", "required": false, "default": 5, "minimum": 1, "maximum": 15},
    "model": {"type": "string", "required": false, "default": "gpt-4o-mini"},
    "api_key_env_var": {"type": "string", "required": false, "default": "OPENAI_API_KEY"},
    "api_base_env_var": {"type": "string", "required": false},
    "temperature": {"type": "number", "required": false, "default": 0.1},
    "planner_max_tokens": {"type": "integer", "required": false, "default": 600},
    "synthesis_max_tokens": {"type": "integer", "required": false, "default": 800},
    "fail_on_execution_error": {"type": "boolean", "required": false, "default": false},
    "synthesis_system_message": {"type": "string", "required": false},
    "group_name": {"type": "string", "required": false},
    "owners": {"type": "array", "required": false},
    "tags": {"type": "object", "required": false},
    "kinds": {"type": "array", "required": false},
    "partition_type": {"type": "string", "required": false},
    "partition_start": {"type": "string", "required": false},
    "partition_values": {"type": "string", "required": false},
    "dynamic_partition_name": {"type": "string", "required": false},
    "freshness_max_lag_minutes": {"type": "integer", "required": false},
    "freshness_cron": {"type": "string", "required": false},
    "retry_policy_max_retries": {"type": "integer", "required": false},
    "retry_policy_delay_seconds": {"type": "integer", "required": false},
    "retry_policy_backoff": {"type": "string", "required": false, "default": "exponential"}
  }
}
