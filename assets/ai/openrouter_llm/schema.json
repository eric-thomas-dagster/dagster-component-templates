{
  "component_type": "dagster_component_templates.OpenRouterLLMComponent",
  "description": "Per-row LLM inference via OpenRouter \u2014 one API key gives access to 100+ models from Anthropic, OpenAI, Google, Meta/Llama, Mistral, DeepSeek, xAI, Cohere, with automatic fallback, caching, and unified billing. Drop-in peer of openai_llm / anthropic_llm / gemini_llm / groq_llm.",
  "category": "ai",
  "icon": "lu:globe",
  "x-dagster-io": {
    "outputs": {
      "type": "DataFrame",
      "description": "Upstream DataFrame with the LLM response column added (and optional _error column)."
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": true
    },
    "api_key_env_var": {
      "type": "string",
      "label": "API Key Env Var",
      "required": false,
      "default": "OPENROUTER_API_KEY"
    },
    "base_url": {
      "type": "string",
      "label": "Base URL",
      "required": false,
      "default": "https://openrouter.ai/api/v1"
    },
    "text_model": {
      "type": "string",
      "label": "Text Model",
      "required": false,
      "default": "anthropic/claude-haiku-4-5",
      "description": "OpenRouter model id ('<provider>/<model>')"
    },
    "provider_preferences": {
      "type": "object",
      "label": "Provider Preferences",
      "required": false,
      "default": null,
      "description": "OpenRouter routing object (order / allow_fallbacks / require_parameters / etc.)"
    },
    "transforms": {
      "type": "array",
      "label": "Transforms",
      "required": false,
      "items": {
        "type": "string"
      },
      "description": "OpenRouter transforms (e.g. ['middle-out'])"
    },
    "referer": {
      "type": "string",
      "label": "Referer",
      "required": false,
      "default": null,
      "description": "HTTP-Referer header \u2014 your app's URL"
    },
    "x_title": {
      "type": "string",
      "label": "X-Title",
      "required": false,
      "default": null,
      "description": "X-Title header \u2014 your app's name"
    },
    "system_prompt": {
      "type": "string",
      "label": "System Prompt",
      "required": false,
      "default": null,
      "ui:widget": "textarea"
    },
    "user_prompt_template": {
      "type": "string",
      "label": "User Prompt Template",
      "required": false,
      "default": null,
      "ui:widget": "textarea"
    },
    "input_column": {
      "type": "string",
      "label": "Input Column",
      "required": false,
      "default": null,
      "x-dagster-widget": "column"
    },
    "output_column": {
      "type": "string",
      "label": "Output Column",
      "required": false,
      "default": "openrouter_response",
      "x-dagster-widget": "column"
    },
    "max_tokens": {
      "type": "integer",
      "label": "Max Tokens",
      "required": false,
      "default": 1024
    },
    "temperature": {
      "type": "number",
      "label": "Temperature",
      "required": false,
      "default": 0.0
    },
    "top_p": {
      "type": "number",
      "label": "Top-P",
      "required": false,
      "default": null
    },
    "response_format": {
      "type": "string",
      "label": "Response Format",
      "required": false,
      "default": null,
      "description": "'json_object' for JSON-only output"
    },
    "rate_limit_delay": {
      "type": "number",
      "label": "Rate Limit Delay",
      "required": false,
      "default": 0.0
    },
    "max_retries": {
      "type": "integer",
      "label": "Max Retries",
      "required": false,
      "default": 3
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null,
      "ui:widget": "textarea"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false,
      "default": null,
      "enum": [
        "daily",
        "hourly",
        "weekly",
        "monthly",
        "static",
        "multi",
        "dynamic"
      ],
      "ui:widget": "select"
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "required": false,
      "default": null
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "required": false,
      "default": null
    },
    "dynamic_partition_name": {
      "type": "string",
      "label": "Dynamic Partition Name",
      "required": false,
      "default": null
    },
    "partition_dimensions": {
      "type": "array",
      "label": "Partition Dimensions",
      "required": false
    }
  },
  "tags": [
    "ai",
    "llm",
    "openrouter",
    "router",
    "multi-provider",
    "fallback"
  ],
  "name": "OpenRouter LLM"
}
