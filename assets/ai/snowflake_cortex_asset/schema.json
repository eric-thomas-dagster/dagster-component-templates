{
  "component_type": "dagster_component_templates.SnowflakeCortexAssetComponent",
  "description": "Run a Snowflake Cortex LLM function on a table and write results to a new table.",
  "category": "ai",
  "icon": "si:snowflake",
  "x-dagster-io": {
    "inputs": {
      "type": "dataframe",
      "required": true,
      "description": "Input DataFrame"
    },
    "outputs": {
      "type": "dataframe",
      "description": "Enriched DataFrame"
    }
  },
  "attributes": {
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "required": false,
      "default": "exponential",
      "enum": [
        "exponential",
        "linear",
        "fixed"
      ],
      "ui:widget": "select"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Kinds",
      "required": false
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag Minutes",
      "required": false
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron",
      "required": false,
      "x-dagster-widget": "cron"
    },
    "column_lineage": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Column Lineage",
      "required": false
    },
    "deps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Deps",
      "required": false
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false,
      "enum": [
        "daily",
        "hourly",
        "weekly",
        "monthly",
        "static",
        "multi",
        "dynamic"
      ],
      "ui:widget": "select"
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "required": false
    },
    "partition_date_column": {
      "type": "string",
      "label": "Partition Date Column",
      "required": false,
      "x-dagster-widget": "column"
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "required": false
    },
    "partition_static_dim": {
      "type": "string",
      "label": "Partition Static Dim",
      "required": false,
      "x-dagster-widget": "column"
    },
    "partition_static_column": {
      "type": "string",
      "label": "Partition Static Column",
      "required": false,
      "x-dagster-widget": "column"
    },
    "dynamic_partition_name": {
      "type": "string",
      "label": "Dynamic Partition Name",
      "description": "Name for DynamicPartitionsDefinition (when partition_type='dynamic'), e.g. 'tenants'.",
      "required": false,
      "default": null
    },
    "partition_dimensions": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "label": "Partition Dimensions",
      "description": "Multi-axis partition spec: list of {name, type, start, values, dynamic_partition_name} dicts. Overrides flat fields when set.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "ai",
    "snowflake",
    "cortex",
    "asset"
  ],
  "name": "Snowflake Cortex Asset"
}
