{
  "component_type": "dagster_component_templates.SpeechToTextAssetComponent",
  "description": "Transcribe audio files via Cloud Speech-to-Text v2. Pass a column of audio references (local paths or gs:// URIs); get back transcripts. Supports per-language config, multilingual recognition, automatic punctuation, word time offsets, speaker diarization. Specialized models: latest_short / latest_long / chirp / chirp_2 / phone_call / medical_conversation.",
  "category": "ai",
  "icon": "si:googlecloud",
  "x-dagster-io": {
    "outputs": {
      "type": "DataFrame",
      "description": "Upstream DataFrame with a transcript column added (and optional _error column on failed rows)."
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": true
    },
    "credentials": {
      "type": "object",
      "label": "Credentials (dict)",
      "required": false,
      "default": null
    },
    "credentials_path": {
      "type": "string",
      "label": "Credentials Path",
      "required": false,
      "default": null
    },
    "project_id": {
      "type": "string",
      "label": "Project ID",
      "required": false,
      "default": null
    },
    "location": {
      "type": "string",
      "label": "Location",
      "required": false,
      "default": "global"
    },
    "audio_column": {
      "type": "string",
      "label": "Audio Column",
      "required": true,
      "x-dagster-widget": "column"
    },
    "output_column": {
      "type": "string",
      "label": "Output Column",
      "required": false,
      "default": "transcript",
      "x-dagster-widget": "column"
    },
    "language_codes": {
      "type": "array",
      "label": "Language Codes",
      "required": false,
      "items": {
        "type": "string"
      },
      "default": [
        "en-US"
      ]
    },
    "recognizer_model": {
      "type": "string",
      "label": "Recognizer Model",
      "required": false,
      "default": "latest_long"
    },
    "enable_automatic_punctuation": {
      "type": "boolean",
      "label": "Auto Punctuation",
      "required": false,
      "default": true
    },
    "enable_word_time_offsets": {
      "type": "boolean",
      "label": "Word Time Offsets",
      "required": false,
      "default": false
    },
    "enable_speaker_diarization": {
      "type": "boolean",
      "label": "Speaker Diarization",
      "required": false,
      "default": false
    },
    "diarization_speaker_count": {
      "type": "integer",
      "label": "Diarization Speaker Count",
      "required": false,
      "default": null
    },
    "rate_limit_delay": {
      "type": "number",
      "label": "Rate Limit Delay",
      "required": false,
      "default": 0.0
    },
    "max_retries": {
      "type": "integer",
      "label": "Max Retries",
      "required": false,
      "default": 3
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null,
      "ui:widget": "textarea"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    }
  },
  "tags": [
    "ai",
    "speech-to-text",
    "transcription",
    "google",
    "audio",
    "voice"
  ],
  "name": "Cloud Speech-to-Text"
}
