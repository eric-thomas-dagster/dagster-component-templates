{
  "component_type": "dagster_component_templates.TicketClassifierComponent",
  "description": "Component for classifying support tickets.",
  "category": "ai",
  "icon": "Sparkles",
  "x-dagster-io": {
    "inputs": {
      "type": "dataframe",
      "required": true,
      "description": "Input DataFrame"
    },
    "outputs": {
      "type": "dataframe",
      "description": "Enriched DataFrame"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Name of the asset that will hold classified ticket data",
      "required": true
    },
    "method": {
      "type": "string",
      "label": "Method",
      "description": "Method",
      "required": false,
      "default": "llm"
    },
    "llm_provider": {
      "type": "string",
      "label": "Llm Provider",
      "description": "Llm Provider",
      "required": false,
      "default": null
    },
    "llm_model": {
      "type": "string",
      "label": "Llm Model",
      "description": "Llm Model",
      "required": false,
      "default": null
    },
    "transformer_model": {
      "type": "string",
      "label": "Transformer Model",
      "description": "Transformer Model",
      "required": false,
      "default": null
    },
    "api_key": {
      "type": "string",
      "label": "Api Key",
      "description": "API key for LLM method. Use ${OPENAI_API_KEY} or ${ANTHROPIC_API_KEY}",
      "required": false,
      "default": null
    },
    "input_column": {
      "type": "string",
      "label": "Input Column",
      "description": "Column name containing ticket text",
      "required": false,
      "default": "ticket_text"
    },
    "categories": {
      "type": "string",
      "label": "Categories",
      "description": "Comma-separated list of ticket categories",
      "required": false,
      "default": "technical"
    },
    "urgency_levels": {
      "type": "string",
      "label": "Urgency Levels",
      "description": "Comma-separated list of urgency levels",
      "required": false,
      "default": "low"
    },
    "departments": {
      "type": "string",
      "label": "Departments",
      "description": "Departments",
      "required": false,
      "default": null
    },
    "classify_sentiment": {
      "type": "boolean",
      "label": "Classify Sentiment",
      "description": "Classify Sentiment",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "include_confidence": {
      "type": "boolean",
      "label": "Include Confidence",
      "description": "Include confidence scores for classifications",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "include_reasoning": {
      "type": "boolean",
      "label": "Include Reasoning",
      "description": "Include Reasoning",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "multi_label": {
      "type": "boolean",
      "label": "Multi Label",
      "description": "Multi Label",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "confidence_threshold": {
      "type": "number",
      "label": "Confidence Threshold",
      "description": "Confidence Threshold",
      "required": false,
      "default": null
    },
    "batch_size": {
      "type": "integer",
      "label": "Batch Size",
      "description": "Batch size for processing",
      "required": false,
      "default": 50
    },
    "temperature": {
      "type": "number",
      "label": "Temperature",
      "description": "Temperature",
      "required": false,
      "default": 0.0
    },
    "max_tokens": {
      "type": "integer",
      "label": "Max Tokens",
      "description": "Max tokens for LLM response",
      "required": false,
      "default": 200
    },
    "rate_limit_delay": {
      "type": "number",
      "label": "Rate Limit Delay",
      "description": "Delay in seconds between API calls",
      "required": false,
      "default": 0.1
    },
    "max_retries": {
      "type": "integer",
      "label": "Max Retries",
      "description": "Maximum retries for failed API calls",
      "required": false,
      "default": 3
    },
    "enable_caching": {
      "type": "boolean",
      "label": "Enable Caching",
      "description": "Cache API responses to avoid redundant calls",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "track_costs": {
      "type": "boolean",
      "label": "Track Costs",
      "description": "Track Costs",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "include_metadata_fields": {
      "type": "string",
      "label": "Include Metadata Fields",
      "description": "Comma-separated list of metadata fields to include in classification (e.g., ",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Asset description",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group for organization",
      "required": false,
      "default": "ticket_classification"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "Enable partitioning: 'daily', 'weekly', 'monthly', 'hourly' for time-based; 'static' for a fixed set of values (e.g. customers); 'multi' for date \u00d7 static (e.g. day \u00d7 customer). Leave empty for unpartitioned.",
      "required": false,
      "default": null,
      "enum": [
        "daily",
        "weekly",
        "monthly",
        "hourly",
        "static",
        "multi"
      ],
      "ui:widget": "select"
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start Date",
      "description": "ISO date string for the first partition, e.g. '2024-01-01'. Required for time-based and multi partition types.",
      "required": false,
      "default": null
    },
    "partition_date_column": {
      "type": "string",
      "label": "Partition Date Column",
      "description": "Column used to filter rows to the current date partition key (e.g. 'event_date', 'created_at').",
      "required": false,
      "default": null
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "description": "Comma-separated values for static or multi partitioning, e.g. 'acme_corp,globex,initech'. Required for static and multi types.",
      "required": false,
      "default": null
    },
    "partition_static_dim": {
      "type": "string",
      "label": "Static Dimension Name",
      "description": "Name for the static partition dimension in multi-partitioning, e.g. 'customer' or 'region'. Defaults to 'segment'.",
      "required": false,
      "default": null
    },
    "partition_static_column": {
      "type": "string",
      "label": "Static Partition Column",
      "description": "Column used to filter rows to the current static partition value (e.g. 'customer_id', 'region').",
      "required": false,
      "default": null
    },
    "include_sample_metadata": {
      "type": "boolean",
      "label": "Include Sample Metadata",
      "description": "Include sample data preview in metadata",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream asset key providing a DataFrame with ticket text to classify",
      "required": true
    }
  },
  "tags": [
    "ai",
    "ticket",
    "classifier"
  ]
}
