  "attributes": {
    "asset_name": {"type": "string", "label": "Asset Name", "required": true},
    "upstream_asset_key": {"type": "string", "label": "Upstream Asset Key", "required": true},
    "credentials": {"type": "object", "label": "Credentials (dict)", "required": false, "default": null},
    "credentials_path": {"type": "string", "label": "Credentials Path", "required": false, "default": null},
    "project_id": {"type": "string", "label": "Project ID", "required": false, "default": null},
    "location": {"type": "string", "label": "Location", "required": false, "default": "us-central1"},
    "text_column": {"type": "string", "label": "Text Column", "required": true},
    "output_column": {"type": "string", "label": "Output Column", "required": false, "default": "embedding"},
    "model_name": {"type": "string", "label": "Model Name", "required": false, "default": "text-embedding-004"},
    "task_type": {"type": "string", "label": "Task Type", "required": false, "default": "RETRIEVAL_DOCUMENT", "description": "RETRIEVAL_QUERY | RETRIEVAL_DOCUMENT | SEMANTIC_SIMILARITY | CLASSIFICATION | CLUSTERING | QUESTION_ANSWERING | FACT_VERIFICATION | CODE_RETRIEVAL_QUERY"},
    "output_dimensionality": {"type": "integer", "label": "Output Dimensionality", "required": false, "default": null},
