{
  "component_type": "dagster_component_templates.BufferComponent",
  "description": "Buffer (expand) point or polygon geometries by a fixed radius.",
  "category": "analytics",
  "icon": "Circle",
  "x-dagster-io": {
    "inputs": {
      "type": "dataframe",
      "required": true,
      "description": "Input DataFrame"
    },
    "outputs": {
      "type": "dataframe",
      "description": "Result DataFrame"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": true
    },
    "geometry_column": {
      "type": "string",
      "label": "Geometry Column",
      "required": true,
      "x-dagster-widget": "column"
    },
    "radius_meters": {
      "type": "number",
      "label": "Radius Meters",
      "required": true
    },
    "metric_crs": {
      "type": "string",
      "label": "Metric Crs",
      "required": true
    },
    "src_crs": {
      "type": "string",
      "label": "Src Crs",
      "required": true
