{
  "component_type": "dagster_component_templates.CampaignPerformanceComponent",
  "description": "Component for analyzing marketing campaign performance.",
  "category": "analytics",
  "icon": "BarChart2",
  "x-dagster-io": {
    "inputs": {
      "type": "dataframe",
      "required": true,
      "description": "Input DataFrame"
    },
    "outputs": {
      "type": "dataframe",
      "description": "Analytics result DataFrame"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Name of the asset to create",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream Asset Key",
      "required": true
    },
    "target_roas": {
      "type": "number",
      "label": "Target Roas",
      "description": "Target Roas",
      "required": false,
      "default": null
    },
    "target_cpa": {
      "type": "number",
      "label": "Target Cpa",
      "description": "Target Cpa",
      "required": false,
      "default": null
    },
    "include_benchmarks": {
      "type": "boolean",
      "label": "Include Benchmarks",
      "description": "Include industry benchmark comparisons",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "campaign_id_field": {
      "type": "string",
      "label": "Campaign Id Field",
      "description": "Campaign Id Field",
      "required": false,
      "default": null
    },
    "campaign_name_field": {
      "type": "string",
      "label": "Campaign Name Field",
      "description": "Campaign Name Field",
      "required": false,
      "default": null
    },
    "channel_field": {
      "type": "string",
      "label": "Channel Field",
      "description": "Channel Field",
      "required": false,
      "default": null
    },
    "spend_field": {
      "type": "string",
      "label": "Spend Field",
      "description": "Spend Field",
      "required": false,
      "default": null
    },
    "impressions_field": {
      "type": "string",
      "label": "Impressions Field",
      "description": "Impressions Field",
      "required": false,
      "default": null
    },
    "clicks_field": {
      "type": "string",
      "label": "Clicks Field",
      "description": "Clicks Field",
      "required": false,
      "default": null
    },
    "conversions_field": {
      "type": "string",
      "label": "Conversions Field",
      "description": "Conversions Field",
      "required": false,
      "default": null
    },
    "revenue_field": {
      "type": "string",
      "label": "Revenue Field",
      "description": "Revenue Field",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Asset description",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group for organization",
      "required": false,
      "default": "marketing_analytics"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "Enable partitioning: 'daily', 'weekly', 'monthly', 'hourly' for time-based; 'static' for a fixed set of values (e.g. customers); 'multi' for date \u00d7 static (e.g. day \u00d7 customer). Leave empty for unpartitioned.",
      "required": false,
      "default": null,
      "enum": [
        "daily",
        "weekly",
        "monthly",
        "hourly",
        "static",
        "multi"
      ],
      "ui:widget": "select"
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start Date",
      "description": "ISO date string for the first partition, e.g. '2024-01-01'. Required for time-based and multi partition types.",
      "required": false,
      "default": null
    },
    "partition_date_column": {
      "type": "string",
      "label": "Partition Date Column",
      "description": "Column used to filter rows to the current date partition key (e.g. 'event_date', 'created_at').",
      "required": false,
      "default": null
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "description": "Comma-separated values for static or multi partitioning, e.g. 'acme_corp,globex,initech'. Required for static and multi types.",
      "required": false,
      "default": null
    },
    "partition_static_dim": {
      "type": "string",
      "label": "Static Dimension Name",
      "description": "Name for the static partition dimension in multi-partitioning, e.g. 'customer' or 'region'. Defaults to 'segment'.",
      "required": false,
      "default": null
    },
    "partition_static_column": {
      "type": "string",
      "label": "Static Partition Column",
      "description": "Column used to filter rows to the current static partition value (e.g. 'customer_id', 'region').",
      "required": false,
      "default": null
    },
    "include_sample_metadata": {
      "type": "boolean",
      "label": "Include Sample Metadata",
      "description": "Include sample data preview in metadata",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    }
  },
  "tags": [
    "analytics",
    "campaign",
    "performance"
  ]
}
