      "required": false,
      "default": ""
    },
    "stage_3_name": {
      "type": "string",
      "label": "Stage 3 Name",
      "description": "Display name for third stage",
      "required": false,
      "default": ""
    },
    "stage_4_event": {
      "type": "string",
      "label": "Stage 4 Event",
      "description": "Stage 4 Event",
      "required": false,
      "default": ""
    },
    "stage_4_name": {
      "type": "string",
      "label": "Stage 4 Name",
      "description": "Display name for fourth stage",
      "required": false,
      "default": ""
    },
    "stage_5_event": {
      "type": "string",
      "label": "Stage 5 Event",
      "description": "Stage 5 Event",
      "required": false,
      "default": ""
    },
    "stage_5_name": {
      "type": "string",
      "label": "Stage 5 Name",
      "description": "Display name for fifth stage",
      "required": false,
      "default": ""
    },
    "funnel_window_days": {
      "type": "integer",
