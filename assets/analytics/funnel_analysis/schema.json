{
  "component_type": "dagster_component_templates.FunnelAnalysisComponent",
  "description": "Component that analyzes user progression through conversion funnels.",
  "category": "analytics",
  "icon": "BarChart2",
  "x-dagster-io": {
    "inputs": {
      "type": "dataframe",
      "required": true,
      "description": "Input DataFrame"
