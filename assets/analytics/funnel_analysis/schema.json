      "description": "Group results by weekly/monthly cohorts",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "cohort_period": {
      "type": "string",
      "label": "Cohort Period",
      "description": "Cohort period: daily, weekly, or monthly",
      "required": false,
      "default": "weekly"
    },
    "segment_by_source": {
      "type": "boolean",
      "label": "Segment By Source",
      "description": "Segment funnel by traffic source/campaign",
      "required": false,
      "default": true,
