    "include_user_level_data": {
      "type": "boolean",
      "label": "Include User Level Data",
      "description": "Include User Level Data",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Asset description",
      "required": false,
      "default": "",
      "ui:widget": "code"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group name",
      "required": false,
      "default": "analytics"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "Enable partitioning: 'daily', 'weekly', 'monthly', 'hourly' for time-based; 'static' for a fixed set of values (e.g. customers); 'multi' for date \u00d7 static (e.g. day \u00d7 customer). Leave empty for unpartitioned.",
      "required": false,
      "default": null,
      "enum": [
        "daily",
        "weekly",
        "monthly",
        "hourly",
        "static",
        "multi"
      ],
      "ui:widget": "select"
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start Date",
      "description": "ISO date string for the first partition, e.g. '2024-01-01'. Required for time-based and multi partition types.",
      "required": false,
      "default": null
    },
    "partition_date_column": {
      "type": "string",
      "label": "Partition Date Column",
      "description": "Column used to filter rows to the current date partition key (e.g. 'event_date', 'created_at').",
      "required": false,
      "default": null
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "description": "Comma-separated values for static or multi partitioning, e.g. 'acme_corp,globex,initech'. Required for static and multi types.",
      "required": false,
      "default": null
    },
    "partition_static_dim": {
      "type": "string",
      "label": "Static Dimension Name",
      "description": "Name for the static partition dimension in multi-partitioning, e.g. 'customer' or 'region'. Defaults to 'segment'.",
      "required": false,
      "default": null
    },
    "partition_static_column": {
      "type": "string",
      "label": "Static Partition Column",
      "description": "Column used to filter rows to the current static partition value (e.g. 'customer_id', 'region').",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "analytics",
    "funnel",
    "analysis"
  ]
}
