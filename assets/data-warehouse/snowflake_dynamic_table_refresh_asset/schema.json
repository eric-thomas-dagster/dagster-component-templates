{
  "component_type": "dagster_community_components.SnowflakeDynamicTableRefreshAssetComponent",
  "description": "Materialize by ALTER DYNAMIC TABLE ... REFRESH on a named Snowflake dynamic table. Single-entity counterpart to snowflake_workspace's auto-discovered DTs.",
  "category": "data-warehouse",
  "icon": "si:snowflake",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Snowflake DT refresh result + last status"
    }
  },
  "attributes": {
    "asset_key": { "type": "string", "label": "Asset Key", "required": true },
    "dynamic_table_name": { "type": "string", "label": "Dynamic Table Name", "required": true },
    "database": { "type": "string", "label": "Database", "required": true },
    "schema": { "type": "string", "label": "Schema", "required": true },
    "account_env_var": { "type": "string", "label": "Account Env Var", "required": true, "ui:widget": "env_var" },
    "user_env_var": { "type": "string", "label": "User Env Var", "required": true, "ui:widget": "env_var" },
    "password_env_var": { "type": "string", "label": "Password Env Var", "required": false, "ui:widget": "env_var" },
    "pat_env_var": { "type": "string", "label": "PAT Env Var", "required": false, "ui:widget": "env_var" },
    "private_key_path_env_var": { "type": "string", "label": "Private Key Path Env Var", "required": false, "ui:widget": "env_var" },
    "private_key_passphrase_env_var": { "type": "string", "label": "Private Key Passphrase Env Var", "required": false, "ui:widget": "env_var" },
    "warehouse_env_var": { "type": "string", "label": "Warehouse Env Var", "required": false, "ui:widget": "env_var" },
    "role_env_var": { "type": "string", "label": "Role Env Var", "required": false, "ui:widget": "env_var" },
    "group_name": { "type": "string", "label": "Group Name", "required": false, "default": "snowflake" },
    "description": { "type": "string", "label": "Description", "required": false },
    "owners": { "type": "array", "items": { "type": "string" }, "label": "Owners", "required": false, "ui:widget": "list" },
    "asset_tags": { "type": "object", "label": "Asset Tags", "required": false, "ui:widget": "key-value" },
    "kinds": { "type": "array", "items": { "type": "string" }, "label": "Kinds", "required": false, "ui:widget": "list" },
    "deps": { "type": "array", "items": { "type": "string" }, "label": "Deps", "required": false, "ui:widget": "list" }
  },
  "tags": ["data-warehouse", "snowflake", "dynamic-table", "refresh"],
  "name": "Snowflake Dynamic Table Refresh Asset"
}
