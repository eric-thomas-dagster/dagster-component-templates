{
  "component_type": "dagster_component_templates.AbInitioRunAssetComponent",
  "description": "Resource for connecting to Ab Initio EME REST API.",
  "category": "infrastructure",
  "icon": "Server",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Provisioning result"
    }
  },
  "attributes": {
    "eme_url": {
      "type": "string",
      "label": "Eme Url",
      "description": "Eme Url",
      "required": true
    },
    "username": {
      "type": "string",
      "label": "Username",
      "description": "Ab Initio EME username",
      "required": true
    },
    "password": {
      "type": "string",
      "label": "Password",
      "description": "Ab Initio EME password",
      "required": true,
      "ui:widget": "password"
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Dagster asset key (e.g. ",
      "required": true
    },
    "job_path": {
      "type": "string",
      "label": "Job Path",
      "description": "Job Path",
      "required": true
    },
    "eme_url_env_var": {
      "type": "string",
      "label": "Eme Url Env Var",
      "description": "Env var with Ab Initio EME base URL",
      "required": false,
      "default": null
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "description": "Env var with Ab Initio EME username",
      "required": false,
      "default": null
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var with Ab Initio EME password",
      "required": false,
      "default": null,
      "ui:widget": "env_var"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Key of an AbInitioResource. When set, env var fields are ignored.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    },
    "parameters": {
      "type": "object",
      "label": "Parameters",
      "description": "Parameters",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    },
    "poll_interval_seconds": {
      "type": "number",
      "label": "Poll Interval Seconds",
      "description": "Seconds between status polls",
      "required": false,
      "default": 15.0
    },
    "timeout_seconds": {
      "type": "integer",
      "label": "Timeout Seconds",
      "description": "Max seconds to wait for job completion",
      "required": false,
      "default": 3600
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Dagster asset group name",
      "required": false,
      "default": "abinitio"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Owners",
      "description": "Asset owners \u2014 team names (team:analytics) or email addresses.",
      "required": false,
      "ui:widget": "list"
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Key-value tags applied to the asset in the Dagster catalog, e.g. {\"domain\": \"finance\"}.",
      "required": false,
      "ui:widget": "key-value"
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Kinds",
      "description": "Asset kinds shown in the Dagster catalog (e.g. snowflake, python). Auto-inferred from component name if empty.",
      "required": false,
      "ui:widget": "list"
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag (minutes)",
      "description": "Maximum acceptable lag in minutes before this asset is considered stale.",
      "required": false,
      "default": null
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron Schedule",
      "description": "Cron schedule for the freshness policy, e.g. '0 9 * * 1-5' (weekdays 9am).",
      "required": false,
      "default": null,
      "x-dagster-widget": "cron"
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false
    },
    "column_lineage": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Column Lineage",
      "required": false
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false,
      "enum": [
        "daily",
        "hourly",
        "weekly",
        "monthly",
        "static",
        "multi",
        "dynamic"
      ],
      "ui:widget": "select"
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "required": false
    },
    "partition_date_column": {
      "type": "string",
      "label": "Partition Date Column",
      "required": false,
      "x-dagster-widget": "column"
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "required": false
    },
    "partition_static_dim": {
      "type": "string",
      "label": "Partition Static Dim",
      "required": false,
      "x-dagster-widget": "column"
    },
    "partition_static_column": {
      "type": "string",
      "label": "Partition Static Column",
      "required": false,
      "x-dagster-widget": "column"
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "required": false,
      "default": "exponential",
      "enum": [
        "exponential",
        "linear",
        "fixed"
      ],
      "ui:widget": "select"
    },
    "dynamic_partition_name": {
      "type": "string",
      "label": "Dynamic Partition Name",
      "description": "Name for DynamicPartitionsDefinition (when partition_type='dynamic'), e.g. 'tenants'.",
      "required": false,
      "default": null
    },
    "partition_dimensions": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "label": "Partition Dimensions",
      "description": "Multi-axis partition spec: list of {name, type, start, values, dynamic_partition_name} dicts. Overrides flat fields when set.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "infrastructure",
    "abinitio",
    "run",
    "asset"
  ],
  "name": "Ab Initio Run Asset"
}
