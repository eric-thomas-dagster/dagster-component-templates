{
  "component_type": "dagster_component_templates.ArmTemplateAssetComponent",
  "description": "Deploy an Azure Resource Manager (ARM) template as a Dagster asset.",
  "category": "infrastructure",
  "icon": "Shield",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name for this ARM deployment",
      "required": true
    },
    "resource_group": {
      "type": "string",
      "label": "Resource Group",
      "description": "Azure resource group to deploy into",
      "required": true
    },
    "deployment_name": {
      "type": "string",
      "label": "Deployment Name",
      "description": "ARM deployment name (idempotent \u2014 re-runs update in place)",
      "required": true
    },
    "template_file": {
      "type": "string",
      "label": "Template File",
      "description": "Local path to ARM JSON template",
      "required": false
    },
    "template_uri": {
      "type": "string",
      "label": "Template Uri",
      "description": "HTTPS URL of remote ARM template (mutually exclusive with template_file)",
      "required": false
    },
    "parameters_file": {
      "type": "string",
      "label": "Parameters File",
      "description": "Local path to parameters JSON file",
      "required": false
    },
    "parameters": {
      "type": "object",
      "label": "Parameters",
      "description": "Inline parameter overrides",
      "required": false
    },
    "subscription_id": {
      "type": "string",
      "label": "Subscription Id",
      "description": "Azure subscription ID (defaults to AZURE_SUBSCRIPTION_ID env)",
      "required": false
    },
    "location": {
      "type": "string",
      "label": "Location",
      "description": "Azure region (only required for subscription-scope deployments)",
      "required": false
    },
    "mode": {
      "type": "string",
      "label": "Mode",
      "description": "Deployment mode: 'Incremental' or 'Complete'",
      "required": false,
      "default": "Incremental",
      "enum": [
        "append",
        "overwrite",
        "upsert"
      ],
      "ui:widget": "select"
    },
    "what_if": {
      "type": "boolean",
      "label": "What If",
      "description": "Run a what-if preview only (no changes applied)",
      "required": false,
      "default": false
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Group Name",
      "required": false,
      "default": "infrastructure"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "description": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "description": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "description": "Retry Policy Backoff",
      "required": false,
      "default": "exponential",
      "enum": [
        "exponential",
        "linear",
        "fixed"
      ],
      "ui:widget": "select"
    }
  }
}
