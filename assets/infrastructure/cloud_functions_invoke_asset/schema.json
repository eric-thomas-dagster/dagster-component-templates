{
  "component_type": "dagster_component_templates.CloudFunctionsInvokeAssetComponent",
  "description": "Invoke a deployed Cloud Function (gen 1 or gen 2) or Cloud Run-deployed function with automatic OIDC authentication. Static-call mode (single request) or per-row mode (one call per upstream DataFrame row, with payload_template column substitution).",
  "category": "infrastructure",
  "icon": "si:googlecloud",
  "x-dagster-io": {
    "outputs": {
      "type": "DataFrame",
      "description": "One row with the function response (static mode) or upstream rows + response columns (per-row mode)."
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "credentials": {
      "type": "object",
      "label": "Credentials (dict)",
      "required": false,
      "default": null
    },
    "credentials_path": {
      "type": "string",
      "label": "Credentials Path",
      "required": false,
      "default": null
    },
    "function_url": {
      "type": "string",
      "label": "Function URL",
      "required": true,
      "description": "HTTPS URL of the function."
    },
    "method": {
      "type": "string",
      "label": "HTTP Method",
      "required": false,
      "default": "POST"
    },
    "payload": {
      "type": "object",
      "label": "Payload",
      "required": false,
      "default": null,
      "description": "Static request body. Mutually exclusive with upstream_asset_key."
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": false,
      "default": null
    },
    "payload_column": {
      "type": "string",
      "label": "Payload Column",
      "required": false,
      "default": null,
      "x-dagster-widget": "column"
    },
    "payload_template": {
      "type": "object",
      "label": "Payload Template",
      "required": false,
      "default": null,
      "description": "Static dict with {column} placeholders rendered per row."
    },
    "headers": {
      "type": "object",
      "label": "Headers",
      "required": false,
      "default": null
    },
    "timeout_seconds": {
      "type": "number",
      "label": "Timeout Seconds",
      "required": false,
      "default": 60.0
    },
    "max_retries": {
      "type": "integer",
      "label": "Max Retries",
      "required": false,
      "default": 3
    },
    "rate_limit_delay": {
      "type": "number",
      "label": "Rate Limit Delay",
      "required": false,
      "default": 0.0
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null,
      "ui:widget": "textarea"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    }
  },
  "tags": [
    "infrastructure",
    "google",
    "cloud-functions",
    "cloud-run",
    "compute",
    "trigger",
    "oidc"
  ],
  "name": "Cloud Functions Invoke"
}
