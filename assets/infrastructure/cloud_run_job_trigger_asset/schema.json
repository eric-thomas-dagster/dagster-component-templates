{
  "component_type": "dagster_component_templates.CloudRunJobTriggerAssetComponent",
  "description": "Trigger a single deployed Cloud Run job and wait for it to finish, with optional per-execution container overrides (env / args / task_count / timeout). Same shape as matillion_run_asset / rivery_run_asset / precisely_run_asset. Use google_cloud_run_jobs (integration) for batch import of all Cloud Run jobs in a project.",
  "category": "infrastructure",
  "icon": "si:googlecloud",
  "x-dagster-io": {"outputs": {"type": "DataFrame", "description": "One-row DataFrame describing the Execution (succeeded_count, failed_count, task_count, log_uri, start/completion_time)."}},
  "attributes": {
    "asset_name": {"type": "string", "label": "Asset Name", "required": true},
    "credentials": {"type": "object", "label": "Credentials (dict)", "required": false, "default": null},
    "credentials_path": {"type": "string", "label": "Credentials Path", "required": false, "default": null},
    "project_id": {"type": "string", "label": "Project ID", "required": false, "default": null},
    "location": {"type": "string", "label": "Location", "required": false, "default": "us-central1"},
    "job_name": {"type": "string", "label": "Job Name", "required": true, "description": "Cloud Run job name (no projects/.../jobs/ prefix)."},
    "container_overrides": {"type": "array", "label": "Container Overrides", "required": false, "default": null, "description": "List of {name, args?, env?} per container override."},
    "task_count": {"type": "integer", "label": "Task Count", "required": false, "default": null},
    "task_timeout_seconds": {"type": "integer", "label": "Task Timeout Seconds", "required": false, "default": null},
    "poll_interval_seconds": {"type": "number", "label": "Poll Interval Seconds", "required": false, "default": 5.0},
    "timeout_seconds": {"type": "number", "label": "Timeout Seconds", "required": false, "default": 3600.0},
    "description": {"type": "string", "label": "Description", "required": false, "default": null, "ui:widget": "textarea"},
    "group_name": {"type": "string", "label": "Group Name", "required": false, "default": null},
    "deps": {"type": "array", "label": "Deps", "required": false, "items": {"type": "string"}},
    "tags": {"type": "object", "label": "Tags", "required": false},
    "owners": {"type": "array", "label": "Owners", "required": false, "items": {"type": "string"}}
  },
  "tags": ["infrastructure", "google", "cloud-run", "compute", "trigger", "external-job"],
  "name": "Cloud Run Job Trigger"
}
