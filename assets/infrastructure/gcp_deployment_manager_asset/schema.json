{
  "component_type": "dagster_component_templates.GcpDeploymentManagerAssetComponent",
  "description": "Deploy a GCP Deployment Manager configuration (.yaml or jinja) as a Dagster asset.",
  "category": "infrastructure",
  "icon": "Shield",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name for this DM deployment",
      "required": true
    },
    "project_id": {
      "type": "string",
      "label": "Project Id",
      "description": "GCP project ID",
      "required": true
    },
    "deployment_name": {
      "type": "string",
      "label": "Deployment Name",
      "description": "Deployment Manager deployment name (idempotent)",
      "required": true
    },
    "config_file": {
      "type": "string",
      "label": "Config File",
      "description": "Local path to deployment config (YAML / jinja)",
      "required": true
    },
    "properties": {
      "type": "object",
      "label": "Properties",
      "description": "Inline property overrides",
      "required": false
    },
    "preview": {
      "type": "boolean",
      "label": "Preview",
      "description": "Preview only (don't apply)",
      "required": false,
      "default": false
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Group Name",
      "required": false,
      "default": "infrastructure"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "description": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "description": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "description": "Retry Policy Backoff",
      "required": false,
      "default": "exponential",
      "enum": [
        "exponential",
        "linear",
        "fixed"
      ],
      "ui:widget": "select"
    }
  }
}
