{
  "component_type": "dagster_component_templates.MatillionResource",
  "description": "Resource for connecting to the Matillion ETL REST API.",
  "category": "infrastructure",
  "icon": "Server",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Provisioning result"
    }
  },
  "attributes": {
    "instance_url": {
      "type": "string",
      "label": "Instance Url",
      "description": "Instance Url",
      "required": true
    },
    "username": {
      "type": "string",
      "label": "Username",
      "description": "Matillion username",
      "required": true
    },
    "password": {
      "type": "string",
      "label": "Password",
      "description": "Matillion password",
      "required": true,
      "ui:widget": "password"
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Dagster asset key (e.g. ",
      "required": true
    },
    "project": {
      "type": "string",
      "label": "Project",
      "description": "Matillion project name",
      "required": true
    },
    "version": {
      "type": "string",
      "label": "Version",
      "description": "Matillion project version name",
      "required": false,
      "default": "default"
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Matillion job name to run",
      "required": true
    },
    "instance_url_env_var": {
      "type": "string",
      "label": "Instance Url Env Var",
      "description": "Env var with Matillion instance URL",
      "required": false,
      "default": null
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "description": "Env var with Matillion username",
      "required": false,
      "default": null
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var with Matillion password",
      "required": false,
      "default": null,
      "ui:widget": "env_var"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Key of a MatillionResource",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    },
    "variables": {
      "type": "object",
      "label": "Variables",
      "description": "Job variable overrides passed at runtime",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    },
    "poll_interval_seconds": {
      "type": "number",
      "label": "Poll Interval Seconds",
      "description": "Seconds between status polls",
      "required": false,
      "default": 10.0
    },
    "timeout_seconds": {
      "type": "integer",
      "label": "Timeout Seconds",
      "description": "Max seconds to wait for job completion",
      "required": false,
      "default": 3600
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Dagster asset group name",
      "required": false,
      "default": "matillion"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Owners",
      "description": "Asset owners \u2014 team names (team:analytics) or email addresses.",
      "required": false,
      "ui:widget": "list"
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Key-value tags applied to the asset in the Dagster catalog, e.g. {\"domain\": \"finance\"}.",
      "required": false,
      "ui:widget": "key-value"
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Kinds",
      "description": "Asset kinds shown in the Dagster catalog (e.g. snowflake, python). Auto-inferred from component name if empty.",
      "required": false,
      "ui:widget": "list"
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag (minutes)",
      "description": "Maximum acceptable lag in minutes before this asset is considered stale.",
      "required": false,
      "default": null
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron Schedule",
      "description": "Cron schedule for the freshness policy, e.g. '0 9 * * 1-5' (weekdays 9am).",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "infrastructure",
    "matillion",
    "run",
    "asset"
  ],
  "name": "Matillion Run Asset"
