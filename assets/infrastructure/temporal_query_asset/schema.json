{
  "component_type": "dagster_community_components.TemporalQueryAssetComponent",
  "description": "Materialize the live state of a running Temporal workflow via a Query (read-only). Great for long-lived workflows exposing accumulated state.",
  "category": "infrastructure",
  "icon": "si:temporal",
  "attributes": {
    "asset_key": {"type": "string", "required": true},
    "workflow_id": {"type": "string", "required": true},
    "query_name": {"type": "string", "required": true},
    "query_args": {"type": "array", "required": false},
    "query_arg": {"type": "object", "required": false},
    "query_timeout_seconds": {"type": "integer", "required": false, "default": 30},
    "target_host": {"type": "string", "required": false, "default": "localhost:7233"},
    "namespace": {"type": "string", "required": false, "default": "default"},
    "api_key_env_var": {"type": "string", "required": false},
    "tls_cert_env_var": {"type": "string", "required": false},
    "tls_key_env_var": {"type": "string", "required": false},
    "tls_server_root_ca_env_var": {"type": "string", "required": false},
    "group_name": {"type": "string", "required": false, "default": "temporal"},
    "description": {"type": "string", "required": false},
    "owners": {"type": "array", "required": false},
    "tags": {"type": "object", "required": false},
    "kinds": {"type": "array", "required": false},
    "deps": {"type": "array", "required": false}
  }
}
