{
  "component_type": "dagster_component_templates.TerraformAssetComponent",
  "description": "Provision infrastructure with Terraform as a Dagster asset.",
  "category": "infrastructure",
  "icon": "Server",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Provisioning result"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "working_dir": {
      "type": "string",
      "label": "Working Dir",
      "description": "Path to the Terraform root module directory",
      "required": true
    },
    "workspace": {
      "type": "string",
      "label": "Workspace",
      "description": "Terraform workspace to select before running. Uses the default workspace if None.",
      "required": false,
      "default": null
    },
    "var_files": {
      "type": "string",
      "label": "Var Files",
      "description": "List of .tfvars files passed as -var-file arguments",
      "required": false,
      "default": null
    },
    "vars": {
      "type": "object",
      "label": "Vars",
      "description": "Inline variable overrides passed as -var key=value",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    },
    "targets": {
      "type": "string",
      "label": "Targets",
      "description": "Limit apply/plan scope to specific resources via -target",
      "required": false,
      "default": null
    },
    "terraform_bin": {
      "type": "string",
      "label": "Terraform Bin",
      "description": "Path to the terraform binary (default: ",
      "required": false,
      "default": "terraform"
    },
    "init_on_run": {
      "type": "boolean",
      "label": "Init On Run",
      "description": "Run ",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "plan_only": {
      "type": "boolean",
      "label": "Plan Only",
      "description": "Only run ",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "destroy": {
      "type": "boolean",
      "label": "Destroy",
      "description": "Run ",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "parallelism": {
      "type": "integer",
      "label": "Parallelism",
      "description": "Parallelism",
      "required": false,
      "default": 10
    },
    "auto_approve": {
      "type": "boolean",
      "label": "Auto Approve",
      "description": "Pass -auto-approve to apply/destroy. Set False to require manual approval.",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "env_vars": {
      "type": "object",
      "label": "Env Vars",
      "description": "Env Vars",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Dagster asset group name",
      "required": false,
      "default": "infrastructure"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Owners",
      "description": "Asset owners \u2014 team names (team:analytics) or email addresses.",
      "required": false,
      "ui:widget": "list"
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Key-value tags applied to the asset in the Dagster catalog, e.g. {\"domain\": \"finance\"}.",
      "required": false,
      "ui:widget": "key-value"
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Kinds",
      "description": "Asset kinds shown in the Dagster catalog (e.g. snowflake, python). Auto-inferred from component name if empty.",
      "required": false,
      "ui:widget": "list"
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag (minutes)",
      "description": "Maximum acceptable lag in minutes before this asset is considered stale.",
      "required": false,
      "default": null
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron Schedule",
      "description": "Cron schedule for the freshness policy, e.g. '0 9 * * 1-5' (weekdays 9am).",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Human-readable description of what this Terraform module provisions",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream Dagster asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    },
    "column_lineage": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Column Lineage",
      "required": false
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "required": false
    },
    "partition_date_column": {
      "type": "string",
      "label": "Partition Date Column",
      "required": false
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "required": false
    },
    "partition_static_dim": {
      "type": "string",
      "label": "Partition Static Dim",
      "required": false
    },
    "partition_static_column": {
      "type": "string",
      "label": "Partition Static Column",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "required": false,
      "default": "exponential"
    },
    "dynamic_partition_name": {
      "type": "string",
      "label": "Dynamic Partition Name",
      "description": "Name for DynamicPartitionsDefinition (when partition_type='dynamic'), e.g. 'tenants'.",
      "required": false,
      "default": null
    },
    "partition_dimensions": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "label": "Partition Dimensions",
      "description": "Multi-axis partition spec: list of {name, type, start, values, dynamic_partition_name} dicts. Overrides flat fields when set.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "infrastructure",
    "terraform",
    "asset"
  ],
  "name": "Terraform Asset"
}