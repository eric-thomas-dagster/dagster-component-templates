{
  "component_type": "dagster_component_templates.ADLSToDatabaseAssetComponent",
  "description": "Read a file from ADLS Gen2 and write it to a database table.",
  "category": "ingestion",
  "icon": "ArrowUpFromLine",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Ingestion result with row count"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "connection_string_env_var": {
      "type": "string",
      "label": "Connection String Env Var",
      "description": "Env var with ADLS connection string",
      "required": true
    },
    "database_url_env_var": {
      "type": "string",
      "label": "Database Url Env Var",
      "description": "Env var with SQLAlchemy database URL",
      "required": true
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Destination table name",
      "required": true
    },
    "schema_name": {
      "type": "string",
      "label": "Schema Name",
      "description": "Destination schema name",
      "required": false,
      "default": null
    },
    "if_exists": {
      "type": "string",
      "label": "If Exists",
      "description": "fail, replace, or append",
      "required": false,
      "default": "append"
    },
    "file_format": {
      "type": "string",
      "label": "File Format",
      "description": "csv, json, parquet, or auto",
      "required": false,
      "default": "auto"
    },
    "csv_delimiter": {
      "type": "string",
      "label": "Csv Delimiter",
      "description": "CSV delimiter",
      "required": false,
      "default": ""
    },
    "column_mapping": {
      "type": "object",
      "label": "Column Mapping",
      "description": "Rename columns: {old: new}",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group name",
      "required": false,
      "default": "ingestion"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "none, daily, weekly, or monthly",
      "required": false,
      "default": "none"
    },
    "partition_start_date": {
      "type": "string",
      "label": "Partition Start Date",
      "description": "Partition Start Date",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "ingestion",
    "adls",
    "database",
    "asset"
  ]
}