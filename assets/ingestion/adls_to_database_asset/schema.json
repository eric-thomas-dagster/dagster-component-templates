{
  "component_type": "dagster_component_templates.ADLSToDatabaseAssetComponent",
  "description": "Read a file from ADLS Gen2 and write it to a database table.",
  "category": "ingestion",
  "icon": "si:microsoftazure",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Ingestion result with row count"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "connection_string_env_var": {
      "type": "string",
      "label": "Connection String Env Var",
      "description": "Env var with ADLS connection string",
      "required": true
    },
    "database_url_env_var": {
      "type": "string",
      "label": "Database Url Env Var",
      "description": "Env var with SQLAlchemy database URL",
      "required": true
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Destination table name",
      "required": true
    },
    "schema_name": {
      "type": "string",
      "label": "Schema Name",
      "description": "Destination schema name",
      "required": false,
      "default": null
    },
    "if_exists": {
      "type": "string",
      "label": "If Exists",
      "description": "fail, replace, or append",
      "required": false,
      "default": "append"
    },
    "file_format": {
      "type": "string",
      "label": "File Format",
      "description": "csv, json, parquet, or auto",
      "required": false,
      "default": "auto"
    },
    "csv_delimiter": {
      "type": "string",
      "label": "Csv Delimiter",
      "description": "CSV delimiter",
      "required": false,
      "default": ""
    },
    "column_mapping": {
      "type": "object",
      "label": "Column Mapping",
      "description": "Rename columns: {old: new}",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group name",
      "required": false,
      "default": "ingestion"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Owners",
      "description": "Asset owners \u2014 team names (team:analytics) or email addresses.",
      "required": false,
      "ui:widget": "list"
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Key-value tags applied to the asset in the Dagster catalog, e.g. {\"domain\": \"finance\"}.",
      "required": false,
      "ui:widget": "key-value"
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Kinds",
      "description": "Asset kinds shown in the Dagster catalog (e.g. snowflake, python). Auto-inferred from component name if empty.",
      "required": false,
      "ui:widget": "list"
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag (minutes)",
      "description": "Maximum acceptable lag in minutes before this asset is considered stale.",
      "required": false,
      "default": null
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron Schedule",
      "description": "Cron schedule for the freshness policy, e.g. '0 9 * * 1-5' (weekdays 9am).",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "none, daily, weekly, or monthly",
      "required": false,
      "default": "none"
    },
    "partition_start_date": {
      "type": "string",
      "label": "Partition Start Date",
      "description": "Partition Start Date",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "ingestion",
    "adls",
    "database",
    "asset"
  ]
}