{
  "component_type": "dagster_component_templates.ContentIngestionComponent",
  "description": "Component for ingesting user-generated content for moderation.",
  "category": "ingestion",
  "icon": "ArrowUpFromLine",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Ingestion result with row count"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Name of the asset to create",
      "required": true
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Asset description",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "required": false,
      "default": false
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "required": false,
      "default": 25
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "required": false,
      "default": "exponential"
    }
  },
  "tags": [
    "ingestion",
    "content"
  ],
  "name": "Content Ingestion"
}
