{
  "component_type": "dagster_component_templates.CSVFileIngestionComponent",
  "description": "Component for ingesting CSV files into Dagster assets.",
  "category": "ingestion",
  "icon": "ArrowUpFromLine",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Ingestion result with row count"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Name of the asset",
      "required": true
    },
    "file_path": {
      "type": "string",
      "label": "File Path",
      "description": "Path to the CSV file to ingest",
      "required": true,
      "ui:widget": "file"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description of the asset",
      "required": false,
      "default": "",
      "ui:widget": "code"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group name for organization",
      "required": false,
      "default": ""
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Owners",
      "description": "Asset owners \u2014 team names (team:analytics) or email addresses.",
      "required": false,
      "ui:widget": "list"
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Key-value tags applied to the asset in the Dagster catalog, e.g. {\"domain\": \"finance\"}.",
      "required": false,
      "ui:widget": "key-value"
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Kinds",
      "description": "Asset kinds shown in the Dagster catalog (e.g. snowflake, python). Auto-inferred from component name if empty.",
      "required": false,
      "ui:widget": "list"
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag (minutes)",
      "description": "Maximum acceptable lag in minutes before this asset is considered stale.",
      "required": false,
      "default": null
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron Schedule",
      "description": "Cron schedule for the freshness policy, e.g. '0 9 * * 1-5' (weekdays 9am).",
      "required": false,
      "default": null
    },
    "delimiter": {
      "type": "string",
      "label": "Delimiter",
      "description": "CSV delimiter character",
      "required": false,
      "default": ""
    },
    "encoding": {
      "type": "string",
      "label": "Encoding",
      "description": "File encoding",
      "required": false,
      "default": "utf-8"
    },
    "skip_rows": {
      "type": "integer",
      "label": "Skip Rows",
      "description": "Number of rows to skip at the start",
      "required": false,
      "default": 0
    },
    "header_row": {
      "type": "integer",
      "label": "Header Row",
      "description": "Header Row",
      "required": false,
      "default": 0
    },
    "columns_to_read": {
      "type": "string",
      "label": "Columns To Read",
      "description": "Columns To Read",
      "required": false,
      "default": ""
    },
    "dtype_mapping": {
      "type": "string",
      "label": "Dtype Mapping",
      "description": "Column type mappings as JSON string, e.g. {\\",
      "required": false,
      "default": ""
    },
    "parse_dates": {
      "type": "string",
      "label": "Parse Dates",
      "description": "Comma-separated list of columns to parse as dates",
      "required": false,
      "default": ""
    },
    "cache_to_parquet": {
      "type": "boolean",
      "label": "Cache To Parquet",
      "description": "Whether to cache the data to a parquet file for better performance",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "parquet_path": {
      "type": "string",
      "label": "Parquet Path",
      "description": "Parquet Path",
      "required": false,
      "default": ""
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Include Preview Metadata",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Rows to include in the preview metadata. For long DataFrames (>10x preview_rows), a random sample is used; otherwise head().",
      "required": false,
      "default": 25
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "required": false,
      "default": "exponential"
    }
  },
  "tags": [
    "ingestion",
    "csv",
    "file"
  ],
  "name": "CSV File Ingestion"
}
