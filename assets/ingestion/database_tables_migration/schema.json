{
  "component_type": "dagster_component_templates.DatabaseTablesMigrationComponent",
  "description": "DDL-first table migration: build portable CREATE TABLE statements from source INFORMATION_SCHEMA (types + PKs + FKs + NOT NULL + defaults) and execute on target. Emits per-table status DataFrame.",
  "category": "ingestion",
  "icon": "Table2",
  "x-dagster-io": {
    "inputs": {"type": "external", "description": "Reads source INFORMATION_SCHEMA for column + constraint metadata"},
    "outputs": {"type": "dataframe", "description": "Per-table status: schema_name, table_name, target_table, status, error_message, n_columns, n_foreign_keys, has_primary_key, ddl_preview"}
  },
  "attributes": {
    "asset_name": {"type": "string", "label": "Asset Name", "required": true},
    "source_connection_env_var": {"type": "string", "label": "Source Connection Env Var", "required": true, "ui:widget": "env_var"},
    "target_connection_env_var": {"type": "string", "label": "Target Connection Env Var", "required": true, "ui:widget": "env_var"},
    "source_type": {
      "type": "string", "label": "Source Type", "required": true,
      "enum": ["postgres", "mysql", "mssql", "oracle", "db2", "snowflake", "redshift", "duckdb"],
      "ui:widget": "select"
    },
    "target_type": {
      "type": "string", "label": "Target Type", "required": true,
      "enum": ["postgres", "mysql", "mssql", "oracle", "db2", "snowflake", "redshift", "duckdb"],
      "ui:widget": "select"
    },
    "schemas": {"type": "array", "items": {"type": "string"}, "label": "Source Schemas", "required": false},
    "include_patterns": {"type": "array", "items": {"type": "string"}, "label": "Include Patterns", "required": false},
    "exclude_patterns": {"type": "array", "items": {"type": "string"}, "label": "Exclude Patterns", "required": false},
    "target_schema": {"type": "string", "label": "Target Schema Override", "required": false},
    "table_replacements": {"type": "object", "label": "FK Table Replacements", "required": false, "ui:widget": "key-value"},
    "table_ddl_overrides": {"type": "object", "label": "Per-Table CREATE TABLE Overrides", "description": "Source qualified name → full CREATE TABLE SQL on target. Used for tables the auto-generator can't handle (XMLTYPE, etc.)", "required": false, "ui:widget": "key-value"},
    "drop_if_exists": {"type": "boolean", "label": "Drop If Exists", "required": false, "default": false},
    "include_primary_keys": {"type": "boolean", "label": "Include Primary Keys", "required": false, "default": true},
    "include_foreign_keys": {"type": "boolean", "label": "Include Foreign Keys", "required": false, "default": true},
    "include_check_constraints": {"type": "boolean", "label": "Include CHECK Constraints", "required": false, "default": true},
    "include_unique_constraints": {"type": "boolean", "label": "Include UNIQUE Constraints", "required": false, "default": true},
    "function_replacements": {"type": "object", "label": "CHECK Function Replacements", "description": "Substitutions applied to CHECK expressions (e.g. {'NVL': 'COALESCE'})", "required": false, "ui:widget": "key-value"},
    "dry_run": {"type": "boolean", "label": "Dry Run", "description": "Try every CREATE TABLE in a transaction then ROLLBACK — no state change. Status: would_succeed / would_fail.", "required": false, "default": false},
    "fail_on_any_error": {"type": "boolean", "label": "Fail On Any Error", "required": false, "default": false},
    "group_name": {"type": "string", "label": "Group Name", "required": false},
    "description": {"type": "string", "label": "Description", "required": false},
    "owners": {"type": "array", "items": {"type": "string"}, "label": "Owners", "required": false, "ui:widget": "list"},
    "asset_tags": {"type": "object", "label": "Asset Tags", "required": false, "ui:widget": "key-value"},
    "kinds": {"type": "array", "items": {"type": "string"}, "label": "Kinds", "required": false, "ui:widget": "list"},
    "deps": {"type": "array", "items": {"type": "string"}, "label": "Deps", "required": false}
  },
  "tags": ["ingestion", "migration", "ddl", "schema", "primary-key", "foreign-key", "warehouse"],
  "name": "Database Tables Migration"
}
