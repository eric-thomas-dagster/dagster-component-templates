{
  "component_type": "dagster_component_templates.DeltaIngestionComponent",
  "description": "Read from an EXISTING external Delta Lake table (S3 / ADLS / GCS / Unity Catalog) into a Dagster asset as a pandas DataFrame. Uses delta-rs (no Spark / JVM). Supports version + timestamp time-travel + partition-predicate pushdown.",
  "category": "ingestion",
  "icon": "si:databricks",
  "x-dagster-io": {
    "outputs": {
      "type": "Output[DataFrame]"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "table_uri": {
      "type": "string",
      "label": "Table URI",
      "description": "s3://, az://, gs://, /local, or uc://catalog.schema.table",
      "required": true
    },
    "storage_options": {
      "type": "object",
      "label": "Storage Options",
      "description": "Cloud credentials + config. ${ENV_VAR} expansion supported.",
      "required": false,
      "ui:widget": "key-value"
    },
    "select_columns": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Select Columns",
      "required": false,
      "ui:widget": "list",
      "x-dagster-widget": "columns"
    },
    "partition_filters": {
      "type": "array",
      "items": {
        "type": "array"
      },
      "label": "Partition Filters",
      "description": "List of [col, op, value] predicates. Supports {partition_key}.",
      "required": false
    },
    "version": {
      "type": "integer",
      "label": "Version",
      "required": false
    },
    "timestamp": {
      "type": "string",
      "label": "Timestamp (ISO)",
      "required": false
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "ui:widget": "code"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": "delta"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Owners",
      "required": false,
      "ui:widget": "list"
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false,
      "ui:widget": "key-value"
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Kinds",
      "required": false,
      "ui:widget": "list"
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag (minutes)",
      "required": false
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron",
      "required": false,
      "x-dagster-widget": "cron"
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "required": false,
      "default": 25
    },
    "deps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Deps",
      "required": false,
      "ui:widget": "list"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false,
      "enum": [
        "daily",
        "hourly",
        "weekly",
        "monthly",
        "static",
        "multi",
        "dynamic"
      ],
      "ui:widget": "select"
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "required": false
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "required": false
    },
    "dynamic_partition_name": {
      "type": "string",
      "label": "Dynamic Partition Name",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "required": false,
      "default": "exponential",
      "enum": [
        "exponential",
        "linear",
        "fixed"
      ],
      "ui:widget": "select"
    }
  },
  "tags": [
    "ingestion",
    "delta",
    "delta-lake",
    "lakehouse",
    "delta-rs",
    "databricks",
    "unity-catalog"
  ],
  "name": "Delta Lake Ingestion"
}
