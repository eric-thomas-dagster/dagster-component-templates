{
  "component_type": "dagster_component_templates.GoogleCalendarIngestionComponent",
  "description": "List events from a Google Calendar via a service account. Returns one row per event with summary, time, location, attendees, organizer, html_link.",
  "category": "ingestion",
  "icon": "si:googlecalendar",
  "x-dagster-io": {
    "outputs": {
      "type": "DataFrame",
      "description": "One row per event in the time window."
    }
  },
  "attributes": {
    "asset_name": {"type": "string", "label": "Asset Name", "required": true},
    "credentials": {"type": "object", "label": "Credentials (dict)", "required": false, "default": null},
    "credentials_path": {"type": "string", "label": "Credentials Path", "required": false, "default": null, "description": "Falls back to GOOGLE_APPLICATION_CREDENTIALS."},
    "calendar_id": {"type": "string", "label": "Calendar ID", "required": false, "default": "primary", "description": "Use the OWNER's email or a named calendar ID — not 'primary' (which is the SA's own empty calendar)."},
    "time_min": {"type": "string", "label": "Time Min (RFC3339)", "required": false, "default": null, "description": "Defaults to now."},
    "time_max": {"type": "string", "label": "Time Max (RFC3339)", "required": false, "default": null, "description": "Defaults to now + days_ahead."},
    "days_ahead": {"type": "integer", "label": "Days Ahead", "required": false, "default": 30, "description": "Used when time_max is unset."},
    "max_results": {"type": "integer", "label": "Max Results", "required": false, "default": 250},
    "single_events": {"type": "boolean", "label": "Single Events", "required": false, "default": true, "description": "Expand recurring events into individual instances."},
    "show_deleted": {"type": "boolean", "label": "Show Deleted", "required": false, "default": false},
    "description": {"type": "string", "label": "Description", "required": false, "default": null, "ui:widget": "textarea"},
    "group_name": {"type": "string", "label": "Group Name", "required": false, "default": null},
    "deps": {"type": "array", "label": "Deps", "required": false, "items": {"type": "string"}},
    "tags": {"type": "object", "label": "Tags", "required": false},
    "owners": {"type": "array", "label": "Owners", "required": false, "items": {"type": "string"}},
    "partition_type": {"type": "string", "label": "Partition Type", "required": false, "default": null},
    "partition_start": {"type": "string", "label": "Partition Start", "required": false, "default": null},
    "partition_values": {"type": "string", "label": "Partition Values", "required": false, "default": null},
    "dynamic_partition_name": {"type": "string", "label": "Dynamic Partition Name", "required": false, "default": null},
    "partition_dimensions": {"type": "array", "label": "Partition Dimensions", "required": false}
  },
  "tags": ["ingestion", "google", "calendar", "events", "scheduling"],
  "name": "Google Calendar Ingestion"
}
