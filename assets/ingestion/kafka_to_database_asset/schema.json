{
  "component_type": "dagster_component_templates.KafkaToDatabaseAssetComponent",
  "description": "Consume messages from a Kafka topic and write them to a database table.",
  "category": "ingestion",
  "icon": "ArrowUpFromLine",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Ingestion result with row count"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "bootstrap_servers_env_var": {
      "type": "string",
      "label": "Bootstrap Servers Env Var",
      "description": "Bootstrap Servers Env Var",
      "required": true
    },
    "database_url_env_var": {
      "type": "string",
      "label": "Database Url Env Var",
      "description": "Env var with SQLAlchemy database URL",
      "required": true
    },
    "topic": {
      "type": "string",
      "label": "Topic",
      "description": "Kafka topic to consume from",
      "required": true
    },
    "consumer_group": {
      "type": "string",
      "label": "Consumer Group",
      "description": "Kafka consumer group ID",
      "required": false,
      "default": "dagster-ingestion"
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Destination table name",
      "required": true
    },
    "schema_name": {
      "type": "string",
      "label": "Schema Name",
      "description": "Destination schema name",
      "required": false,
      "default": null
    },
    "if_exists": {
      "type": "string",
      "label": "If Exists",
      "description": "fail, replace, or append",
      "required": false,
      "default": "append"
    },
    "max_messages": {
      "type": "integer",
      "label": "Max Messages",
      "description": "Max messages to consume per run",
      "required": false,
      "default": 10000
    },
    "poll_timeout_seconds": {
      "type": "number",
      "label": "Poll Timeout Seconds",
      "description": "Seconds to wait for messages before stopping",
      "required": false,
      "default": 5.0
    },
    "security_protocol": {
      "type": "string",
      "label": "Security Protocol",
      "description": "PLAINTEXT, SSL, SASL_PLAINTEXT, SASL_SSL",
      "required": false,
      "default": "PLAINTEXT"
    },
    "sasl_mechanism": {
      "type": "string",
      "label": "Sasl Mechanism",
      "description": "PLAIN, SCRAM-SHA-256, SCRAM-SHA-512",
      "required": false,
      "default": null
    },
    "sasl_username_env_var": {
      "type": "string",
      "label": "Sasl Username Env Var",
      "description": "Env var with SASL username",
      "required": false,
      "default": null
    },
    "sasl_password_env_var": {
      "type": "string",
      "label": "Sasl Password Env Var",
      "description": "Env var with SASL password",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "column_mapping": {
      "type": "object",
      "label": "Column Mapping",
      "description": "Rename columns: {old: new}",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group name",
      "required": false,
      "default": "ingestion"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "none, daily, weekly, or monthly",
      "required": false,
      "default": "none"
    },
    "partition_start_date": {
      "type": "string",
      "label": "Partition Start Date",
      "description": "Partition Start Date",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "ingestion",
    "kafka",
    "database",
    "asset"
  ]
}