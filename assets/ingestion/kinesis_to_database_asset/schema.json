{
  "component_type": "dagster_component_templates.KinesisToDatabaseAssetComponent",
  "description": "Read records from a Kinesis Data Stream and write them to a database table.",
  "category": "ingestion",
  "icon": "ArrowUpFromLine",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Ingestion result with row count"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "stream_name": {
      "type": "string",
      "label": "Stream Name",
      "description": "Kinesis stream name",
      "required": true
    },
    "database_url_env_var": {
      "type": "string",
      "label": "Database Url Env Var",
      "description": "Env var with SQLAlchemy database URL",
      "required": true
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Destination table name",
      "required": true
    },
    "schema_name": {
      "type": "string",
      "label": "Schema Name",
      "description": "Destination schema name",
      "required": false,
      "default": null
    },
    "if_exists": {
      "type": "string",
      "label": "If Exists",
      "description": "fail, replace, or append",
      "required": false,
      "default": "append"
    },
    "max_records": {
      "type": "integer",
      "label": "Max Records",
      "description": "Max records to consume per run",
      "required": false,
      "default": 10000
    },
    "shard_iterator_type": {
      "type": "string",
      "label": "Shard Iterator Type",
      "description": "TRIM_HORIZON, LATEST, AT_SEQUENCE_NUMBER, AFTER_SEQUENCE_NUMBER",
      "required": false,
      "default": "TRIM_HORIZON"
    },
    "region_name": {
      "type": "string",
      "label": "Region Name",
      "description": "AWS region",
      "required": false,
      "default": "us-east-1"
    },
    "aws_access_key_env_var": {
      "type": "string",
      "label": "Aws Access Key Env Var",
      "description": "Env var with AWS access key ID",
      "required": false,
      "default": null
    },
    "aws_secret_key_env_var": {
      "type": "string",
      "label": "Aws Secret Key Env Var",
      "description": "Env var with AWS secret access key",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "column_mapping": {
      "type": "object",
      "label": "Column Mapping",
      "description": "Rename columns: {old: new}",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group name",
      "required": false,
      "default": "ingestion"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "none, daily, weekly, or monthly",
      "required": false,
      "default": "none"
    },
    "partition_start_date": {
      "type": "string",
      "label": "Partition Start Date",
      "description": "Partition Start Date",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "ingestion",
    "kinesis",
    "database",
    "asset"
  ]
}