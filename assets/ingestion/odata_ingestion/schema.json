{
  "component_type": "dagster_component_templates.ODataIngestionComponent",
  "description": "Generic OData v2/v4 client. Covers SAP S/4HANA, SuccessFactors, Datasphere, Microsoft Dynamics 365 / Dataverse, MS Graph, SharePoint, Business Central, Oracle Fusion, Epicor, IFS, and any other OData-exposing system.",
  "category": "ingestion",
  "icon": "si:odata",
  "x-dagster-io": {
    "outputs": {
      "type": "Output[DataFrame]",
      "description": "Flattened OData response as a pandas DataFrame"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "service_url": {
      "type": "string",
      "label": "Service URL",
      "description": "Base service URL (no entity set).",
      "required": true
    },
    "entity_set": {
      "type": "string",
      "label": "Entity Set",
      "description": "Entity collection name appended to service_url.",
      "required": true
    },
    "odata_version": {
      "type": "string",
      "label": "OData Version",
      "description": "'v2' (default) or 'v4'.",
      "required": false,
      "default": "v2"
    },
    "select": {
      "type": "string",
      "label": "$select",
      "required": false
    },
    "filter": {
      "type": "string",
      "label": "$filter",
      "description": "Supports {partition_key} template.",
      "required": false,
      "ui:widget": "code"
    },
    "expand": {
      "type": "string",
      "label": "$expand",
      "required": false
    },
    "orderby": {
      "type": "string",
      "label": "$orderby",
      "required": false
    },
    "top": {
      "type": "integer",
      "label": "$top",
      "required": false
    },
    "extra_query": {
      "type": "object",
      "label": "Extra Query Options",
      "required": false,
      "ui:widget": "key-value"
    },
    "auth_type": {
      "type": "string",
      "label": "Auth Type",
      "description": "'basic' | 'bearer' | 'none'",
      "required": false,
      "default": "basic"
    },
    "auth_username_env_var": {
      "type": "string",
      "label": "Auth Username Env Var",
      "required": false
    },
    "auth_password_env_var": {
      "type": "string",
      "label": "Auth Password Env Var",
      "required": false
    },
    "auth_token_env_var": {
      "type": "string",
      "label": "Auth Token Env Var",
      "required": false
    },
    "extra_headers": {
      "type": "object",
      "label": "Extra Headers",
      "required": false,
      "ui:widget": "key-value"
    },
    "verify_ssl": {
      "type": "boolean",
      "label": "Verify SSL",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "max_pages": {
      "type": "integer",
      "label": "Max Pages",
      "required": false,
      "default": 1000
    },
    "timeout_seconds": {
      "type": "integer",
      "label": "Timeout (seconds)",
      "required": false,
      "default": 120
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "ui:widget": "code"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": "odata"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Owners",
      "required": false,
      "ui:widget": "list"
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false,
      "ui:widget": "key-value"
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Kinds",
      "description": "Defaults to ['odata'].",
      "required": false,
      "ui:widget": "list"
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag (minutes)",
      "required": false
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron",
      "required": false,
      "x-dagster-widget": "cron"
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "required": false,
      "default": 25
    },
    "deps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Deps",
      "required": false,
      "ui:widget": "list"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false,
      "enum": [
        "daily",
        "hourly",
        "weekly",
        "monthly",
        "static",
        "multi",
        "dynamic"
      ],
      "ui:widget": "select"
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "required": false
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "required": false
    },
    "dynamic_partition_name": {
      "type": "string",
      "label": "Dynamic Partition Name",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "required": false,
      "default": "exponential",
      "enum": [
        "exponential",
        "linear",
        "fixed"
      ],
      "ui:widget": "select"
    }
  },
  "tags": [
    "ingestion",
    "odata",
    "sap",
    "s4hana",
    "successfactors",
    "datasphere",
    "dynamics365",
    "dataverse",
    "msgraph",
    "sharepoint",
    "oracle-fusion",
    "epicor"
  ],
  "name": "OData Ingestion"
}
