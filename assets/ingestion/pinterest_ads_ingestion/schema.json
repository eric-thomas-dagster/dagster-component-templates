      "required": false
    },
    "partition_static_dim": {
      "type": "string",
      "label": "Partition Static Dim",
      "required": false,
      "x-dagster-widget": "column"
    },
    "partition_static_column": {
      "type": "string",
      "label": "Partition Static Column",
      "required": false,
      "x-dagster-widget": "column"
