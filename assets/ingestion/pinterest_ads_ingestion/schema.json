    "dataset_name": {
      "type": "string",
      "label": "Dataset Name",
      "required": false
    },
    "persist_only": {
      "type": "boolean",
      "label": "Persist Only",
      "required": false,
      "default": false
    },
    "destination_credentials_url": {
      "type": "string",
      "label": "Destination Credentials Url",
      "required": false
    },
    "destination_credentials_env_var": {
      "type": "string",
      "label": "Destination Credentials Env Var",
      "required": false
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false,
      "enum": [
        "daily",
        "hourly",
        "weekly",
        "monthly",
