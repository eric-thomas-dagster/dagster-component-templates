    "app_secret": {
      "type": "string",
      "label": "App Secret",
      "description": "App Secret",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "resources": {
      "type": "string",
      "label": "Resources",
      "description": "Comma-separated list of resources to extract: ad_accounts, campaigns, ad_groups, ads, pins, keywords, analytics",
