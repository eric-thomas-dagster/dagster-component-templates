{
  "component_type": "dagster_component_templates.PulsarToDatabaseAssetComponent",
  "description": "Consume messages from an Apache Pulsar topic and write to a database table.",
  "category": "ingestion",
  "icon": "ArrowUpFromLine",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Ingestion result with row count"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "service_url_env_var": {
      "type": "string",
      "label": "Service Url Env Var",
      "description": "Service Url Env Var",
      "required": true
    },
    "topic": {
      "type": "string",
      "label": "Topic",
      "description": "Topic",
      "required": true
    },
    "subscription_name": {
      "type": "string",
      "label": "Subscription Name",
      "description": "Pulsar subscription name",
      "required": false,
      "default": "dagster-ingest",
      "ui:widget": "code"
    },
    "subscription_type": {
      "type": "string",
      "label": "Subscription Type",
      "description": "Exclusive, Shared, Failover, or KeyShared",
      "required": false,
      "default": "Shared",
      "ui:widget": "code"
    },
    "token_env_var": {
      "type": "string",
      "label": "Token Env Var",
      "description": "Env var with Pulsar JWT auth token",
      "required": false,
      "default": null
    },
    "database_url_env_var": {
      "type": "string",
      "label": "Database Url Env Var",
      "description": "Env var with SQLAlchemy database URL",
      "required": true
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Destination table name",
      "required": true
    },
    "schema_name": {
      "type": "string",
      "label": "Schema Name",
      "description": "Destination schema name",
      "required": false,
      "default": null
    },
    "if_exists": {
      "type": "string",
      "label": "If Exists",
      "description": "fail, replace, or append",
      "required": false,
      "default": "append"
    },
    "max_messages": {
      "type": "integer",
      "label": "Max Messages",
      "description": "Max messages to consume per run",
      "required": false,
      "default": 10000
    },
    "receive_timeout_ms": {
      "type": "integer",
      "label": "Receive Timeout Ms",
      "description": "Timeout in ms for each receive call",
      "required": false,
      "default": 5000
    },
    "column_mapping": {
      "type": "object",
      "label": "Column Mapping",
      "description": "Rename columns: {old: new}",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group name",
      "required": false,
      "default": "ingestion"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Owners",
      "description": "Asset owners \u2014 team names (team:analytics) or email addresses.",
      "required": false,
      "ui:widget": "list"
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Key-value tags applied to the asset in the Dagster catalog, e.g. {\"domain\": \"finance\"}.",
      "required": false,
      "ui:widget": "key-value"
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Kinds",
      "description": "Asset kinds shown in the Dagster catalog (e.g. snowflake, python). Auto-inferred from component name if empty.",
      "required": false,
      "ui:widget": "list"
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag (minutes)",
      "description": "Maximum acceptable lag in minutes before this asset is considered stale.",
      "required": false,
      "default": null
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron Schedule",
      "description": "Cron schedule for the freshness policy, e.g. '0 9 * * 1-5' (weekdays 9am).",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "none, daily, weekly, or monthly",
      "required": false,
      "default": "none"
    },
    "partition_start_date": {
      "type": "string",
      "label": "Partition Start Date",
      "description": "Partition Start Date",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "ingestion",
    "pulsar",
    "database",
    "asset"
  ],
  "connectors": {
    "left": false,
    "right": false
  }
}
