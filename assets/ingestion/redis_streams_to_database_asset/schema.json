      "type": "string",
      "label": "Redis Url Env Var",
      "description": "Redis Url Env Var",
      "required": true
    },
    "stream_name": {
      "type": "string",
      "label": "Stream Name",
      "description": "Stream Name",
      "required": true
    },
    "consumer_group": {
      "type": "string",
      "label": "Consumer Group",
      "description": "Consumer Group",
      "required": false,
      "default": null
