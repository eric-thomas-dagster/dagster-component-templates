    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "How many rows to include in the preview. Large tables (>10\u00d7 this number) are sampled randomly.",
      "required": false,
      "default": 25
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false,
      "enum": [
        "daily",
        "hourly",
        "weekly",
        "monthly",
        "static",
        "multi",
        "dynamic"
      ],
      "ui:widget": "select"
