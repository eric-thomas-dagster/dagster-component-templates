  "category": "ingestion",
  "icon": "ArrowUpFromLine",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Ingestion result with row count"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Name of the asset to create",
      "required": true
    },
    "username": {
      "type": "string",
      "label": "Username",
      "description": "Salesforce username",
      "required": true
    },
    "password": {
      "type": "string",
      "label": "Password",
      "description": "Salesforce password",
      "required": true,
      "ui:widget": "password"
    },
    "security_token": {
      "type": "string",
      "label": "Security Token",
      "description": "Security Token",
      "required": true,
      "ui:widget": "password"
    },
    "sf_objects": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Sf Objects",
      "description": "Sf Objects",
      "required": false,
      "default": "[\"Account\"",
      "ui:widget": "list"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Asset description",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
