      "type": "string",
      "label": "Destination Config",
      "description": "Optional destination configuration as connection string or JSON. Required if destination is set.",
      "required": false,
      "default": null
    },
    "persist_and_return": {
      "type": "boolean",
      "label": "Persist And Return",
      "description": "If True with destination set: persist to database AND return DataFrame. If False: only persist to database.",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "deps": {
      "type": "string",
      "label": "Deps",
      "description": "Upstream asset keys this asset depends on (e.g. [",
      "required": false,
      "default": null
