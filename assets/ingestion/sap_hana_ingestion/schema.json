{
  "component_type": "dagster_component_templates.SapHanaIngestionComponent",
  "description": "Query SAP HANA (Cloud or on-premise) and return the result as a Dagster asset (pandas DataFrame).",
  "category": "ingestion",
  "icon": "si:sap",
  "x-dagster-io": {
    "outputs": {
      "type": "Output[DataFrame]",
      "description": "Query result as a pandas DataFrame"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "connection_url_env_var": {
      "type": "string",
      "label": "Connection URL Env Var",
      "description": "Env var holding a full SQLAlchemy HANA URL (e.g. 'hana://user:pwd@host:443?encrypt=true'). If unset, uses host/port/user/password_env_var.",
      "required": false
    },
    "host": {
      "type": "string",
      "label": "Host",
      "description": "HANA host. Required if connection_url_env_var is unset.",
      "required": false
    },
    "port": {
      "type": "integer",
      "label": "Port",
      "description": "443 for HANA Cloud, 30015 for on-prem default.",
      "required": false,
      "default": 443
    },
    "database": {
      "type": "string",
      "label": "Database",
      "description": "Tenant DB name (multi-tenant only). HANA Cloud: leave empty.",
      "required": false
    },
    "user": {
      "type": "string",
      "label": "User",
      "description": "HANA user. Required if connection_url_env_var is unset.",
      "required": false
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var holding the HANA user's password.",
      "required": false
    },
    "encrypt": {
      "type": "boolean",
      "label": "Encrypt (TLS)",
      "description": "TLS — required for HANA Cloud.",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "validate_certificate": {
      "type": "boolean",
      "label": "Validate Certificate",
      "description": "Verify the server certificate.",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "query": {
      "type": "string",
      "label": "SQL Query",
      "description": "SQL query. Supports '{partition_key}' template substitution. Use this OR table_name.",
      "required": false,
      "ui:widget": "code"
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Table or view name. Generates 'SELECT * FROM <schema>.<table>'.",
      "required": false
    },
    "schema_name": {
      "type": "string",
      "label": "Schema Name",
      "description": "Schema for table_name (e.g. 'SAPABAP1', '_SYS_BIC').",
      "required": false
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "ui:widget": "code"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": "sap_hana"
    },
    "owners": {
      "type": "array",
      "items": {"type": "string"},
      "label": "Owners",
      "required": false,
      "ui:widget": "list"
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false,
      "ui:widget": "key-value"
    },
    "kinds": {
      "type": "array",
      "items": {"type": "string"},
      "label": "Kinds",
      "description": "Defaults to ['hana', 'sql'].",
      "required": false,
      "ui:widget": "list"
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag (minutes)",
      "required": false
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron Schedule",
      "required": false
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "required": false,
      "default": 25
    },
    "deps": {
      "type": "array",
      "items": {"type": "string"},
      "label": "Deps",
      "required": false,
      "ui:widget": "list"
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "'daily' | 'weekly' | 'monthly' | 'hourly' | 'static' | 'dynamic'",
      "required": false
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "description": "ISO start date for time-based partitions.",
      "required": false
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "required": false
    },
    "dynamic_partition_name": {
      "type": "string",
      "label": "Dynamic Partition Name",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "required": false,
      "default": "exponential"
    }
  },
  "tags": ["ingestion", "sap", "hana", "sql"],
  "name": "SAP HANA Ingestion"
}
