{
  "component_type": "dagster_component_templates.SapRFCIngestionComponent",
  "description": "Execute an SAP RFC / BAPI / RFC_READ_TABLE and materialize the result as a pandas DataFrame. Classic on-prem R/3 / ECC / S/4HANA integration path. Pairs with sap_rfc_resource.",
  "category": "ingestion",
  "icon": "si:sap",
  "x-dagster-io": {"outputs": {"type": "Output[DataFrame]"}},
  "attributes": {
    "asset_name": {"type": "string", "label": "Asset Name", "required": true},
    "sap_rfc_resource_key": {"type": "string", "label": "SAP RFC Resource Key", "required": true},
    "mode": {"type": "string", "label": "Mode", "description": "'read_table' (default) | 'bapi'", "required": false, "default": "read_table"},
    "table_name": {"type": "string", "label": "Table Name", "description": "For mode='read_table'", "required": false},
    "fields": {"type": "array", "items": {"type": "string"}, "label": "Fields", "required": false, "ui:widget": "list"},
    "where_clause": {"type": "string", "label": "WHERE Clause", "description": "Supports {partition_key}", "required": false, "ui:widget": "code"},
    "delimiter": {"type": "string", "label": "Delimiter", "required": false, "default": "|"},
    "rowcount": {"type": "integer", "label": "Row Count", "required": false, "default": 0},
    "rowskips": {"type": "integer", "label": "Row Skips", "required": false, "default": 0},
    "rfc_name": {"type": "string", "label": "RFC Name", "description": "For mode='bapi'", "required": false},
    "import_params": {"type": "object", "label": "Import Params", "required": false, "ui:widget": "key-value"},
    "result_table": {"type": "string", "label": "Result Table", "required": false},
    "description": {"type": "string", "label": "Description", "required": false, "ui:widget": "code"},
    "group_name": {"type": "string", "label": "Group Name", "required": false, "default": "sap_rfc"},
    "owners": {"type": "array", "items": {"type": "string"}, "label": "Owners", "required": false, "ui:widget": "list"},
    "asset_tags": {"type": "object", "label": "Asset Tags", "required": false, "ui:widget": "key-value"},
    "kinds": {"type": "array", "items": {"type": "string"}, "label": "Kinds", "required": false, "ui:widget": "list"},
    "freshness_max_lag_minutes": {"type": "integer", "label": "Freshness Max Lag (minutes)", "required": false},
    "freshness_cron": {"type": "string", "label": "Freshness Cron", "required": false},
    "include_preview_metadata": {"type": "boolean", "label": "Include Preview Metadata", "required": false, "default": true, "ui:widget": "checkbox"},
    "preview_rows": {"type": "integer", "label": "Preview Rows", "required": false, "default": 25},
    "deps": {"type": "array", "items": {"type": "string"}, "label": "Deps", "required": false, "ui:widget": "list"},
    "partition_type": {"type": "string", "label": "Partition Type", "required": false},
    "partition_start": {"type": "string", "label": "Partition Start", "required": false},
    "partition_values": {"type": "string", "label": "Partition Values", "required": false},
    "dynamic_partition_name": {"type": "string", "label": "Dynamic Partition Name", "required": false},
    "retry_policy_max_retries": {"type": "integer", "label": "Retry Policy Max Retries", "required": false},
    "retry_policy_delay_seconds": {"type": "integer", "label": "Retry Policy Delay Seconds", "required": false},
    "retry_policy_backoff": {"type": "string", "label": "Retry Policy Backoff", "required": false, "default": "exponential"}
  },
  "tags": ["ingestion", "sap", "rfc", "bapi", "idoc", "ecc", "r3", "s4hana"],
  "name": "SAP RFC Ingestion"
}
