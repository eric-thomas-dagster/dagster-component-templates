      "required": true
    },
    "subdomain": {
      "type": "string",
      "label": "Subdomain",
      "description": "Zendesk subdomain (e.g., ",
      "required": true
    },
    "email": {
      "type": "string",
      "label": "Email",
      "description": "Email address for Zendesk authentication",
      "required": true
    },
    "api_token": {
      "type": "string",
      "label": "Api Token",
      "description": "Zendesk API token for authentication",
      "required": true,
      "ui:widget": "password"
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "string"
