{
  "component_type": "dagster_component_templates.BigQueryExportToGcsAssetComponent",
  "description": "Export a BigQuery table or query result to GCS as parquet / CSV / JSONL / AVRO. The classic warehouse \u2192 lake step at the end of an ELT pipeline. Two source modes: source_table_id (uses BQ EXTRACT job \u2014 faster for whole tables) or source_query (uses EXPORT DATA SQL \u2014 flexible).",
  "category": "sink",
  "icon": "si:googlebigquery",
  "x-dagster-io": {
    "outputs": {
      "type": "DataFrame",
      "description": "One row per resulting GCS object (uri, size_bytes, content_type, updated)."
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "credentials": {
      "type": "object",
      "label": "Credentials (dict)",
      "required": false,
      "default": null
    },
    "credentials_path": {
      "type": "string",
      "label": "Credentials Path",
      "required": false,
      "default": null
    },
    "project_id": {
      "type": "string",
      "label": "Project ID",
      "required": false,
      "default": null
    },
    "location": {
      "type": "string",
      "label": "Location",
      "required": false,
      "default": null
    },
    "source_table_id": {
      "type": "string",
      "label": "Source Table ID",
      "required": false,
      "default": null
    },
    "source_query": {
      "type": "string",
      "label": "Source Query",
      "required": false,
      "default": null,
      "ui:widget": "textarea"
    },
    "query_params": {
      "type": "object",
      "label": "Query Params",
      "required": false,
      "default": {}
    },
    "destination_uri": {
      "type": "string",
      "label": "Destination URI",
      "required": true,
      "description": "GCS URI; use a `*` wildcard for sharded exports."
    },
    "format": {
      "type": "string",
      "label": "Format",
      "required": false,
      "default": "parquet",
      "description": "One of: parquet / csv / json / avro.",
      "enum": [
        "parquet",
        "csv",
        "json",
        "avro"
      ],
      "ui:widget": "select"
    },
    "compression": {
      "type": "string",
      "label": "Compression",
      "required": false,
      "default": null
    },
    "csv_field_delimiter": {
      "type": "string",
      "label": "CSV Field Delimiter",
      "required": false,
      "default": null
    },
    "csv_print_header": {
      "type": "boolean",
      "label": "CSV Print Header",
      "required": false,
      "default": true
    },
    "overwrite": {
      "type": "boolean",
      "label": "Overwrite",
      "required": false,
      "default": true
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null,
      "ui:widget": "textarea"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    }
  },
  "tags": [
    "sink",
    "google",
    "bigquery",
    "gcs",
    "export",
    "warehouse-to-lake"
  ],
  "name": "BigQuery to GCS Export"
}
