{
  "component_type": "dagster_component_templates.DataframeToAzureTableComponent",
  "description": "Write DataFrame rows as entities to Azure Table Storage. NoSQL key-value store, way cheaper than Cosmos for simple structured data ($0.045/GB/mo + $0.00036 per 10K transactions).",
  "category": "sink",
  "icon": "Table",
  "x-dagster-io": {
    "supports_partitions": false
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": true
    },
    "account_name_env_var": {
      "type": "string",
      "label": "Account Name Env Var",
      "required": false,
      "default": "AZURE_STORAGE_ACCOUNT"
    },
    "account_key_env_var": {
      "type": "string",
      "label": "Account Key Env Var",
      "required": false,
      "default": "AZURE_STORAGE_ACCOUNT_KEY"
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "required": true
    },
    "partition_key_column": {
      "type": "string",
      "label": "Partition Key Column",
      "required": true
    },
    "row_key_column": {
      "type": "string",
      "label": "Row Key Column",
      "required": true
    },
    "create_if_missing": {
      "type": "boolean",
      "label": "Create If Missing",
      "required": false,
      "default": true
    },
    "write_mode": {
      "type": "string",
      "label": "Write Mode",
      "required": false,
      "default": "upsert",
      "enum": [
        "upsert",
        "merge",
        "insert"
      ]
    },
    "batch_size": {
      "type": "integer",
      "label": "Batch Size",
      "required": false,
      "default": 100
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false,
      "default": null
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    }
  }
}