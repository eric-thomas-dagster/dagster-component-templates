{
  "additionalProperties": false,
  "description": "Bulk-ingest a Pandas DataFrame into Apache Doris via Stream Load.\n\nExample:\n\n    ```yaml\n    type: dagster_community_components.DataframeToDorisComponent\n    attributes:\n      asset_name: doris_orders_load\n      upstream_asset_key: orders_clean\n      table: orders                          # Doris table (database from resource)\n      host_env_var: DORIS_FE_HOST            # OR use resource_key\n      http_port: 8030\n      username_env_var: DORIS_USER\n      password_env_var: DORIS_PASSWORD\n      database: analytics\n      mode: append                           # 'append' or 'replace' (DELETE+INSERT pattern)\n      format: csv\n    ```",
  "properties": {
    "asset_name": {
      "description": "Output Dagster asset name.",
      "title": "Asset Name",
      "type": "string"
    },
    "upstream_asset_key": {
      "description": "Upstream asset providing the DataFrame.",
      "title": "Upstream Asset Key",
      "type": "string"
    },
    "table": {
      "description": "Destination Doris table name.",
      "title": "Table",
      "type": "string"
    },
    "database": {
      "description": "Destination Doris database (catalog).",
      "title": "Database",
      "type": "string"
    },
    "host_env_var": {
      "default": "DORIS_FE_HOST",
      "description": "Env var with Doris FE host.",
      "title": "Host Env Var",
      "type": "string"
    },
    "http_port": {
      "default": 8030,
      "description": "Doris FE HTTP port.",
      "title": "Http Port",
      "type": "integer"
    },
    "username_env_var": {
      "default": "DORIS_USER",
      "description": "Env var with Doris username.",
      "title": "Username Env Var",
      "type": "string"
    },
    "password_env_var": {
      "default": "DORIS_PASSWORD",
      "description": "Env var with Doris password.",
      "title": "Password Env Var",
      "type": "string"
    },
    "ssl": {
      "default": false,
      "description": "Use https for the Stream Load endpoint.",
      "title": "Ssl",
      "type": "boolean"
    },
    "format": {
      "default": "csv",
      "description": "'csv' or 'json'. CSV is faster + smaller.",
      "title": "Format",
      "type": "string"
    },
    "column_separator": {
      "default": ",",
      "description": "CSV column separator (Doris default ','.)",
      "title": "Column Separator",
      "type": "string"
    },
    "line_delimiter": {
      "default": "\\n",
      "description": "CSV line delimiter (Doris default '\\n').",
      "title": "Line Delimiter",
      "type": "string"
    },
    "columns": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional explicit column list (must match Doris table column order). If unset, DataFrame column order is used.",
      "title": "Columns"
    },
    "mode": {
      "default": "append",
      "description": "Load mode: 'append' (default \u2014 Stream Load appends), or 'replace' (DELETE rows matching a predicate first, then Stream Load \u2014 requires replace_predicate).",
      "title": "Mode",
      "type": "string"
    },
    "replace_predicate": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "SQL WHERE clause for replace mode (e.g. \"event_date = '2026-05-27'\").",
      "title": "Replace Predicate"
    },
    "request_timeout_seconds": {
      "default": 300,
      "minimum": 10,
      "title": "Request Timeout Seconds",
      "type": "integer"
    },
    "group_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": "doris",
      "description": "Dagster asset group name.",
      "title": "Group Name"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Asset description.",
      "title": "Description"
    },
    "owners": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Asset owners.",
      "title": "Owners"
    },
    "tags": {
      "anyOf": [
        {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Catalog tags.",
      "title": "Tags"
    },
    "kinds": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Asset kinds (auto-includes 'doris').",
      "title": "Kinds"
    }
  },
  "required": [
    "asset_name",
    "upstream_asset_key",
    "table",
    "database"
  ],
  "title": "DataframeToDorisComponent",
  "type": "object"
}