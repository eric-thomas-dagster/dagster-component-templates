{
  "component_type": "dagster_component_templates.DataframeToDynatraceEventsComponent",
  "description": "Push DataFrame rows as Dynatrace events via the v2 Events API. Use for batch-job markers (deployments, ETL completions, anomalies) that should annotate Dynatrace's timeline.",
  "category": "sink",
  "icon": "Upload",
  "x-dagster-io": {
    "supports_partitions": false
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": true
    },
    "environment_url": {
      "type": "string",
      "label": "Environment Url",
      "required": true
    },
    "api_token_env_var": {
      "type": "string",
      "label": "Api Token Env Var",
      "required": true
    },
    "event_type": {
      "type": "string",
      "label": "Event Type",
      "required": false,
      "default": "CUSTOM_INFO"
    },
    "title_column": {
      "type": "string",
      "label": "Title Column",
      "required": false,
      "default": null
    },
    "entity_selector": {
      "type": "string",
      "label": "Entity Selector",
      "required": false,
      "default": null
    },
    "properties_columns": {
      "type": "array",
      "label": "Properties Columns",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false,
      "default": null
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    }
  }
}