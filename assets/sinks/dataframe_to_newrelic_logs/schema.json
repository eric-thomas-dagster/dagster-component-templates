{
  "component_type": "dagster_component_templates.DataframeToNewRelicLogsComponent",
  "description": "Push DataFrame rows as log events to New Relic. Each row becomes one log entry; configurable timestamp + message fields, with logtype for downstream parsing.",
  "category": "sink",
  "icon": "Upload",
  "x-dagster-io": {
    "supports_partitions": false
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": true
    },
    "api_key_env_var": {
      "type": "string",
      "label": "Api Key Env Var",
      "required": true
    },
    "region": {
      "type": "string",
      "label": "Region",
      "required": false,
      "default": "US",
      "enum": [
        "US",
        "EU"
      ]
    },
    "log_type": {
      "type": "string",
      "label": "Log Type",
      "required": false,
      "default": null
    },
    "timestamp_column": {
      "type": "string",
      "label": "Timestamp Column",
      "required": false,
      "default": null,
      "x-dagster-widget": "column"
    },
    "message_column": {
      "type": "string",
      "label": "Message Column",
      "required": false,
      "default": null,
      "x-dagster-widget": "column"
    },
    "batch_size": {
      "type": "integer",
      "label": "Batch Size",
      "required": false,
      "default": 1000
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false,
      "default": null
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    }
  }
}
