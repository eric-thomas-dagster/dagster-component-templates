{
  "component_type": "dagster_component_templates.DataframeToPrometheusComponent",
  "description": "Push DataFrame rows as Prometheus metrics via a pushgateway. Each row becomes a metric sample with labels from configured columns. Useful for batch-job metrics that surface in operational dashboards.",
  "category": "sink",
  "icon": "Upload",
  "x-dagster-io": {
    "supports_partitions": false
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": true
    },
    "pushgateway_url": {
      "type": "string",
      "label": "Pushgateway Url",
      "required": true
    },
    "job": {
      "type": "string",
      "label": "Job",
      "required": true
    },
    "metric_name": {
      "type": "string",
      "label": "Metric Name",
      "required": true
    },
    "metric_type": {
      "type": "string",
      "label": "Metric Type",
      "required": false,
      "default": "gauge",
      "enum": [
        "gauge",
        "counter"
      ]
    },
    "metric_help": {
      "type": "string",
      "label": "Metric Help",
      "required": false,
      "default": null
    },
    "value_column": {
      "type": "string",
      "label": "Value Column",
      "required": true,
      "x-dagster-widget": "column"
    },
    "label_columns": {
      "type": "array",
      "label": "Label Columns",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      },
      "x-dagster-widget": "columns"
    },
    "grouping_key_columns": {
      "type": "array",
      "label": "Grouping Key Columns",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      },
      "x-dagster-widget": "columns"
    },
    "extra_headers": {
      "type": "object",
      "label": "Extra Headers",
      "required": false,
      "default": null
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false,
      "default": null
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    }
  }
}
