{
  "component_type": "dagster_component_templates.DataframeToServiceBusComponent",
  "description": "Send each DataFrame row to an Azure Service Bus queue or topic as a JSON message. Mirrors dataframe_to_eventhub for SB workloads \u2014 completes the registry's existing servicebus_monitor + servicebus_to_database_asset (consumer) pair.",
  "category": "sink",
  "icon": "MessageSquare",
  "x-dagster-io": {
    "supports_partitions": false
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true,
      "default": null
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "required": true,
      "default": null
    },
    "connection_string_env_var": {
      "type": "string",
      "label": "Connection String Env Var",
      "required": true,
      "default": null
    },
    "destination_name": {
      "type": "string",
      "label": "Destination Name",
      "required": true,
      "default": null
    },
    "destination_type": {
      "type": "string",
      "label": "Destination Type",
      "required": false,
      "default": "queue",
      "enum": [
        "queue",
        "topic"
      ]
    },
    "session_id_column": {
      "type": "string",
      "label": "Session Id Column",
      "required": false,
      "default": null,
      "x-dagster-widget": "column"
    },
    "message_id_column": {
      "type": "string",
      "label": "Message Id Column",
      "required": false,
      "default": null,
      "x-dagster-widget": "column"
    },
    "correlation_id_column": {
      "type": "string",
      "label": "Correlation Id Column",
      "required": false,
      "default": null,
      "x-dagster-widget": "column"
    },
    "batch_size": {
      "type": "integer",
      "label": "Batch Size",
      "required": false,
      "default": 100
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false,
      "default": null
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    }
  }
}
