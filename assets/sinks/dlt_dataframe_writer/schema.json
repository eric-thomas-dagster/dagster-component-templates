{
  "component_type": "dagster_component_templates.DLTDataFrameWriterComponent",
  "description": "Component for writing pandas DataFrames to any database using dlt (data load tool).",
  "category": "sink",
  "icon": "ArrowDownToLine",
  "x-dagster-io": {
    "inputs": {
      "type": "dataframe",
      "required": true,
      "description": "DataFrame to write"
    },
    "outputs": {
      "type": "MaterializeResult",
      "description": "Write confirmation with metadata"
    }
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Name of the asset to create",
      "required": true
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Name of the table to write data to in the destination",
      "required": true
    },
    "primary_key": {
      "type": "string",
      "label": "Primary Key",
      "description": "Primary Key",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description of the asset",
      "required": false,
      "default": "",
      "ui:widget": "code"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group name for organization",
      "required": false,
      "default": ""
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "Enable partitioning: 'daily', 'weekly', 'monthly', 'hourly' for time-based; 'static' for a fixed set of values (e.g. customers); 'multi' for date \u00d7 static (e.g. day \u00d7 customer). Leave empty for unpartitioned.",
      "required": false,
      "default": null,
      "enum": [
        "daily",
        "weekly",
        "monthly",
        "hourly",
        "static",
        "multi"
      ],
      "ui:widget": "select"
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start Date",
      "description": "ISO date string for the first partition, e.g. '2024-01-01'. Required for time-based and multi partition types.",
      "required": false,
      "default": null
    },
    "partition_date_column": {
      "type": "string",
      "label": "Partition Date Column",
      "description": "Column used to filter rows to the current date partition key (e.g. 'event_date', 'created_at').",
      "required": false,
      "default": null
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "description": "Comma-separated values for static or multi partitioning, e.g. 'acme_corp,globex,initech'. Required for static and multi types.",
      "required": false,
      "default": null
    },
    "partition_static_dim": {
      "type": "string",
      "label": "Static Dimension Name",
      "description": "Name for the static partition dimension in multi-partitioning, e.g. 'customer' or 'region'. Defaults to 'segment'.",
      "required": false,
      "default": null
    },
    "partition_static_column": {
      "type": "string",
      "label": "Static Partition Column",
      "description": "Column used to filter rows to the current static partition value (e.g. 'customer_id', 'region').",
      "required": false,
      "default": null
    },
    "upstream_asset_keys": {
      "type": "string",
      "label": "Upstream Asset Keys",
      "description": "Upstream Asset Keys",
      "required": false,
      "default": null
    },
    "destination": {
      "type": "string",
      "label": "Destination",
      "description": "Destination",
      "required": false,
      "default": null
    },
    "snowflake_account": {
      "type": "string",
      "label": "Snowflake Account",
      "description": "Snowflake account identifier",
      "required": false,
      "default": null
    },
    "snowflake_database": {
      "type": "string",
      "label": "Snowflake Database",
      "description": "Snowflake database name",
      "required": false,
      "default": null
    },
    "snowflake_schema": {
      "type": "string",
      "label": "Snowflake Schema",
      "description": "Snowflake schema name",
      "required": false,
      "default": "public"
    },
    "snowflake_warehouse": {
      "type": "string",
