      "description": "Snowflake warehouse name",
      "required": false,
      "default": null
    },
    "snowflake_username": {
      "type": "string",
      "label": "Snowflake Username",
      "description": "Snowflake username",
      "required": false,
      "default": null
    },
    "snowflake_password": {
      "type": "string",
      "label": "Snowflake Password",
      "description": "Snowflake password",
      "required": false,
      "default": null,
