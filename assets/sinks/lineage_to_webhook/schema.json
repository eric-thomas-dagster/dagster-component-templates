{
  "component_type": "dagster_component_templates.LineageToWebhookComponent",
  "description": "Sink that POSTs the raw upstream lineage_graph to any HTTP webhook (Slack, internal endpoint, n8n). Optional Bearer auth.",
  "category": "sink",
  "icon": "ArrowRightLeft",
  "x-dagster-io": {
    "inputs": {"type": "dict", "description": "Canonical lineage payload from lineage_graph_extractor"},
    "outputs": {"type": "MaterializeResult", "description": "Push status + last-pushed hash for change detection"},
    "supports_partitions": false
  },
  "attributes": {
    "asset_name": {"type": "string", "label": "Asset Name", "required": false, "default": "lineage_to_webhook"},
    "upstream_asset_key": {"type": "string", "label": "Upstream Asset Key", "required": false, "default": "lineage_graph"},
    "catalog_url": {"type": "string", "label": "Catalog URL", "required": false, "default": "https://example.com/lineage-webhook"},
    "api_token_env": {"type": "string", "label": "API Token Env Var", "required": false, "default": "LINEAGE_WEBHOOK_TOKEN"},
    "only_push_on_change": {"type": "boolean", "label": "Only Push On Change", "required": false, "default": true},
    "group_name": {"type": "string", "label": "Group Name", "required": false, "default": "lineage"},
    "description": {"type": "string", "label": "Description", "required": false, "default": null},
    "owners": {"type": "array", "items": {"type": "string"}, "label": "Owners", "required": false, "default": null},
    "asset_tags": {"type": "object", "label": "Asset Tags", "required": false, "default": null}
  }
}
