{
  "component_type": "dagster_component_templates.PubSubPublishAssetComponent",
  "description": "Publish DataFrame rows as Pub/Sub messages — one message per row. Columns can be mapped into Pub/Sub message attributes for downstream filter routing on subscribers.",
  "category": "sink",
  "icon": "si:googlecloud",
  "x-dagster-io": {"outputs": {"type": "DataFrame", "description": "Upstream DataFrame with pubsub_message_id (and optional _error) columns added."}},
  "attributes": {
    "asset_name": {"type": "string", "label": "Asset Name", "required": true},
    "upstream_asset_key": {"type": "string", "label": "Upstream Asset Key", "required": true},
    "credentials": {"type": "object", "label": "Credentials (dict)", "required": false, "default": null},
    "credentials_path": {"type": "string", "label": "Credentials Path", "required": false, "default": null},
    "project_id": {"type": "string", "label": "Project ID", "required": false, "default": null},
    "topic": {"type": "string", "label": "Topic", "required": true, "description": "Topic name (no projects/.../topics/ prefix)."},
    "auto_create_topic": {"type": "boolean", "label": "Auto-Create Topic", "required": false, "default": false},
    "message_column": {"type": "string", "label": "Message Column", "required": false, "default": null, "description": "Single column to publish. Default: JSON-serialize the whole row."},
    "attribute_columns": {"type": "array", "label": "Attribute Columns", "required": false, "items": {"type": "string"}, "description": "Columns mapped to Pub/Sub message attributes."},
    "ordering_key_column": {"type": "string", "label": "Ordering Key Column", "required": false, "default": null},
    "flush_batch_size": {"type": "integer", "label": "Flush Batch Size", "required": false, "default": 100},
    "description": {"type": "string", "label": "Description", "required": false, "default": null, "ui:widget": "textarea"},
    "group_name": {"type": "string", "label": "Group Name", "required": false, "default": null},
    "deps": {"type": "array", "label": "Deps", "required": false, "items": {"type": "string"}},
    "tags": {"type": "object", "label": "Tags", "required": false},
    "owners": {"type": "array", "label": "Owners", "required": false, "items": {"type": "string"}}
  },
  "tags": ["sink", "google", "pubsub", "messaging", "streaming"],
  "name": "Pub/Sub Publish"
}
