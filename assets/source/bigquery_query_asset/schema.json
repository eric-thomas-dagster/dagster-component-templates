{
  "component_type": "dagster_component_templates.BigQueryQueryAssetComponent",
  "description": "Run a SQL query against Google BigQuery and return a pandas DataFrame. Drop-in peer of duckdb_query_reader (DuckDB) and database_query (generic SQL). For multi-asset 'import every BQ entity as an asset' use google_bigquery instead.",
  "category": "source",
  "icon": "si:googlebigquery",
  "x-dagster-io": {
    "outputs": {
      "type": "DataFrame",
      "description": "BigQuery query result as a pandas DataFrame, with bytes_processed / cache_hit / slot_millis exposed in metadata."
    }
  },
  "attributes": {
    "asset_name": {"type": "string", "label": "Asset Name", "required": true},
    "credentials": {"type": "object", "label": "Credentials (dict)", "required": false, "default": null},
    "credentials_path": {"type": "string", "label": "Credentials Path", "required": false, "default": null, "description": "Falls back to GOOGLE_APPLICATION_CREDENTIALS."},
    "project_id": {"type": "string", "label": "Project ID", "required": false, "default": null, "description": "Billing project for the BQ job. Defaults to the SA's project."},
    "location": {"type": "string", "label": "Location", "required": false, "default": null, "description": "BigQuery location ('US', 'EU', 'us-central1'). Default: auto-detect."},
    "query": {"type": "string", "label": "Query", "required": true, "description": "SQL query. Supports {placeholder} substitution from query_params; partition_key is auto-added.", "ui:widget": "textarea"},
    "query_params": {"type": "object", "label": "Query Params", "required": false, "default": {}, "description": "Mapping substituted into {placeholder} segments before submission."},
    "use_legacy_sql": {"type": "boolean", "label": "Use Legacy SQL", "required": false, "default": false},
    "dry_run": {"type": "boolean", "label": "Dry Run", "required": false, "default": false, "description": "Validate the query and report byte estimate without scanning data."},
    "max_rows": {"type": "integer", "label": "Max Rows", "required": false, "default": null, "description": "Hard cap on result rows fetched."},
    "description": {"type": "string", "label": "Description", "required": false, "default": null, "ui:widget": "textarea"},
    "group_name": {"type": "string", "label": "Group Name", "required": false, "default": null},
    "deps": {"type": "array", "label": "Deps", "required": false, "items": {"type": "string"}},
    "tags": {"type": "object", "label": "Tags", "required": false},
    "owners": {"type": "array", "label": "Owners", "required": false, "items": {"type": "string"}},
    "partition_type": {"type": "string", "label": "Partition Type", "required": false, "default": null},
    "partition_start": {"type": "string", "label": "Partition Start", "required": false, "default": null},
    "partition_values": {"type": "string", "label": "Partition Values", "required": false, "default": null},
    "dynamic_partition_name": {"type": "string", "label": "Dynamic Partition Name", "required": false, "default": null},
    "partition_dimensions": {"type": "array", "label": "Partition Dimensions", "required": false}
  },
  "tags": ["source", "google", "bigquery", "sql", "warehouse", "query"],
  "name": "BigQuery Query Asset"
}
