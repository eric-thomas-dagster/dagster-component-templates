{
  "component_type": "dagster_component_templates.BigtableReaderAssetComponent",
  "description": "BigtableReaderAssetComponent \u2014 read rows from a Cloud Bigtable table into a DataFrame.",
  "category": "source",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": false,
      "description": "Output asset name."
    },
    "credentials": {
      "type": "object",
      "label": "Credentials",
      "required": false
    },
    "credentials_path": {
      "type": "string",
      "label": "Credentials Path",
      "required": false
    },
    "project_id": {
      "type": "string",
      "label": "Project Id",
      "required": false
    },
    "instance_id": {
      "type": "string",
      "label": "Instance Id",
      "required": false,
      "description": "Bigtable instance id."
    },
    "table_id": {
      "type": "string",
      "label": "Table Id",
      "required": false,
      "description": "Bigtable table id."
    },
    "row_key_prefix": {
      "type": "string",
      "label": "Row Key Prefix",
      "required": false,
      "description": "Row-key prefix scan. Mutually exclusive with start_key/end_key."
    },
    "start_key": {
      "type": "string",
      "label": "Start Key",
      "required": false,
      "description": "Start of row-key range (inclusive)."
    },
    "end_key": {
      "type": "string",
      "label": "End Key",
      "required": false,
      "description": "End of row-key range (exclusive)."
    },
    "column_families": {
      "type": "array",
      "label": "Column Families",
      "required": false,
      "description": "Optional list of column families to read. Default: all.",
      "items": {
        "type": "string"
      }
    },
    "limit": {
      "type": "integer",
      "label": "Limit",
      "required": false,
      "description": "Max rows to return."
    },
    "decode_values_as": {
      "type": "string",
      "label": "Decode Values As",
      "required": false,
      "description": "How to decode cell values. 'utf-8' (default), 'bytes' (keep raw), or 'json' (parse JSON cells).",
      "default": "utf-8"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    }
  },
  "tags": [
    "bigtable-reader-asset",
    "source"
  ],
  "name": "Bigtable Reader Asset"
}
