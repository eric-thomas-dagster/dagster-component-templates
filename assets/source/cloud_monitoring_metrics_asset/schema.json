{
  "component_type": "dagster_component_templates.CloudMonitoringMetricsAssetComponent",
  "description": "CloudMonitoringMetricsAssetComponent \u2014 pull GCP time-series metrics into a DataFrame.",
  "category": "source",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": false,
      "description": "Output asset name."
    },
    "credentials": {
      "type": "object",
      "label": "Credentials",
      "required": false
    },
    "credentials_path": {
      "type": "string",
      "label": "Credentials Path",
      "required": false
    },
    "project_id": {
      "type": "string",
      "label": "Project Id",
      "required": false
    },
    "filter_": {
      "type": "string",
      "label": "Filter ",
      "required": false,
      "description": "Cloud Monitoring filter. Must include a `metric.type=...` clause. Example: 'metric.type=\"compute.googleapis.com/instance/cpu/utilization\"'."
    },
    "lookback_minutes": {
      "type": "integer",
      "label": "Lookback Minutes",
      "required": false,
      "description": "Time window (minutes from now backwards).",
      "default": 60
    },
    "alignment_period_seconds": {
      "type": "integer",
      "label": "Alignment Period Seconds",
      "required": false,
      "description": "Bucket size for per-series alignment.",
      "default": 60
    },
    "aligner": {
      "type": "string",
      "label": "Aligner",
      "required": false,
      "default": "MEAN"
    },
    "cross_series_reducer": {
      "type": "string",
      "label": "Cross Series Reducer",
      "required": false,
      "description": "Optional cross-series reducer (combines all series matching the filter)."
    },
    "group_by_fields": {
      "type": "array",
      "label": "Group By Fields",
      "required": false,
      "description": "Resource labels to retain when reducing (e.g. ['resource.labels.zone']).",
      "items": {
        "type": "string"
      }
    },
    "view": {
      "type": "string",
      "label": "View",
      "required": false,
      "description": "FULL returns data points; HEADERS returns series metadata only.",
      "default": "FULL"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    }
  },
  "tags": [
    "cloud-monitoring-metrics-asset",
    "source"
  ],
  "name": "Cloud Monitoring Metrics Asset"
}
