{
  "component_type": "dagster_component_templates.SpannerQueryAssetComponent",
  "description": "SpannerQueryAssetComponent \u2014 run a SQL query against Cloud Spanner.",
  "category": "source",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": false,
      "description": "Output asset name."
    },
    "credentials": {
      "type": "object",
      "label": "Credentials",
      "required": false
    },
    "credentials_path": {
      "type": "string",
      "label": "Credentials Path",
      "required": false
    },
    "project_id": {
      "type": "string",
      "label": "Project Id",
      "required": false
    },
    "instance_id": {
      "type": "string",
      "label": "Instance Id",
      "required": false,
      "description": "Spanner instance id."
    },
    "database_id": {
      "type": "string",
      "label": "Database Id",
      "required": false,
      "description": "Spanner database id."
    },
    "sql": {
      "type": "string",
      "label": "Sql",
      "required": false,
      "description": "The SQL query to run. Spanner GoogleSQL dialect by default."
    },
    "params": {
      "type": "object",
      "label": "Params",
      "required": false,
      "description": "Optional named parameters for the query (use `@name` in SQL)."
    },
    "param_types": {
      "type": "object",
      "label": "Param Types",
      "required": false,
      "description": "Optional explicit type hints per param (string names: STRING, INT64, FLOAT64, BOOL, BYTES, TIMESTAMP, DATE, NUMERIC). Default: inferred."
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    }
  },
  "tags": [
    "spanner-query-asset",
    "source"
  ],
  "name": "Spanner Query Asset"
}
