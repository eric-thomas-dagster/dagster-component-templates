{
  "component_type": "dagster_component_templates.SyntheticPdfGeneratorComponent",
  "description": "SyntheticPdfGeneratorComponent \u2014 generate sample PDFs for OCR / Document AI demos.",
  "category": "source",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": false,
      "description": "Output asset name."
    },
    "output_dir": {
      "type": "string",
      "label": "Output Dir",
      "required": false,
      "description": "Filesystem directory to write PDFs into (created if missing).",
      "default": "/tmp/synthetic_pdfs"
    },
    "samples": {
      "type": "string",
      "label": "Samples",
      "required": false,
      "description": "`default` to use the built-in 2-doc sample set, or `custom` to use `documents` instead.",
      "default": "default"
    },
    "documents": {
      "type": "array",
      "label": "Documents",
      "required": false,
      "description": "When samples='custom', list of {doc_id, kind, title, body} dicts. `body` is a list of strings rendered as separate lines.",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    }
  },
  "tags": [
    "synthetic-pdf-generator",
    "source"
  ],
  "name": "Synthetic Pdf Generator"
}
