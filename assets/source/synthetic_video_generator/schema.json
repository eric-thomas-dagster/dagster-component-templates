{
  "component_type": "dagster_component_templates.SyntheticVideoGeneratorComponent",
  "description": "SyntheticVideoGeneratorComponent \u2014 generate tiny test videos via ffmpeg.",
  "category": "source",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": false,
      "description": "Output asset name."
    },
    "output_dir": {
      "type": "string",
      "label": "Output Dir",
      "required": false,
      "description": "Filesystem directory to write videos into (created if missing).",
      "default": "/tmp/synthetic_videos"
    },
    "samples": {
      "type": "string",
      "label": "Samples",
      "required": false,
      "description": "`default` to use the built-in 2-clip set, or `custom` to use `clips` instead.",
      "default": "default"
    },
    "clips": {
      "type": "array",
      "label": "Clips",
      "required": false,
      "description": "When samples='custom', list of {clip_id, duration_seconds, fps, width, height, tone_hz} dicts. tone_hz is the audio track's sine-tone frequency in Hz.",
      "items": {
        "type": "string"
      }
    },
    "ffmpeg_binary": {
      "type": "string",
      "label": "Ffmpeg Binary",
      "required": false,
      "default": "ffmpeg"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "items": {
        "type": "string"
      }
    }
  },
  "tags": [
    "synthetic-video-generator",
    "source"
  ],
  "name": "Synthetic Video Generator"
}
