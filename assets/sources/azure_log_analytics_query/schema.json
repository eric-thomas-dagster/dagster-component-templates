{
  "component_type": "dagster_component_templates.AzureLogAnalyticsQueryComponent",
  "description": "Materialize a DataFrame from a KQL query against an Azure Log Analytics workspace. Read-side counterpart to audit_logs_to_sentinel \u2014 write logs, then query them back.",
  "category": "source",
  "icon": "Search",
  "x-dagster-io": {
    "supports_partitions": false
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true,
      "default": null
    },
    "workspace_id": {
      "type": "string",
      "label": "Workspace Id",
      "required": true,
      "default": null,
      "description": "Log Analytics workspace GUID"
    },
    "query": {
      "type": "string",
      "label": "Query",
      "required": true,
      "default": null
    },
    "timespan_iso8601": {
      "type": "string",
      "label": "Timespan Iso8601",
      "required": false,
      "default": null,
      "description": "ISO 8601 duration like 'PT1H', 'P30D'"
    },
    "tenant_id_env_var": {
      "type": "string",
      "label": "Tenant Id Env Var",
      "required": false,
      "default": null
    },
    "client_id_env_var": {
      "type": "string",
      "label": "Client Id Env Var",
      "required": false,
      "default": null
    },
    "client_secret_env_var": {
      "type": "string",
      "label": "Client Secret Env Var",
      "required": false,
      "default": null
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false,
      "default": null
    },
    "description": {
      "type": "string",
      "label": "Description",
      "required": false,
      "default": null
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false,
      "default": null
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    }
