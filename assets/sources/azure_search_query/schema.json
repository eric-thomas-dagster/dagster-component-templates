    "owners": {
      "type": "array",
      "label": "Owners",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false,
      "default": null
