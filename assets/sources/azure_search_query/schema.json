    "supports_partitions": false
  },
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "required": true
    },
    "endpoint": {
      "type": "string",
      "label": "Endpoint",
      "required": true
    },
    "index_name": {
      "type": "string",
      "label": "Index Name",
      "required": true
    },
    "api_key_env_var": {
      "type": "string",
      "label": "Api Key Env Var",
      "required": false,
      "default": null
    },
    "search_text": {
      "type": "string",
      "label": "Search Text",
      "required": false,
      "default": "*"
    },
    "filter_query": {
      "type": "string",
      "label": "Filter Query",
      "required": false,
      "default": null
    },
    "select": {
      "type": "array",
      "label": "Select",
      "required": false,
      "default": null,
      "items": {
        "type": "string"
      }
    },
    "order_by": {
      "type": "array",
