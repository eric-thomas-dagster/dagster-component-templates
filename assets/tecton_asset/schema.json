{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TectonAssetComponent",
  "description": "Trigger Tecton feature view materialization jobs via the Tecton SDK for online and/or offline stores.",
  "category": "assets",
  "tags": ["assets", "feature-store", "tecton", "ml", "machine-learning", "features"],
  "type": "object",
  "required": ["workspace"],
  "properties": {
    "workspace": {
      "type": "string",
      "description": "Tecton workspace name (e.g. 'production', 'staging')."
    },
    "tecton_api_key_env_var": {
      "type": "string",
      "default": "TECTON_API_KEY",
      "description": "Name of the environment variable holding the Tecton API key."
    },
    "tecton_url_env_var": {
      "type": ["string", "null"],
      "default": null,
      "description": "Name of the environment variable holding the Tecton cluster URL. Defaults to https://app.tecton.ai."
    },
    "feature_views": {
      "type": ["array", "null"],
      "default": null,
      "items": { "type": "string" },
      "description": "Specific feature view names to trigger. When null all views in the workspace are triggered."
    },
    "online": {
      "type": "boolean",
      "default": true,
      "description": "Materialize to the online store."
    },
    "offline": {
      "type": "boolean",
      "default": true,
      "description": "Materialize to the offline store."
    },
    "asset_name": {
      "type": "string",
      "default": "tecton_features",
      "description": "Dagster asset key for this component."
    },
    "group_name": {
      "type": ["string", "null"],
      "default": "feature_store",
      "description": "Dagster asset group name."
    },
    "deps": {
      "type": ["array", "null"],
      "default": null,
      "items": { "type": "string" },
      "description": "Upstream asset keys for lineage."
    }
  },
  "additionalProperties": false
}
