{
  "component_type": "dagster_community_components.JupyterNotebookComponent",
  "description": "Execute a Jupyter notebook (.ipynb) or inline Python code against an upstream DataFrame. Two backends: papermill (notebook-as-pipeline) or exec (inline body).",
  "category": "transformation",
  "icon": "Notebook",
  "x-dagster-io": {
    "inputs": {
      "type": "dataframe",
      "required": true,
      "description": "Upstream DataFrame; available as `df` in the notebook / code scope"
    },
    "outputs": {
      "type": "dataframe",
      "description": "The notebook / code must assign result to `out_df` (or write to `output_dataframe_path` for papermill backend)"
    }
  },
  "attributes": {
    "asset_name": { "type": "string", "label": "Asset Name", "required": true },
    "upstream_asset_key": { "type": "string", "label": "Upstream Asset Key", "required": true },
    "notebook_path": { "type": "string", "label": "Notebook Path (.ipynb)" },
    "code": { "type": "string", "label": "Inline Python Code", "description": "Receives `df`, must assign `out_df`" },
    "backend": {
      "type": "string",
      "enum": ["papermill", "exec"],
      "default": "exec",
      "label": "Backend"
    },
    "output_notebook_path": { "type": "string", "label": "Save executed notebook (papermill)" },
    "parameters": { "type": "object", "label": "papermill Parameters" },
    "timeout_seconds": { "type": "integer", "default": 600, "label": "Timeout (seconds)" },
    "group_name": { "type": "string", "label": "Group Name" }
  }
}
