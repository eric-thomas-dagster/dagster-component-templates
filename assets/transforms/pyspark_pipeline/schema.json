{
  "component_type": "dagster_component_templates.PySparkPipelineComponent",
  "description": "Multi-step PySpark DataFrame chain in a single Dagster asset (Catalyst-optimized).",
  "category": "transformation",
  "icon": "Zap",
  "x-dagster-io": {
    "outputs": {"type": "table_or_dataframe", "description": "Either materialized to a sink (parquet/table/jdbc) or returned as pandas (sink.kind=none)"}
  },
  "attributes": {
    "asset_name":         {"type": "string", "required": true},
    "spark_config":       {"type": "object", "description": "SparkConf options (e.g. spark.master, spark.sql.shuffle.partitions)"},
    "spark_app_name":     {"type": "string", "default": "dagster-pyspark-pipeline"},
    "source":             {"type": "object", "required": true,
                           "description": "{kind: parquet|csv|json|orc|delta|table|jdbc|upstream, ...kind-specific}"},
    "operations":         {"type": "array", "required": true, "items": {"type": "object"},
                           "description": "Ordered list of PySpark DataFrame ops."},
    "sink":               {"type": "object", "required": true,
                           "description": "{kind: parquet|csv|json|delta|table|jdbc|none, ...kind-specific}"},
    "upstream_asset_key": {"type": "string", "description": "Required when source.kind='upstream'"},
    "group_name":         {"type": "string"},
    "description":        {"type": "string"},
    "asset_tags":         {"type": "object"},
    "kinds":              {"type": "array", "items": {"type": "string"}},
    "owners":             {"type": "array", "items": {"type": "string"}},
    "deps":               {"type": "array", "items": {"type": "string"}}
  }
}
