{
  "component_type": "dagster_component_templates.WarehouseFormulaComponent",
  "description": "Add/replace columns via inline SQL expressions (CTAS pushdown). Alteryx Formula In-DB equivalent.",
  "category": "transformation",
  "icon": "Calculator",
  "x-dagster-io": {
    "inputs":  {"type": "table", "required": true},
    "outputs": {"type": "table"}
  },
  "attributes": {
    "asset_name":           {"type": "string", "required": true},
    "database_url":         {"type": "string"},
    "database_url_env_var": {"type": "string"},
    "dialect":              {"type": "string", "required": true,
                             "enum": ["duckdb","postgres","postgresql","snowflake","bigquery","redshift","databricks","mssql","mysql"]},
    "upstream_table":       {"type": "string", "required": true},
    "output_table":         {"type": "string", "required": true},
    "expressions":          {"type": "object", "required": true,
                             "description": "Map of output_col → SQL expression (inlined verbatim into SELECT)."},
    "keep_existing":        {"type": "boolean", "default": true,
                             "description": "true: SELECT *, <new>. false + keep_columns: those cols + new. false alone: only new."},
    "keep_columns":         {"type": "array", "items": {"type": "string"}},
    "mode":                 {"type": "string", "enum": ["replace","create_if_not_exists"], "default": "replace"},
    "group_name":           {"type": "string"},
    "deps":                 {"type": "array", "items": {"type": "string"}},
    "owners":               {"type": "array", "items": {"type": "string"}},
    "description":          {"type": "string"},
    "asset_tags":           {"type": "object"},
    "kinds":                {"type": "array", "items": {"type": "string"}},
    "include_preview_metadata": {"type": "boolean", "default": false},
    "preview_rows":         {"type": "integer", "default": 25, "minimum": 1, "maximum": 200}
  }
}
