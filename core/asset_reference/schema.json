{
  "type": "dagster_component_templates.AssetReferenceComponent",
  "name": "Asset Reference",
  "category": "core",
  "description": "Reference an existing asset (dbt, Python, etc.) in a pipeline definition",
  "version": "1.0.0",
  "author": "Dagster Community",
  "attributes": {
    "asset_name": {
      "type": "string",
      "required": true,
      "label": "Asset Name",
      "description": "Name of the existing asset to reference",
      "placeholder": "my_existing_asset"
    },
    "module": {
      "type": "string",
      "required": false,
      "label": "Module Path",
      "description": "Python module where the asset is defined",
      "placeholder": "my_project.assets"
    },
    "description": {
      "type": "string",
      "required": false,
      "label": "Description",
      "description": "Description of what this asset does",
      "placeholder": "Existing asset for customer data"
    },
    "group_name": {
      "type": "string",
      "required": false,
      "label": "Asset Group",
      "description": "Asset group for organization",
      "placeholder": "staging"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Kinds",
      "required": false
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag Minutes",
      "required": false
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron",
      "required": false
    },
    "column_lineage": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Column Lineage",
      "required": false
    },
    "deps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Deps",
      "required": false
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "required": false
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "required": false
    },
    "partition_date_column": {
      "type": "string",
      "label": "Partition Date Column",
      "required": false
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "required": false
    },
    "partition_static_dim": {
      "type": "string",
      "label": "Partition Static Dim",
      "required": false
    },
    "partition_static_column": {
      "type": "string",
      "label": "Partition Static Column",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "required": false,
      "default": "exponential"
    },
    "dynamic_partition_name": {
      "type": "string",
      "label": "Dynamic Partition Name",
      "description": "Name for DynamicPartitionsDefinition (when partition_type='dynamic'), e.g. 'tenants'.",
      "required": false,
      "default": null
    },
    "partition_dimensions": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "label": "Partition Dimensions",
      "description": "Multi-axis partition spec: list of {name, type, start, values, dynamic_partition_name} dicts. Overrides flat fields when set.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "core",
    "reference",
    "existing-asset",
    "import"
  ]
}