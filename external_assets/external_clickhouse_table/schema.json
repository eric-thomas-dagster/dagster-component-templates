{
  "component_type": "dagster_component_templates.ClickHouseResource",
  "description": "Resource for connecting to ClickHouse.",
  "category": "external",
  "icon": "Link",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetSpec",
      "description": "External asset declaration"
    }
  },
  "attributes": {
    "host": {
      "type": "string",
      "label": "Host",
      "description": "ClickHouse host",
      "required": true
    },
    "port": {
      "type": "integer",
      "label": "Port",
      "description": "Port",
      "required": false,
      "default": 8443
    },
    "username": {
      "type": "string",
      "label": "Username",
      "description": "ClickHouse username",
      "required": false,
      "default": "default"
    },
    "password": {
      "type": "string",
      "label": "Password",
      "description": "ClickHouse password",
      "required": false,
      "default": "",
      "ui:widget": "password"
    },
    "secure": {
      "type": "boolean",
      "label": "Secure",
      "description": "Secure",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Dagster asset key (e.g. ",
      "required": true
    },
    "database": {
      "type": "string",
      "label": "Database",
      "description": "ClickHouse database name",
      "required": true
    },
    "table": {
      "type": "string",
      "label": "Table",
      "description": "ClickHouse table name",
      "required": true
    },
    "host_env_var": {
      "type": "string",
      "label": "Host Env Var",
      "description": "Env var with ClickHouse host",
      "required": true
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "description": "Env var with ClickHouse username",
      "required": false,
      "default": null
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var with ClickHouse password",
      "required": false,
      "default": null,
      "ui:widget": "env_var"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Human-readable description",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Dagster asset group name",
      "required": false,
      "default": "clickhouse"
    },
    "owners": {
      "type": "string",
      "label": "Owners",
      "description": "List of owner emails or team names",
      "required": false,
      "default": null
    },
    "partition_type": {
      "type": "string",
      "label": "Partition Type",
      "description": "'daily'|'weekly'|'monthly'|'hourly'|'static'|'dynamic'|'multi', or None for unpartitioned.",
      "required": false,
      "default": null
    },
    "partition_start": {
      "type": "string",
      "label": "Partition Start",
      "description": "ISO start date for time-based partition types (e.g. '2024-01-01').",
      "required": false,
      "default": null
    },
    "partition_values": {
      "type": "string",
      "label": "Partition Values",
      "description": "Comma-separated values for static / multi partition types.",
      "required": false,
      "default": null
    },
    "dynamic_partition_name": {
      "type": "string",
      "label": "Dynamic Partition Name",
      "description": "Name for DynamicPartitionsDefinition (when partition_type='dynamic').",
      "required": false,
      "default": null
    },
    "partition_dimensions": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "label": "Partition Dimensions",
      "description": "Multi-axis partition spec: list of {name, type, start, values, dynamic_partition_name} dicts. Overrides flat fields when set.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "external",
    "clickhouse",
    "table"
  ],
  "name": "External ClickHouse Table"
}