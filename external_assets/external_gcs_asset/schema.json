{
  "type": "dagster_component_templates.ExternalGcsAsset",
  "name": "External GCS Asset",
  "category": "sensors",
  "description": "Declare a GCS bucket prefix as an external asset",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "external_asset"
  },
  "attributes": {
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key",
      "placeholder": "raw/data"
    },
    "bucket_name": {
      "type": "string",
      "required": true,
      "label": "Bucket Name",
      "placeholder": "my-bucket"
    },
    "prefix": {
      "type": "string",
      "required": false,
      "label": "Prefix",
      "default": ""
    },
    "project": {
      "type": "string",
      "required": false,
      "label": "GCP Project"
    },
    "group_name": {
      "type": "string",
      "required": false,
      "label": "Group Name"
    },
    "description": {
      "type": "string",
      "required": false,
      "label": "Description"
    }
  },
  "dependencies": {
    "pip": [
      "dagster"
    ]
  },
  "tags": [
    "sensors",
    "external_asset"
  ]
}
