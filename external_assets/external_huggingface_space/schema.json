{
  "component_type": "dagster_community_components.ExternalHuggingfaceSpaceAsset",
  "description": "Declare a HuggingFace Space as an external Dagster asset (declare-only AssetSpec). Pair with huggingface_space_status_sensor to materialize on stage transitions.",
  "category": "external",
  "icon": "si:huggingface",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetSpec",
      "description": "Declare-only external asset"
    }
  },
  "attributes": {
    "asset_key": { "type": "string", "label": "Asset Key", "required": true },
    "space_id": { "type": "string", "label": "Space ID", "description": "HuggingFace Space id (e.g. 'my-org/my-app')", "required": true },
    "group_name": { "type": "string", "label": "Group Name", "required": false, "default": "huggingface" },
    "description": { "type": "string", "label": "Description", "required": false },
    "owners": { "type": "array", "items": { "type": "string" }, "label": "Owners", "required": false, "ui:widget": "list" },
    "tags": { "type": "object", "label": "Tags", "required": false, "ui:widget": "key-value" },
    "kinds": { "type": "array", "items": { "type": "string" }, "label": "Kinds", "required": false, "ui:widget": "list" },
    "deps": { "type": "array", "items": { "type": "string" }, "label": "Deps", "required": false, "ui:widget": "list" }
  },
  "tags": ["external", "huggingface", "space", "asset-spec"],
  "name": "External HuggingFace Space Asset"
}
