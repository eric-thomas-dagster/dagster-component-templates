{
  "type": "dagster_component_templates.ExternalKafkaAsset",
  "name": "External Kafka Asset",
  "category": "sensors",
  "description": "Declare a Kafka topic as an external asset",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "external_asset"
  },
  "attributes": {
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key",
      "placeholder": "streaming/orders"
    },
    "bootstrap_servers": {
      "type": "string",
      "required": true,
      "label": "Bootstrap Servers",
      "placeholder": "localhost:9092"
    },
    "topic": {
      "type": "string",
      "required": true,
      "label": "Topic",
      "placeholder": "orders"
    },
    "group_name": {
      "type": "string",
      "required": false,
      "label": "Group Name"
    },
    "description": {
      "type": "string",
      "required": false,
      "label": "Description"
    }
  },
  "dependencies": {
    "pip": [
      "dagster"
    ]
  },
  "tags": [
    "sensors",
    "external_asset"
  ]
}
