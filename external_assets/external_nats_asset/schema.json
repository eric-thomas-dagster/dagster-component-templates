{
  "type": "dagster_component_templates.ExternalNatsAsset",
  "name": "External NATS Asset",
  "category": "sensors",
  "description": "Declare a NATS JetStream stream as an external asset",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "external_asset"
  },
  "attributes": {
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key",
      "placeholder": "streaming/events"
    },
    "servers": {
      "type": "string",
      "required": true,
      "label": "Servers",
      "placeholder": "nats://localhost:4222"
    },
    "stream_name": {
      "type": "string",
      "required": true,
      "label": "Stream Name",
      "placeholder": "EVENTS"
    },
    "group_name": {
      "type": "string",
      "required": false,
      "label": "Group Name"
    },
    "description": {
      "type": "string",
      "required": false,
      "label": "Description"
    }
  },
  "dependencies": {
    "pip": [
      "dagster"
    ]
  },
  "tags": [
    "sensors",
    "external_asset"
  ]
}
