{
  "type": "dagster_component_templates.ExternalSqlAsset",
  "name": "External SQL Asset",
  "category": "sensors",
  "description": "Declare a SQL database table as an external asset",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "external_asset"
  },
  "attributes": {
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key",
      "placeholder": "db/orders"
    },
    "table_name": {
      "type": "string",
      "required": true,
      "label": "Table Name",
      "placeholder": "orders"
    },
    "connection_string_env_var": {
      "type": "string",
      "required": true,
      "label": "Connection String Env Var",
      "placeholder": "DATABASE_URL"
    },
    "group_name": {
      "type": "string",
      "required": false,
      "label": "Group Name"
    },
    "description": {
      "type": "string",
      "required": false,
      "label": "Description"
    }
  },
  "dependencies": {
    "pip": [
      "dagster"
    ]
  },
  "tags": [
    "sensors",
    "external_asset"
  ]
}
