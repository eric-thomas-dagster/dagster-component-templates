      "default": null,
      "title": "Owners"
    },
    "tags": {
      "anyOf": [
        {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tags"
    },
    "kinds": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Kinds"
    },
    "deps": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
