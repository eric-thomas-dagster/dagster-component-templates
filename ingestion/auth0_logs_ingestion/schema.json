{
  "component_type": "dagster_component_templates.Auth0LogsIngestionComponent",
  "description": "Pull Auth0 tenant logs via the Management API /api/v2/logs endpoint.",
  "category": "security",
  "icon": "Shield",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "auth0_domain": {
      "type": "string",
      "label": "Auth0 Domain",
      "description": "Auth0 tenant domain (e.g. 'acme.us.auth0.com')",
      "required": true
    },
    "mgmt_token_env": {
      "type": "string",
      "label": "Mgmt Token Env",
      "description": "Env var with Mgmt API access token",
      "required": false,
      "default": "AUTH0_MGMT_TOKEN"
    },
    "lookback_hours": {
      "type": "integer",
      "label": "Lookback Hours",
      "description": "How far back",
      "required": false,
      "default": 24
    },
    "log_type_filter": {
      "type": "string",
      "label": "Log Type Filter",
      "description": "Filter by log type code (e.g. 's' for success login)",
      "required": false
    },
    "page_size": {
      "type": "integer",
      "label": "Page Size",
      "description": "Per-page (max 100 for Mgmt API)",
      "required": false,
      "default": 100
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Asset description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Dagster asset group",
      "required": false,
      "default": "security_audit"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Upstream asset deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Asset owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Catalog tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Asset kinds",
      "required": false
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag Minutes",
      "description": "Freshness Max Lag Minutes",
      "required": false
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron",
      "description": "Freshness Cron",
      "required": false,
      "x-dagster-widget": "cron"
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "description": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "description": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "description": "Retry Policy Backoff",
      "required": false,
      "default": "exponential",
      "enum": [
        "exponential",
        "linear",
        "fixed"
      ],
      "ui:widget": "select"
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Emit preview metadata",
      "required": false,
      "default": true
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Preview row count",
      "required": false,
      "default": 20
    }
  }
}
