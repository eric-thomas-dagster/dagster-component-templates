{
  "component_type": "dagster_component_templates.O365AuditLogIngestionComponent",
  "description": "Pull Microsoft 365 / Office 365 Unified Audit Log entries via the Management Activity API.",
  "category": "security",
  "icon": "Shield",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "tenant_id": {
      "type": "string",
      "label": "Tenant Id",
      "description": "Azure AD tenant ID",
      "required": true
    },
    "client_id": {
      "type": "string",
      "label": "Client Id",
      "description": "App registration client ID",
      "required": true
    },
    "client_secret_env": {
      "type": "string",
      "label": "Client Secret Env",
      "description": "Env var holding client secret",
      "required": false,
      "default": "O365_CLIENT_SECRET"
    },
    "content_type": {
      "type": "string",
      "label": "Content Type",
      "description": "Audit.General | Audit.AzureActiveDirectory | Audit.Exchange | Audit.SharePoint | DLP.All",
      "required": false,
      "default": "Audit.General"
    },
    "lookback_hours": {
      "type": "integer",
      "label": "Lookback Hours",
      "description": "How far back",
      "required": false,
      "default": 24
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Asset description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Dagster asset group",
      "required": false,
      "default": "security_audit"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Upstream asset deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Asset owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Catalog tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Asset kinds",
      "required": false
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag Minutes",
      "description": "Freshness Max Lag Minutes",
      "required": false
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron",
      "description": "Freshness Cron",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "description": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "description": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "description": "Retry Policy Backoff",
      "required": false,
      "default": "exponential"
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Emit preview metadata",
      "required": false,
      "default": true
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Preview row count",
      "required": false,
      "default": 20
    }
  }
}