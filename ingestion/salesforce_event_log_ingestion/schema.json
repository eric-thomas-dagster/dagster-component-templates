{
  "component_type": "dagster_component_templates.SalesforceEventLogIngestionComponent",
  "description": "Pull Salesforce EventLogFile records (login, API access, report exports) via SOQL.",
  "category": "security",
  "icon": "Shield",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "instance_url": {
      "type": "string",
      "label": "Instance Url",
      "description": "Salesforce instance URL (e.g. 'https://acme.my.salesforce.com')",
      "required": true
    },
    "username_env": {
      "type": "string",
      "label": "Username Env",
      "description": "Username Env",
      "required": false,
      "default": "SF_USERNAME"
    },
    "password_env": {
      "type": "string",
      "label": "Password Env",
      "description": "Password Env",
      "required": false,
      "default": "SF_PASSWORD"
    },
    "security_token_env": {
      "type": "string",
      "label": "Security Token Env",
      "description": "Security Token Env",
      "required": false,
      "default": "SF_SECURITY_TOKEN"
    },
    "event_type": {
      "type": "string",
      "label": "Event Type",
      "description": "EventLogFile EventType (Login | API | ReportExport | etc.)",
      "required": false,
      "default": "Login"
    },
    "lookback_hours": {
      "type": "integer",
      "label": "Lookback Hours",
      "description": "How far back",
      "required": false,
      "default": 24
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Asset description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Dagster asset group",
      "required": false,
      "default": "security_audit"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Upstream asset deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Asset owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Catalog tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Asset kinds",
      "required": false
    },
    "freshness_max_lag_minutes": {
      "type": "integer",
      "label": "Freshness Max Lag Minutes",
      "description": "Freshness Max Lag Minutes",
      "required": false
    },
    "freshness_cron": {
      "type": "string",
      "label": "Freshness Cron",
      "description": "Freshness Cron",
      "required": false,
      "x-dagster-widget": "cron"
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "description": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "description": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "description": "Retry Policy Backoff",
      "required": false,
      "default": "exponential",
      "enum": [
        "exponential",
        "linear",
        "fixed"
      ],
      "ui:widget": "select"
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Emit preview metadata",
      "required": false,
      "default": true
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Preview row count",
      "required": false,
      "default": 20
    }
  }
}
