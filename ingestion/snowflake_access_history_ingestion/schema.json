{
  "component_type": "dagster_component_templates.SnowflakeAccessHistoryIngestionComponent",
  "description": "Pull Snowflake access history (every query, every column accessed) from the ACCOUNT_USAGE views.",
  "category": "security",
  "icon": "Shield",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "account": {
      "type": "string",
      "label": "Account",
      "description": "Snowflake account identifier (e.g. 'acme-prod')",
      "required": true
    },
    "user": {
      "type": "string",
      "label": "User",
      "description": "Snowflake user",
      "required": true
    },
    "password_env": {
      "type": "string",
      "label": "Password Env",
      "description": "Password Env",
      "required": false,
      "default": "SNOWFLAKE_PASSWORD"
    },
    "warehouse": {
      "type": "string",
      "label": "Warehouse",
      "description": "Warehouse",
      "required": false
    },
    "role": {
      "type": "string",
      "label": "Role",
      "description": "Role with access to ACCOUNT_USAGE",
      "required": false,
      "default": "ACCOUNTADMIN"
    },
    "lookback_hours": {
      "type": "integer",
      "label": "Lookback Hours",
      "description": "How far back",
      "required": false,
      "default": 24
    },
    "table": {
      "type": "string",
      "label": "Table",
      "description": "ACCESS_HISTORY | LOGIN_HISTORY | QUERY_HISTORY",
      "required": false,
      "default": "ACCESS_HISTORY"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Asset description",
      "required": false
