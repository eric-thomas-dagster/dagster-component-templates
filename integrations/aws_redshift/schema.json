{
  "component_type": "dagster_component_templates.AWSRedshiftComponent",
  "description": "Component for importing AWS Redshift entities as Dagster assets.",
  "category": "integration",
  "icon": "si:amazonredshift",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Integration result"
    }
  },
  "attributes": {
    "aws_region": {
      "type": "string",
      "label": "Aws Region",
      "description": "AWS region",
      "required": true
    },
    "aws_access_key_id": {
      "type": "string",
      "label": "Aws Access Key Id",
      "description": "Aws Access Key Id",
      "required": false,
      "default": null
    },
    "aws_secret_access_key": {
      "type": "string",
      "label": "Aws Secret Access Key",
      "description": "Aws Secret Access Key",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "aws_session_token": {
      "type": "string",
      "label": "Aws Session Token",
      "description": "Aws Session Token",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "cluster_identifier": {
      "type": "string",
      "label": "Cluster Identifier",
      "description": "Redshift cluster identifier",
      "required": true
    },
    "database": {
      "type": "string",
      "label": "Database",
      "description": "Redshift database name",
      "required": true
    },
    "db_user": {
      "type": "string",
      "label": "Db User",
      "description": "Db User",
      "required": false,
      "default": null
    },
    "secret_arn": {
      "type": "string",
      "label": "Secret Arn",
      "description": "Secret Arn",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "import_scheduled_queries": {
      "type": "boolean",
      "label": "Import Scheduled Queries",
      "description": "Import scheduled queries as materializable assets",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "import_stored_procedures": {
      "type": "boolean",
      "label": "Import Stored Procedures",
      "description": "Import stored procedures as materializable assets",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "import_materialized_views": {
      "type": "boolean",
      "label": "Import Materialized Views",
      "description": "Import materialized views as materializable assets",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "filter_by_name_pattern": {
      "type": "string",
      "label": "Filter By Name Pattern",
      "description": "Regex pattern to filter entities by name",
      "required": false,
      "default": null
    },
    "exclude_name_pattern": {
      "type": "string",
      "label": "Exclude Name Pattern",
      "description": "Regex pattern to exclude entities by name",
      "required": false,
      "default": null
    },
    "schema_name": {
      "type": "string",
      "label": "Schema Name",
      "description": "Schema name to query for procedures and views",
      "required": false,
      "default": "public"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group name for all imported assets",
      "required": false,
      "default": "aws_redshift"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description for the AWS Redshift component",
      "required": false,
      "default": null,
      "ui:widget": "code"
    }
  },
  "tags": [
    "integration",
    "aws",
    "redshift"
  ],
  "connectors": {
    "left": false,
    "right": false
  }
}
