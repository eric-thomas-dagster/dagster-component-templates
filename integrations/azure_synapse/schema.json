      "ui:widget": "code"
    },
    "resource_group_name": {
      "type": "string",
      "label": "Resource Group Name",
      "description": "Azure resource group name",
      "required": true
    },
    "workspace_name": {
      "type": "string",
      "label": "Workspace Name",
      "description": "Azure Synapse workspace name",
      "required": true
    },
    "tenant_id": {
      "type": "string",
      "label": "Tenant Id",
      "description": "Tenant Id",
      "required": false,
      "default": null
    },
    "client_id": {
      "type": "string",
      "label": "Client Id",
      "description": "Client Id",
      "required": false,
      "default": null
    },
    "client_secret": {
      "type": "string",
      "label": "Client Secret",
      "description": "Client Secret",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "import_pipelines": {
      "type": "boolean",
      "label": "Import Pipelines",
      "description": "Import pipelines as materializable assets",
      "required": false,
      "default": true,
