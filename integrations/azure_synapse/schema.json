      "description": "Regex pattern to filter entities by name",
      "required": false,
      "default": null
    },
    "exclude_name_pattern": {
      "type": "string",
      "label": "Exclude Name Pattern",
      "description": "Regex pattern to exclude entities by name",
      "required": false,
      "default": null
    },
    "filter_by_tags": {
      "type": "string",
      "label": "Filter By Tags",
      "description": "Comma-separated tag keys to filter entities (e.g., ",
