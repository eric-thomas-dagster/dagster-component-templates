{
  "component_type": "dagster_component_templates.DatabricksWorkspaceComponent",
  "description": "Component for importing Databricks workspace entities as Dagster assets.",
  "category": "integration",
  "icon": "si:databricks",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Integration result"
    }
  },
  "attributes": {
    "workspace_url": {
      "type": "string",
      "label": "Workspace Url",
      "description": "Workspace Url",
      "required": true
    },
    "access_token": {
      "type": "string",
      "label": "Access Token",
      "description": "Databricks personal access token",
      "required": true,
      "ui:widget": "password"
    },
    "import_jobs": {
      "type": "boolean",
      "label": "Import Jobs",
      "description": "Import Databricks jobs as assets",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "import_notebooks": {
      "type": "boolean",
      "label": "Import Notebooks",
      "description": "Import standalone notebooks as assets",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "import_dlt_pipelines": {
      "type": "boolean",
      "label": "Import Dlt Pipelines",
      "description": "Import Dlt Pipelines",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "import_model_endpoints": {
      "type": "boolean",
      "label": "Import Model Endpoints",
      "description": "Import ML model serving endpoints as observable assets",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "filter_by_tags": {
      "type": "string",
      "label": "Filter By Tags",
      "description": "Comma-separated list of tags to filter entities",
      "required": false,
      "default": null
    },
    "filter_by_name_pattern": {
      "type": "string",
      "label": "Filter By Name Pattern",
      "description": "Regex pattern to filter entities by name",
      "required": false,
      "default": null
    },
    "exclude_name_pattern": {
      "type": "string",
      "label": "Exclude Name Pattern",
      "description": "Regex pattern to exclude entities by name",
      "required": false,
      "default": null
    },
    "notebook_base_path": {
      "type": "string",
      "label": "Notebook Base Path",
      "description": "Notebook Base Path",
      "required": false,
      "default": null
    },
    "poll_interval_seconds": {
      "type": "integer",
      "label": "Poll Interval Seconds",
      "description": "Poll Interval Seconds",
      "required": false,
      "default": 60
    },
    "generate_sensor": {
      "type": "boolean",
      "label": "Generate Sensor",
      "description": "Create a sensor to observe runs from Databricks",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Group name for all imported assets",
      "required": false,
      "default": "databricks"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description for the Databricks workspace component",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "assets_by_job_name": {
      "type": "object",
      "label": "Assets By Job Name",
      "description": "Assets By Job Name",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    }
  },
  "tags": [
    "integration",
    "databricks",
    "workspace"
  ]
}