{
  "component_type": "dagster_community_components.GoogleAnalyticsWorkspaceComponent",
  "description": "Auto-emit one Dagster asset per GA4 property via the Admin API. StateBackedComponent — discovery cached to disk. Materializing an asset runs a runReport against the GA Data API for the configured metrics + dimensions over a rolling date range, returning a DataFrame.",
  "category": "ingestion",
  "icon": "AccountTree",
  "attributes": {
    "credentials_json_env_var": {"type": "string", "label": "Service-Account JSON Env Var", "required": true, "description": "Env var containing the full service-account credentials JSON blob (from Google Cloud Console)."},
    "verify_ssl": {"type": "boolean", "label": "Verify SSL", "required": false, "default": true, "ui:widget": "checkbox"},
    "property_selector": {"type": "object", "label": "Property Selector", "required": false, "description": "Fivetran-shape selector against property displayName."},
    "metrics": {"type": "array", "label": "Metrics", "required": false, "default": ["activeUsers", "sessions", "eventCount"], "description": "GA4 metric names for runReport."},
    "dimensions": {"type": "array", "label": "Dimensions", "required": false, "default": ["date"], "description": "GA4 dimension names for runReport."},
    "date_range_days": {"type": "integer", "label": "Date Range (days)", "required": false, "default": 30, "description": "Rolling window in days."},
    "group_name": {"type": "string", "label": "Group Name", "required": false},
    "asset_key_prefix": {"type": "array", "label": "Asset Key Prefix", "required": false, "default": ["ga"]},
    "compute_kind": {"type": "string", "label": "Compute Kind", "required": false, "default": "google_analytics"},
    "defs_state": {"type": "object", "label": "Defs State Config", "required": false}
  }
}
