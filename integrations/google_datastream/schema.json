{
  "component_type": "dagster_component_templates.GoogleDatastreamComponent",
  "description": "Component for importing Google Cloud Datastream entities as Dagster assets.",
  "category": "integration",
  "icon": "Plug",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Integration result"
    }
  },
  "attributes": {
    "project_id": {
      "type": "string",
      "label": "Project Id",
      "description": "GCP project ID",
      "required": true
    },
    "location": {
      "type": "string",
      "label": "Location",
      "description": "GCP location/region for Datastream resources",
      "required": false,
      "default": "us-central1"
    },
    "credentials_path": {
      "type": "string",
      "label": "Credentials Path",
      "description": "Credentials Path",
      "required": false,
      "default": null
    },
    "import_streams": {
      "type": "boolean",
      "label": "Import Streams",
      "description": "Import Datastream streams as observable assets",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "import_connection_profiles": {
      "type": "boolean",
      "label": "Import Connection Profiles",
      "description": "Import connection profiles as observable assets",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "filter_by_name_pattern": {
      "type": "string",
      "label": "Filter By Name Pattern",
      "description": "Regex pattern to filter entities by name",
      "required": false,
      "default": null
    },
    "exclude_name_pattern": {
      "type": "string",
      "label": "Exclude Name Pattern",
      "description": "Regex pattern to exclude entities by name",
      "required": false,
      "default": null
    },
    "poll_interval_seconds": {
      "type": "integer",
      "label": "Poll Interval Seconds",
      "description": "Sensor poll interval in seconds",
      "required": false,
      "default": 60
    },
    "generate_sensor": {
      "type": "boolean",
      "label": "Generate Sensor",
      "description": "Generate observation sensor for streams",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Asset group name for all imported assets",
      "required": false,
      "default": "google_datastream"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description for the Google Datastream component",
      "required": false,
      "default": null,
      "ui:widget": "code"
    }
  },
  "tags": [
    "integration",
    "google",
    "datastream"
  ],
  "connectors": {
    "left": false,
    "right": false
  }
}
