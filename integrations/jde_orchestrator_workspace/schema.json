{
  "component_type": "dagster_community_components.JDEOrchestratorWorkspaceComponent",
  "description": "Auto-emit one Dagster asset per JDE orchestration via the Orchestrator REST API. StateBackedComponent — discovery cached to disk, refreshed on explicit trigger. Materializing an asset executes the orchestration (sync or async) and polls to terminal state. The workspace-shape peer of the jde_orchestrator_* low-level components.",
  "category": "integration",
  "icon": "AccountTree",
  "attributes": {
    "base_url_env_var": {"type": "string", "label": "Base URL Env Var", "required": true},
    "username_env_var": {"type": "string", "label": "Username Env Var", "required": true},
    "password_env_var": {"type": "string", "label": "Password Env Var", "required": true},
    "api_path_prefix": {"type": "string", "label": "API Path Prefix", "required": false, "default": "/jderest/v3/orchestrator"},
    "verify_ssl": {"type": "boolean", "label": "Verify SSL", "required": false, "default": true, "ui:widget": "checkbox"},
    "orchestration_selector": {"type": "object", "label": "Orchestration Selector", "required": false, "description": "Fivetran-shape selector: by_name / by_pattern / exclude_by_name / exclude_by_pattern."},
    "group_name": {"type": "string", "label": "Group Name", "required": false},
    "asset_key_prefix": {"type": "array", "label": "Asset Key Prefix", "required": false, "default": ["jde", "orchestration"]},
    "compute_kind": {"type": "string", "label": "Compute Kind", "required": false, "default": "jde"},
    "async_mode": {"type": "boolean", "label": "Async Mode", "required": false, "default": false, "ui:widget": "checkbox"},
    "wait_for_completion": {"type": "boolean", "label": "Wait for Completion", "required": false, "default": true, "ui:widget": "checkbox"},
    "poll_interval_seconds": {"type": "integer", "label": "Poll Interval (s)", "required": false, "default": 15},
    "timeout_seconds": {"type": "integer", "label": "Timeout (s)", "required": false, "default": 1800},
    "defs_state": {"type": "object", "label": "Defs State Config", "required": false}
  }
}
