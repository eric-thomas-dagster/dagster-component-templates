{
  "component_type": "dagster_community_components.PagerDutyWorkspaceComponent",
  "description": "Auto-emit one Dagster asset per PagerDuty service. StateBackedComponent — discovery cached to disk. Materializing an asset fetches recent incidents for the service (statuses / assignees / timestamps) and emits a DataFrame.",
  "category": "ingestion",
  "icon": "AccountTree",
  "attributes": {
    "api_token_env_var": {"type": "string", "label": "API Token Env Var", "required": true, "description": "Env var with a PagerDuty API access key."},
    "verify_ssl": {"type": "boolean", "label": "Verify SSL", "required": false, "default": true, "ui:widget": "checkbox"},
    "service_selector": {"type": "object", "label": "Service Selector", "required": false, "description": "Fivetran-shape selector against service names."},
    "incidents_since_days": {"type": "integer", "label": "Incidents Since (days)", "required": false, "default": 30, "description": "Rolling window in days."},
    "incidents_limit": {"type": "integer", "label": "Incidents Limit", "required": false, "default": 100},
    "statuses": {"type": "array", "label": "Incident Statuses", "required": false, "default": ["triggered", "acknowledged", "resolved"], "description": "Statuses to include."},
    "group_name": {"type": "string", "label": "Group Name", "required": false},
    "asset_key_prefix": {"type": "array", "label": "Asset Key Prefix", "required": false, "default": ["pagerduty"]},
    "compute_kind": {"type": "string", "label": "Compute Kind", "required": false, "default": "pagerduty"},
    "defs_state": {"type": "object", "label": "Defs State Config", "required": false}
  }
}
