{
  "component_type": "dagster_community_components.QlikComposeWorkspaceComponent",
  "description": "Auto-emit one Dagster asset per Qlik Compose Workflow / Data Mart across every Project (Data Warehouse). StateBackedComponent — discovery cached to disk. Materializing a Workflow asset runs the workflow to terminal state; Data Mart assets are observational. The workspace-shape peer of the low-level qlik_compose_* components.",
  "category": "integration",
  "icon": "AccountTree",
  "attributes": {
    "base_url_env_var": {"type": "string", "label": "Base URL Env Var", "required": true},
    "username_env_var": {"type": "string", "label": "Username Env Var", "required": false},
    "password_env_var": {"type": "string", "label": "Password Env Var", "required": false},
    "api_token_env_var": {"type": "string", "label": "API Token Env Var", "required": false},
    "verify_ssl": {"type": "boolean", "label": "Verify SSL", "required": false, "default": true, "ui:widget": "checkbox"},
    "projects": {"type": "array", "label": "Projects Filter", "required": false},
    "workflow_selector": {"type": "object", "label": "Workflow Selector", "required": false, "description": "Fivetran-shape selector: by_name / by_pattern / exclude_by_name / exclude_by_pattern."},
    "data_mart_selector": {"type": "object", "label": "Data Mart Selector", "required": false, "description": "Fivetran-shape selector for data marts."},
    "group_name": {"type": "string", "label": "Group Name", "required": false},
    "asset_key_prefix": {"type": "array", "label": "Asset Key Prefix", "required": false, "default": ["qlik_compose"]},
    "compute_kind": {"type": "string", "label": "Compute Kind", "required": false, "default": "qlik_compose"},
    "wait_for_completion": {"type": "boolean", "label": "Wait for Completion", "required": false, "default": true, "ui:widget": "checkbox"},
    "poll_interval_seconds": {"type": "integer", "label": "Poll Interval (s)", "required": false, "default": 30},
    "timeout_seconds": {"type": "integer", "label": "Timeout (s)", "required": false, "default": 3600},
    "defs_state": {"type": "object", "label": "Defs State Config", "required": false}
  }
}
