{
  "component_type": "dagster_community_components.ServiceNowWorkspaceComponent",
  "description": "Auto-emit one Dagster asset per ServiceNow table by enumerating sys_db_object. StateBackedComponent \u2014 discovery cached to disk. Materializing an asset reads recent records via the Table API. Workspace-shape peer of servicenow_ingestion (single-table).",
  "category": "ingestion",
  "icon": "AccountTree",
  "attributes": {
    "instance_env_var": {
      "type": "string",
      "label": "Instance Env Var",
      "required": true,
      "description": "Env var with the ServiceNow instance subdomain (e.g. dev123456)."
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "required": true
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "required": true
    },
    "verify_ssl": {
      "type": "boolean",
      "label": "Verify SSL",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "table_selector": {
      "type": "object",
      "label": "Table Selector",
      "required": false,
      "description": "Fivetran-shape selector across sys_db_object."
    },
    "query": {
      "type": "string",
      "label": "sysparm_query Filter",
      "required": false,
      "description": "ServiceNow encoded-query filter applied to every table."
    },
    "query_limit": {
      "type": "integer",
      "label": "Query Limit",
      "required": false,
      "default": 100
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "required": false
    },
    "asset_key_prefix": {
      "type": "array",
      "label": "Asset Key Prefix",
      "required": false,
      "default": [
        "servicenow"
      ]
    },
    "compute_kind": {
      "type": "string",
      "label": "Compute Kind",
      "required": false,
      "default": "servicenow"
    },
    "defs_state": {
      "type": "object",
      "label": "Defs State Config",
      "required": false
    }
  }
}
