{
  "component_type": "dagster_component_templates.SnowflakeCortexSearchComponent",
  "description": "Query a Snowflake Cortex Search Service and materialize the results as a Dagster asset.",
  "category": "ai",
  "icon": "Snowflake",
  "attributes": {
    "asset_name": {
      "type": "string",
      "required": true,
      "description": "Output Dagster asset name"
    },
    "account": {
      "type": "string",
      "required": true,
      "description": "Snowflake account, e.g. xy12345-abc."
    },
    "user": {
      "type": "string",
      "required": true,
      "description": "Snowflake user (NAME for keypair, LOGIN_NAME for password/SSO/PAT)."
    },
    "warehouse": {
      "type": "string",
      "required": false
    },
    "database": {
      "type": "string",
      "required": true,
      "description": "Database containing the search service."
    },
    "schema_name": {
      "type": "string",
      "required": true,
      "description": "Schema containing the search service."
    },
    "role": {
      "type": "string",
      "required": false
    },
    "password": {
      "type": "string",
      "required": false,
      "description": "Snowflake password."
    },
    "authenticator": {
      "type": "string",
      "required": false,
      "description": "Snowflake authenticator: 'SNOWFLAKE_JWT' (keypair), 'externalbrowser' (SSO), 'PROGRAMMATIC_ACCESS_TOKEN' (PAT), 'oauth'."
    },
    "private_key_file": {
      "type": "string",
      "required": false
    },
    "private_key_file_pwd": {
      "type": "string",
      "required": false
    },
    "token": {
      "type": "string",
      "required": false
    },
    "service_name": {
      "type": "string",
      "required": true,
      "description": "Name of the Cortex Search Service to query. Unqualified \u2014 gets resolved to `database.schema_name.service_name`."
    },
    "query": {
      "type": "string",
      "required": true,
      "description": "The search query (natural-language text)."
    },
    "result_limit": {
      "type": "integer",
      "required": false,
      "description": "Max number of results to return."
    },
    "result_columns": {
      "type": "array",
      "required": false,
      "description": "Subset of the search service's source columns to return per result (e.g. ['CONTENT', 'TITLE', 'URL']). If unset, all columns the service exposes are returned.",
      "x-dagster-widget": "columns"
    },
    "result_filter": {
      "type": "string",
      "required": false,
      "description": "Optional JSON filter applied at query time (e.g. '{\"@eq\": {\"category\": \"docs\"}}'). See Cortex Search docs for filter syntax."
    },
    "group_name": {
      "type": "string",
      "required": false
    },
    "description": {
      "type": "string",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "required": false
    },
    "kinds": {
      "type": "array",
      "required": false
    },
    "owners": {
      "type": "array",
      "required": false
    },
    "deps": {
      "type": "array",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "required": false,
      "description": "Max retries on query failure. Defines a RetryPolicy."
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "required": false,
      "enum": [
        "exponential",
        "linear",
        "fixed"
      ],
      "ui:widget": "select"
    }
  }
}
