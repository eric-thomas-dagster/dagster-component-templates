      "description": "Account",
      "required": true
    },
    "user": {
      "type": "string",
      "label": "User",
      "description": "Snowflake username",
      "required": true
    },
    "password": {
      "type": "string",
      "label": "Password",
      "description": "Snowflake password",
      "required": true,
      "ui:widget": "password"
    },
    "warehouse": {
      "type": "string",
