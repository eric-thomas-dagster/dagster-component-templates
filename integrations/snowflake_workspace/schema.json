{
  "component_type": "dagster_component_templates.SnowflakeWorkspaceComponent",
  "description": "Component for importing Snowflake workspace entities as Dagster assets.",
  "category": "integration",
  "icon": "si:snowflake",
  "x-dagster-io": {
    "outputs": {
      "type": "MaterializeResult",
      "description": "Integration result"
