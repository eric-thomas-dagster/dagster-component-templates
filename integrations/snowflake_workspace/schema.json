      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "import_external_tables": {
      "type": "boolean",
      "label": "Import External Tables",
      "description": "Import External Tables",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "import_alerts": {
      "type": "boolean",
      "label": "Import Alerts",
      "description": "Import Alerts",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "import_openflow_flows": {
      "type": "boolean",
      "label": "Import Openflow Flows",
      "description": "Import Openflow Flows",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
