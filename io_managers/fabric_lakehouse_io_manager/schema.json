{
  "component_type": "dagster_component_templates.FabricLakehouseIOManagerComponent",
  "description": "ConfigurableIOManager: auto-serializes asset DataFrames as Delta tables in a Fabric Lakehouse on OneLake. Asset key becomes the table name (sanitized). Tables auto-register in the Fabric SQL endpoint.",
  "category": "io_manager",
  "icon": "Database",
  "x-dagster-io": {
    "supports_partitions": false
  },
  "attributes": {
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "required": false,
      "default": "io_manager"
    },
    "workspace_id": {
      "type": "string",
      "label": "Workspace Id",
      "required": true,
      "default": null
    },
    "lakehouse_name": {
      "type": "string",
      "label": "Lakehouse Name",
      "required": true,
      "default": null
    },
    "if_exists": {
      "type": "string",
      "label": "If Exists",
      "required": false,
      "default": "overwrite",
      "enum": [
        "overwrite",
        "append"
      ]
    },
    "table_prefix": {
      "type": "string",
      "label": "Table Prefix",
      "required": false,
      "default": ""
    },
    "tenant_id_env_var": {
      "type": "string",
      "label": "Tenant Id Env Var",
      "required": false,
      "default": null
    },
    "client_id_env_var": {
      "type": "string",
      "label": "Client Id Env Var",
      "required": false,
      "default": null
    },
    "client_secret_env_var": {
      "type": "string",
      "label": "Client Secret Env Var",
      "required": false,
      "default": null
    }
  }
}