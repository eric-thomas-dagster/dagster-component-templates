    },
    "connection_url_env_var": {
      "type": "string",
      "label": "Connection Url Env Var",
      "required": true
    },
    "schema_name": {
      "type": "string",
      "label": "Schema Name",
      "required": false
    },
    "if_exists": {
      "type": "string",
      "label": "If Exists",
      "required": true,
      "enum": [
        "fail",
        "replace",
        "append"
      ],
      "ui:widget": "select"
    }
  },
  "tags": [
    "io_manager",
    "mysql",
    "mariadb",
    "sql"
  ],
  "name": "MySQLIOManager"
