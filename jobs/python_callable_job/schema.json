{
  "component_type": "dagster_component_templates.PythonCallableJobComponent",
  "description": "Run an arbitrary Python callable as a Dagster job \u2014 Airflow PythonOperator equivalent.",
  "category": "infrastructure",
  "icon": "Cog",
  "attributes": {
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Dagster job name",
      "required": true
    },
    "schedule": {
      "type": "string",
      "label": "Schedule",
      "description": "Cron schedule (None = no schedule)",
      "required": false,
      "x-dagster-widget": "cron"
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "One of: STOPPED / RUNNING.",
      "required": false,
      "default": "STOPPED",
      "enum": [
        "STOPPED",
        "RUNNING"
      ],
      "ui:widget": "select"
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "description": "Dagster job tags",
      "required": false
    },
    "callable_path": {
      "type": "string",
      "label": "Callable Path",
      "description": "'module.path:function_name' (e.g. 'mypkg.cleanup:run')",
      "required": true
    },
    "kwargs": {
      "type": "object",
      "label": "Kwargs",
      "description": "Keyword arguments passed to the callable",
      "required": false
    }
  }
}
