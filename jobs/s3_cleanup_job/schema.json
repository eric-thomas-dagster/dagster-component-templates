{
  "component_type": "dagster_component_templates.S3CleanupJobComponent",
  "description": "Delete S3 objects older than N days under a prefix \u2014 cost control + compliance retention.",
  "category": "infrastructure",
  "icon": "Cog",
  "attributes": {
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Dagster job name",
      "required": true
    },
    "schedule": {
      "type": "string",
      "label": "Schedule",
      "description": "Cron schedule (None = no schedule)",
      "required": false,
      "x-dagster-widget": "cron"
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "One of: STOPPED / RUNNING.",
      "required": false,
      "default": "STOPPED",
      "enum": [
        "STOPPED",
        "RUNNING"
      ],
      "ui:widget": "select"
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "description": "Dagster job tags",
      "required": false
    },
    "bucket": {
      "type": "string",
      "label": "Bucket",
      "description": "S3 bucket name",
      "required": true
    },
    "prefix": {
      "type": "string",
      "label": "Prefix",
      "description": "Object prefix to scope cleanup",
      "required": false,
      "default": ""
    },
    "older_than_days": {
      "type": "integer",
      "label": "Older Than Days",
      "description": "Delete objects older than this many days",
      "required": true
    },
    "region_name": {
      "type": "string",
      "label": "Region Name",
      "description": "Region Name",
      "required": false,
      "default": "us-east-1"
    },
    "aws_profile": {
      "type": "string",
      "label": "Aws Profile",
      "description": "Aws Profile",
      "required": false
    },
    "dry_run": {
      "type": "boolean",
      "label": "Dry Run",
      "description": "Report what would be deleted without deleting",
      "required": false,
      "default": false
    }
  }
}
