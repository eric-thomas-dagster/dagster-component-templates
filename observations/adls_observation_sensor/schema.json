{
  "type": "dagster_component_templates.AdlsObservationSensorComponent",
  "name": "ADLS Observation Sensor",
  "category": "sensors",
  "description": "Emit health observations for an external ADLS asset",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "observation_sensor"
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "required": true,
      "label": "Sensor Name"
    },
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key"
    },
    "account_name": {
      "type": "string",
      "required": true,
      "label": "Account Name"
    },
    "container_name": {
      "type": "string",
      "required": true,
      "label": "Container Name"
    },
    "path_prefix": {
      "type": "string",
      "required": false,
      "label": "Path Prefix",
      "default": ""
    },
    "connection_string_env_var": {
      "type": "string",
      "required": false,
      "label": "Connection String Env Var"
    },
    "check_interval_seconds": {
      "type": "number",
      "required": false,
      "label": "Check Interval (s)",
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "required": false,
      "label": "Resource Key"
    }
  },
  "dependencies": {
    "pip": [
      "azure-storage-file-datalake>=12.0.0",
      "azure-identity>=1.10.0"
    ]
  },
  "tags": [
    "sensors",
    "observation"
  ]
}
