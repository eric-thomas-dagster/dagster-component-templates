{
  "component_type": "dagster_component_templates.BigQueryTableObservationSensorComponent",
  "description": "Emit health observations for an external BigQuery table.",
  "category": "observation",
  "icon": "si:googlebigquery",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalBigQueryTableAsset to observe",
      "required": true
    },
    "project_id": {
      "type": "string",
      "label": "Project Id",
      "description": "GCP project ID",
      "required": true
    },
    "dataset_id": {
      "type": "string",
      "label": "Dataset Id",
      "description": "BigQuery dataset ID",
      "required": true
    },
    "table_id": {
      "type": "string",
      "label": "Table Id",
      "description": "BigQuery table ID",
      "required": true
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "observation",
    "bigquery",
    "table",
    "sensor"
  ]
