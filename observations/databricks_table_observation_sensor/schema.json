{
  "component_type": "dagster_component_templates.DatabricksTableObservationSensorComponent",
  "description": "Emit health observations for an external Databricks Delta table.",
  "category": "observation",
  "icon": "si:databricks",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalDatabricksTableAsset to observe",
      "required": true
    },
    "workspace_url": {
      "type": "string",
      "label": "Workspace Url",
      "description": "Databricks workspace URL",
      "required": true
    },
    "catalog": {
      "type": "string",
      "label": "Catalog",
      "description": "Unity Catalog name",
      "required": false,
      "default": null
    },
    "schema_name": {
      "type": "string",
      "label": "Schema Name",
      "description": "Schema/database name",
      "required": true
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Table name",
      "required": true
    },
    "token_env_var": {
      "type": "string",
      "label": "Token Env Var",
      "description": "Env var with Databricks personal access token",
      "required": true
    },
    "http_path": {
      "type": "string",
      "label": "Http Path",
      "description": "Http Path",
      "required": true
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "observation",
    "databricks",
    "table",
    "sensor"
  ]
}