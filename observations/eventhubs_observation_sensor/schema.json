{
  "type": "dagster_component_templates.EventHubsObservationSensorComponent",
  "name": "Event Hubs Observation Sensor",
  "category": "sensors",
  "description": "Emit health observations for an external Event Hub",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "observation_sensor"
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "required": true,
      "label": "Sensor Name"
    },
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key"
    },
    "namespace": {
      "type": "string",
      "required": true,
      "label": "Namespace"
    },
    "eventhub_name": {
      "type": "string",
      "required": true,
      "label": "Event Hub Name"
    },
    "connection_string_env_var": {
      "type": "string",
      "required": false,
      "label": "Connection String Env Var"
    },
    "check_interval_seconds": {
      "type": "number",
      "required": false,
      "label": "Check Interval (s)",
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "required": false,
      "label": "Resource Key"
    }
  },
  "dependencies": {
    "pip": [
      "azure-eventhub>=5.10.0",
      "azure-identity>=1.10.0"
    ]
  },
  "tags": [
    "sensors",
    "observation"
  ]
}
