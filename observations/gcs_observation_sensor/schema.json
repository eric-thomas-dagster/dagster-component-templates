{
  "component_type": "dagster_component_templates.GcsObservationSensorComponent",
  "description": "GcsObservationSensorComponent",
  "category": "observation",
  "icon": "si:googlecloud",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalGcsAsset to observe",
      "required": true
    },
    "bucket_name": {
      "type": "string",
      "label": "Bucket Name",
      "description": "GCS bucket name",
      "required": true
    },
    "prefix": {
      "type": "string",
      "label": "Prefix",
      "description": "Object prefix",
      "required": false,
      "default": ""
    },
    "project": {
      "type": "string",
      "label": "Project",
      "description": "GCP project ID",
      "required": false,
      "default": null
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "observation",
    "gcs",
    "sensor"
  ]
}