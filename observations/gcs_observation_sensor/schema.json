{
  "type": "dagster_component_templates.GcsObservationSensorComponent",
  "name": "GCS Observation Sensor",
  "category": "sensors",
  "description": "Emit health observations for an external GCS asset",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "observation_sensor"
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "required": true,
      "label": "Sensor Name"
    },
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key"
    },
    "bucket_name": {
      "type": "string",
      "required": true,
      "label": "Bucket Name"
    },
    "prefix": {
      "type": "string",
      "required": false,
      "label": "Prefix",
      "default": ""
    },
    "project": {
      "type": "string",
      "required": false,
      "label": "GCP Project"
    },
    "check_interval_seconds": {
      "type": "number",
      "required": false,
      "label": "Check Interval (s)",
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "required": false,
      "label": "Resource Key"
    }
  },
  "dependencies": {
    "pip": [
      "google-cloud-storage>=2.0.0"
    ]
  },
  "tags": [
    "sensors",
    "observation"
  ]
}
