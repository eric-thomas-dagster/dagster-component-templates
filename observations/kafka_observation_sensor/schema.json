    },
    "bootstrap_servers": {
      "type": "string",
      "label": "Bootstrap Servers",
      "description": "Comma-separated Kafka broker addresses",
      "required": true
    },
    "topic": {
      "type": "string",
      "label": "Topic",
      "description": "Kafka topic name",
      "required": true
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "observation",
    "kafka",
    "sensor"
  ]
