{
  "type": "dagster_component_templates.KafkaObservationSensorComponent",
  "name": "Kafka Observation Sensor",
  "category": "sensors",
  "description": "Emit health observations for an external Kafka asset",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "observation_sensor"
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "required": true,
      "label": "Sensor Name"
    },
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key"
    },
    "bootstrap_servers": {
      "type": "string",
      "required": true,
      "label": "Bootstrap Servers"
    },
    "topic": {
      "type": "string",
      "required": true,
      "label": "Topic"
    },
    "check_interval_seconds": {
      "type": "number",
      "required": false,
      "label": "Check Interval (s)",
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "required": false,
      "label": "Resource Key"
    }
  },
  "dependencies": {
    "pip": [
      "kafka-python>=2.0.0"
    ]
  },
  "tags": [
    "sensors",
    "observation"
  ]
}
