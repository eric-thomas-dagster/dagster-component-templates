{
  "component_type": "dagster_component_templates.MqttObservationSensorComponent",
  "description": "MqttObservationSensorComponent",
  "category": "observation",
  "icon": "Eye",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalMqttAsset to observe",
      "required": true
    },
    "broker_host": {
      "type": "string",
      "label": "Broker Host",
      "description": "MQTT broker hostname",
      "required": true
    },
    "topic": {
      "type": "string",
      "label": "Topic",
      "description": "MQTT topic to subscribe to",
      "required": true
    },
    "broker_port": {
      "type": "integer",
      "label": "Broker Port",
      "description": "MQTT broker port",
      "required": false,
      "default": 1883
    },
    "connect_timeout_seconds": {
      "type": "number",
      "label": "Connect Timeout Seconds",
      "description": "Seconds to wait for connection",
      "required": false,
      "default": 5.0
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "observation",
    "mqtt",
    "sensor"
  ],
  "name": "Mqtt Observation Sensor"
}