{
  "type": "dagster_component_templates.NatsObservationSensorComponent",
  "name": "NATS Observation Sensor",
  "category": "sensors",
  "description": "Emit health observations for an external NATS JetStream stream",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "observation_sensor"
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "required": true,
      "label": "Sensor Name"
    },
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key"
    },
    "servers": {
      "type": "string",
      "required": true,
      "label": "Servers"
    },
    "stream_name": {
      "type": "string",
      "required": true,
      "label": "Stream Name"
    },
    "credentials_env_var": {
      "type": "string",
      "required": false,
      "label": "Credentials Env Var"
    },
    "check_interval_seconds": {
      "type": "number",
      "required": false,
      "label": "Check Interval (s)",
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "required": false,
      "label": "Resource Key"
    }
  },
  "dependencies": {
    "pip": [
      "nats-py>=2.3.0"
    ]
  },
  "tags": [
    "sensors",
    "observation"
  ]
}
