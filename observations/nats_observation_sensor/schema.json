{
  "component_type": "dagster_component_templates.NatsObservationSensorComponent",
  "description": "NatsObservationSensorComponent",
  "category": "observation",
  "icon": "Eye",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalNatsAsset to observe",
      "required": true
    },
    "servers": {
      "type": "string",
      "label": "Servers",
      "description": "Comma-separated NATS server URLs",
      "required": true
    },
    "stream_name": {
      "type": "string",
      "label": "Stream Name",
      "description": "JetStream stream name",
      "required": true
    },
    "credentials_env_var": {
      "type": "string",
      "label": "Credentials Env Var",
      "description": "Env var with path to NATS .creds file",
      "required": false,
      "default": null
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "observation",
    "nats",
    "sensor"
  ],
  "connectors": {
    "left": false,
    "right": false
  }
}
