{
  "component_type": "dagster_component_templates.PubsubObservationSensorComponent",
  "description": "PubsubObservationSensorComponent",
  "category": "observation",
  "icon": "Eye",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalPubsubAsset to observe",
      "required": true
    },
    "project_id": {
      "type": "string",
      "label": "Project Id",
      "description": "GCP project ID",
      "required": true
    },
    "topic_id": {
      "type": "string",
      "label": "Topic Id",
      "description": "Pub/Sub topic ID",
      "required": true
    },
    "subscription_id": {
      "type": "string",
      "label": "Subscription Id",
      "description": "Subscription ID for lag metrics",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "observation",
    "pubsub",
    "sensor"
  ]
