{
  "type": "dagster_component_templates.PulsarObservationSensorComponent",
  "name": "Pulsar Observation Sensor",
  "category": "sensors",
  "description": "Emit health observations for an external Pulsar topic",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "observation_sensor"
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "required": true,
      "label": "Sensor Name"
    },
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key"
    },
    "service_url": {
      "type": "string",
      "required": true,
      "label": "Service URL"
    },
    "topic": {
      "type": "string",
      "required": true,
      "label": "Topic"
    },
    "admin_url": {
      "type": "string",
      "required": false,
      "label": "Admin URL"
    },
    "jwt_token_env_var": {
      "type": "string",
      "required": false,
      "label": "JWT Token Env Var"
    },
    "check_interval_seconds": {
      "type": "number",
      "required": false,
      "label": "Check Interval (s)",
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "required": false,
      "label": "Resource Key"
    }
  },
  "dependencies": {
    "pip": [
      "pulsar-client>=3.0.0"
    ]
  },
  "tags": [
    "sensors",
    "observation"
  ]
}
