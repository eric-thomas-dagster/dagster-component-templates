{
  "component_type": "dagster_component_templates.RabbitmqObservationSensorComponent",
  "description": "RabbitmqObservationSensorComponent",
  "category": "observation",
  "icon": "si:rabbitmq",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalRabbitmqAsset to observe",
      "required": true
    },
    "host": {
      "type": "string",
      "label": "Host",
      "description": "RabbitMQ host",
      "required": true
    },
    "queue_name": {
      "type": "string",
      "label": "Queue Name",
      "description": "RabbitMQ queue name",
      "required": true
    },
    "virtual_host": {
      "type": "string",
      "label": "Virtual Host",
      "description": "RabbitMQ virtual host",
      "required": false,
      "default": "/"
    },
    "port": {
      "type": "integer",
      "label": "Port",
      "description": "AMQP port",
      "required": false,
      "default": 5672
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "description": "Env var with username",
      "required": false,
      "default": null
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var with password",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 60
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "observation",
    "rabbitmq",
    "sensor"
  ]
}