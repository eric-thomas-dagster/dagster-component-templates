{
  "component_type": "dagster_component_templates.RedisStreamObservationSensorComponent",
  "description": "RedisStreamObservationSensorComponent",
  "category": "observation",
  "icon": "si:redis",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalRedisStreamAsset to observe",
      "required": true
    },
    "stream_name": {
      "type": "string",
      "label": "Stream Name",
      "description": "Redis stream name",
      "required": true
    },
    "host": {
      "type": "string",
      "label": "Host",
      "description": "Redis host",
      "required": false,
      "default": "localhost"
    },
    "port": {
      "type": "integer",
      "label": "Port",
      "description": "Redis port",
      "required": false,
      "default": 6379
    },
    "db": {
      "type": "integer",
      "label": "Db",
      "description": "Redis database index",
      "required": false,
      "default": 0
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var with Redis password",
      "required": false,
      "default": null,
      "ui:widget": "env_var"
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 60
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "observation",
    "redis",
    "stream",
    "sensor"
  ],
  "name": "Redis Stream Observation Sensor"
}