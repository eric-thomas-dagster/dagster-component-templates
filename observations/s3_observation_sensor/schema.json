{
  "type": "dagster_component_templates.S3ObservationSensorComponent",
  "name": "S3 Observation Sensor",
  "category": "sensors",
  "description": "Emit health observations for an external S3 asset",
  "icon": "Database",
  "x-dagster-io": {
    "component_type": "observation_sensor"
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "required": true,
      "label": "Sensor Name",
      "placeholder": "s3_orders_obs"
    },
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key",
      "placeholder": "raw/orders"
    },
    "bucket_name": {
      "type": "string",
      "required": true,
      "label": "Bucket Name",
      "placeholder": "my-data-bucket"
    },
    "prefix": {
      "type": "string",
      "required": false,
      "label": "Prefix",
      "default": ""
    },
    "region_name": {
      "type": "string",
      "required": false,
      "label": "Region"
    },
    "check_interval_seconds": {
      "type": "number",
      "required": false,
      "label": "Check Interval (s)",
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "required": false,
      "label": "Resource Key"
    }
  },
  "dependencies": {
    "pip": [
      "boto3>=1.20.0"
    ]
  },
  "tags": [
    "sensors",
    "observation"
  ]
}
