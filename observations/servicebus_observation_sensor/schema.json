{
  "component_type": "dagster_component_templates.ServiceBusObservationSensorComponent",
  "description": "ServiceBusObservationSensorComponent",
  "category": "observation",
  "icon": "Eye",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalServiceBusAsset to observe",
      "required": true
    },
    "namespace": {
      "type": "string",
      "label": "Namespace",
      "description": "Azure Service Bus namespace",
      "required": true
    },
    "queue_name": {
      "type": "string",
      "label": "Queue Name",
      "description": "Queue Name",
      "required": false,
      "default": null
    },
    "topic_name": {
      "type": "string",
      "label": "Topic Name",
      "description": "Topic name",
      "required": false,
      "default": null
    },
    "subscription_name": {
      "type": "string",
      "label": "Subscription Name",
      "description": "Subscription Name",
      "required": false,
      "default": null,
      "ui:widget": "code"
    },
    "connection_string_env_var": {
      "type": "string",
      "label": "Connection String Env Var",
      "description": "Env var with connection string",
      "required": false,
      "default": null
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 60
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "observation",
    "servicebus",
    "sensor"
  ]
}