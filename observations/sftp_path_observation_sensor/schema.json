{
  "type": "dagster_component_templates.SftpPathObservationSensorComponent",
  "name": "SFTP Path Observation Sensor",
  "category": "observations",
  "description": "Emit health observations for an external SFTP path",
  "icon": "Database",
  "attributes": {
    "sensor_name": {
      "type": "string",
      "required": true,
      "label": "Sensor Name"
    },
    "asset_key": {
      "type": "string",
      "required": true,
      "label": "Asset Key"
    },
    "host": {
      "type": "string",
      "required": true,
      "label": "Host"
    },
    "port": {
      "type": "number",
      "required": false,
      "label": "Port",
      "default": 22
    },
    "remote_path": {
      "type": "string",
      "required": true,
      "label": "Remote Path"
    },
    "username_env_var": {
      "type": "string",
      "required": true,
      "label": "Username Env Var"
    },
    "password_env_var": {
      "type": "string",
      "required": false,
      "label": "Password Env Var"
    },
    "private_key_env_var": {
      "type": "string",
      "required": false,
      "label": "Private Key Env Var"
    },
    "check_interval_seconds": {
      "type": "number",
      "required": false,
      "label": "Check Interval (s)",
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "required": false,
      "label": "Resource Key"
    }
  },
  "dependencies": {
    "pip": [
      "paramiko>=3.0.0"
    ]
  },
  "tags": [
    "observations",
    "sftp",
    "files",
    "monitoring"
  ]
}
