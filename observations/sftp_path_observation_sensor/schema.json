{
  "component_type": "dagster_component_templates.SftpPathObservationSensorComponent",
  "description": "Emit health observations for an external SFTP path.",
  "category": "observation",
  "icon": "Eye",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalSftpPathAsset to observe",
      "required": true
    },
    "host": {
      "type": "string",
      "label": "Host",
      "description": "SFTP host",
      "required": true
    },
    "port": {
      "type": "integer",
      "label": "Port",
      "description": "SFTP port",
      "required": false,
      "default": 22
    },
    "remote_path": {
      "type": "string",
      "label": "Remote Path",
      "description": "Remote directory path",
      "required": true
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "description": "Env var with SFTP username",
      "required": true
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var with SFTP password",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "private_key_env_var": {
      "type": "string",
      "label": "Private Key Env Var",
      "description": "Env var with path to SSH private key",
      "required": false,
      "default": null
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "observation",
    "sftp",
    "path",
    "sensor"
  ]
}