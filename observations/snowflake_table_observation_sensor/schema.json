{
  "component_type": "dagster_component_templates.SnowflakeTableObservationSensorComponent",
  "description": "Emit health observations for an external Snowflake table.",
  "category": "observation",
  "icon": "si:snowflake",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalSnowflakeTableAsset to observe",
      "required": true
    },
    "account": {
      "type": "string",
      "label": "Account",
      "description": "Snowflake account identifier",
      "required": true
    },
    "database": {
      "type": "string",
      "label": "Database",
      "description": "Snowflake database",
      "required": true
    },
    "schema_name": {
      "type": "string",
      "label": "Schema Name",
      "description": "Snowflake schema",
      "required": true
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Snowflake table",
      "required": true
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "description": "Env var with Snowflake username",
      "required": true
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var with password",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "warehouse": {
      "type": "string",
      "label": "Warehouse",
      "description": "Snowflake warehouse to use",
      "required": false,
      "default": null
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "observation",
    "snowflake",
    "table",
    "sensor"
  ],
  "connectors": {
    "left": false,
    "right": false
  }
}
