{
  "component_type": "dagster_component_templates.SqlObservationSensorComponent",
  "description": "SqlObservationSensorComponent",
  "category": "observation",
  "icon": "Eye",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalSqlAsset to observe",
      "required": true
    },
    "table_name": {
      "type": "string",
      "label": "Table Name",
      "description": "Table name to observe",
      "required": true
    },
    "connection_string_env_var": {
      "type": "string",
      "label": "Connection String Env Var",
      "description": "Env var with SQLAlchemy connection string",
      "required": true
    },
    "watermark_column": {
      "type": "string",
      "label": "Watermark Column",
      "description": "Watermark Column",
      "required": false,
      "default": null
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 300
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "observation",
    "sql",
    "sensor"
  ],
  "name": "SQL Observation Sensor"
}