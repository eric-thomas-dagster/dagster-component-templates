{
  "component_type": "dagster_component_templates.SqsObservationSensorComponent",
  "description": "SqsObservationSensorComponent",
  "category": "observation",
  "icon": "Eye",
  "x-dagster-io": {
    "outputs": {
      "type": "AssetObservation",
      "description": "Asset observation events"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "asset_key": {
      "type": "string",
      "label": "Asset Key",
      "description": "Asset key of the ExternalSqsAsset to observe",
      "required": true
    },
    "queue_url": {
      "type": "string",
      "label": "Queue Url",
      "description": "Full SQS queue URL",
      "required": true
    },
    "region_name": {
      "type": "string",
      "label": "Region Name",
      "description": "AWS region",
      "required": false,
      "default": null
    },
    "check_interval_seconds": {
      "type": "integer",
      "label": "Check Interval Seconds",
      "description": "Seconds between health checks",
      "required": false,
      "default": 60
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "observation",
    "sqs",
    "sensor"
  ]
}