    },
    "username": {
      "type": "string",
      "default": "",
      "description": "Username for basic auth (optional)."
    },
    "password_env_var": {
      "type": "string",
      "description": "Name of the environment variable holding the password for basic auth.",
      "ui:widget": "password"
    },
    "verify_certs": {
      "type": "boolean",
      "default": true,
      "description": "Whether to verify TLS certificates."
    }
  },
  "required": [
