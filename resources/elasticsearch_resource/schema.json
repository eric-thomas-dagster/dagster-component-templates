{
  "x-dagster-io": {},
  "x-dagster-provides": [
    "elasticsearch_resource"
  ],
  "category": "resource",
  "type": "object",
  "properties": {
    "resource_key": {
      "type": "string",
      "default": "elasticsearch_resource",
      "description": "The key under which the Elasticsearch resource is registered."
    },
    "hosts": {
      "type": "string",
      "description": "Elasticsearch host URL (e.g. https://my-cluster.es.io:9243)."
    },
    "api_key_env_var": {
      "type": "string",
      "description": "Name of the environment variable holding the Elasticsearch API key.",
