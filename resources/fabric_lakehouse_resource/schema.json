      "default": "fabric_lakehouse"
    },
    "workspace_id": {
      "type": "string",
      "label": "Workspace Id",
      "required": true,
      "default": null
    },
    "lakehouse_name": {
      "type": "string",
      "label": "Lakehouse Name",
      "required": true,
      "default": null
    },
    "tenant_id_env_var": {
      "type": "string",
      "label": "Tenant Id Env Var",
      "required": false,
      "default": null
    },
    "client_id_env_var": {
      "type": "string",
      "label": "Client Id Env Var",
      "required": false,
      "default": null
    },
    "client_secret_env_var": {
      "type": "string",
      "label": "Client Secret Env Var",
      "required": false,
      "default": null
    }
  }
}