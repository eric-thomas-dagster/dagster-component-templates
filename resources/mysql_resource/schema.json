{
  "x-dagster-io": {},
  "x-dagster-provides": [
    "mysql_resource"
  ],
  "category": "resource",
  "type": "object",
  "properties": {
    "resource_key": {
      "type": "string",
      "default": "mysql_resource",
      "description": "The key under which the MySQL resource is registered."
    },
    "host": {
      "type": "string",
      "description": "MySQL server hostname."
    },
    "port": {
      "type": "integer",
      "default": 3306,
      "description": "MySQL server port."
    },
    "database": {
      "type": "string",
      "description": "Target database name."
    },
    "username": {
      "type": "string",
      "description": "MySQL username."
    },
    "password_env_var": {
      "type": "string",
      "description": "Name of the environment variable holding the MySQL password.",
      "ui:widget": "password"
    },
    "ssl_disabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether to disable SSL for the connection."
    }
  },
  "required": [
    "host",
    "database",
    "username",
    "password_env_var"
  ],
  "description": "Register a MySQL resource for relational database access",
  "tags": [
    "resource",
    "mysql",
    "database",
    "sql"
  ],
  "icon": "si:mysql",
  "name": "MySQL Resource",
  "attributes": {
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "required": false,
      "default": "mysql_resource"
    },
    "host": {
      "type": "string",
      "label": "Host",
      "required": true
    },
    "port": {
      "type": "integer",
      "label": "Port",
      "required": false,
      "default": 3306
    },
    "database": {
      "type": "string",
      "label": "Database",
      "required": true
    },
    "username": {
      "type": "string",
      "label": "Username",
      "required": true
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "required": false
    },
    "ssl_disabled": {
      "type": "boolean",
      "label": "Ssl Disabled",
      "required": false,
      "default": false
    }
  }
}
