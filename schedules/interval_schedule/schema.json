{
  "component_type": "dagster_component_templates.IntervalScheduleComponent",
  "description": "Run an asset selection at a fixed interval (every N minutes / hours / days).",
  "category": "infrastructure",
  "icon": "Clock",
  "x-dagster-io": {
    "outputs": {
      "type": "Schedule",
      "description": "ScheduleDefinition + asset job"
    }
  },
  "attributes": {
    "schedule_name": {
      "type": "string",
      "label": "Schedule Name",
      "required": true
    },
    "every": {
      "type": "string",
      "label": "Every",
      "required": true
    },
    "asset_keys": {
      "type": "array",
      "label": "Asset Keys",
      "required": true,
      "items": {
        "type": "string"
      }
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "required": false
    },
    "execution_timezone": {
      "type": "string",
      "label": "Execution Timezone",
      "required": true
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "required": true,
      "enum": [
        "STOPPED",
        "RUNNING"
      ],
      "ui:widget": "select"
    },
    "tags": {
      "type": "object",
      "label": "Tags",
      "required": false
    }
  },
  "tags": [
    "infrastructure",
    "schedule",
    "interval",
    "orchestration"
  ],
  "name": "IntervalSchedule"
}
