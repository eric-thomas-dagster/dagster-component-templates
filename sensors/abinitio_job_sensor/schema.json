{
  "component_type": "dagster_component_templates.AbInitioResource",
  "description": "Resource for connecting to Ab Initio EME REST API.",
  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "eme_url": {
      "type": "string",
      "label": "Eme Url",
      "description": "Eme Url",
      "required": true
    },
    "username": {
      "type": "string",
      "label": "Username",
      "description": "Ab Initio EME username",
      "required": true
    },
    "password": {
      "type": "string",
      "label": "Password",
      "description": "Ab Initio EME password",
      "required": true,
      "ui:widget": "password"
    },
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "job_path": {
      "type": "string",
      "label": "Job Path",
      "description": "Job Path",
      "required": true
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Dagster job to trigger when Ab Initio run completes",
      "required": true
    },
    "eme_url_env_var": {
      "type": "string",
      "label": "Eme Url Env Var",
      "description": "Env var with Ab Initio EME base URL",
      "required": false,
      "default": null
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "description": "Env var with Ab Initio EME username",
      "required": false,
      "default": null
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var with Ab Initio EME password",
      "required": false,
      "default": null,
      "ui:widget": "env_var"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Key of an AbInitioResource. When set, env var fields are ignored.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Seconds between polls",
      "required": false,
      "default": 120
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "running or stopped",
      "required": false,
      "default": "running"
    }
  },
  "tags": [
    "sensor",
    "abinitio",
    "job"
  ],
  "name": "Abinitio Job Sensor"
}