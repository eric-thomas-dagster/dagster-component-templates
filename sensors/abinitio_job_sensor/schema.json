{
  "type": "dagster_component_templates.AbInitioJobSensorComponent",
  "name": "Ab Initio Job Sensor",
  "category": "sensors",
  "description": "Trigger a Dagster job when an Ab Initio EME job run completes",
  "attributes": {
    "sensor_name": {"type": "string", "required": true},
    "job_path": {"type": "string", "required": true},
    "job_name": {"type": "string", "required": true},
    "eme_url_env_var": {"type": "string", "required": false},
    "username_env_var": {"type": "string", "required": false},
    "password_env_var": {"type": "string", "required": false},
    "resource_key": {"type": "string", "required": false},
    "minimum_interval_seconds": {"type": "integer", "default": 120},
    "default_status": {"type": "string", "default": "running", "enum": ["running", "stopped"]}
  },
  "dependencies": {"pip": ["requests>=2.28.0"]},
  "tags": ["sensors", "abinitio", "etl", "enterprise", "automation"]
}
