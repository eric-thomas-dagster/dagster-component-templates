{
  "component_type": "dagster_component_templates.AirbyteSyncSensorComponent",
  "description": "Trigger a job when an Airbyte connection sync completes.",
  "category": "sensor",
  "icon": "si:airbyte",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "connection_id": {
      "type": "string",
      "label": "Connection Id",
      "description": "Airbyte connection UUID",
      "required": true
    },
    "airbyte_url": {
      "type": "string",
      "label": "Airbyte Url",
      "description": "Airbyte server URL",
      "required": false,
      "default": "http://localhost:8000"
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "description": "Username Env Var",
      "required": false,
      "default": null
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Password Env Var",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Job to trigger when sync completes",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Seconds between polls",
      "required": false,
      "default": 60
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "running or stopped",
      "required": false,
      "default": "running"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "sensor",
    "airbyte",
    "sync"
  ],
  "connectors": {
    "left": false,
    "right": false
  }
}
