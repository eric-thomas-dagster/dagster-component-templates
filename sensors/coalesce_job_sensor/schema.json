{
  "component_type": "dagster_component_templates.CoalesceJobSensorComponent",
  "description": "Trigger a Dagster job when a Coalesce job run completes.",
  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "environment_id": {
      "type": "string",
      "label": "Environment Id",
      "description": "Coalesce environment ID",
      "required": true
    },
    "job_id": {
      "type": "string",
      "label": "Job Id",
      "description": "Coalesce job ID to monitor",
      "required": true
    },
    "api_token_env_var": {
      "type": "string",
      "label": "Api Token Env Var",
      "description": "Env var containing the Coalesce API token",
      "required": true,
      "ui:widget": "password"
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Dagster job to trigger when Coalesce run succeeds",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Seconds between polls",
      "required": false,
      "default": 60
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "running or stopped",
      "required": false,
      "default": "running"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "sensor",
    "coalesce",
    "job"
  ],
  "connectors": {
    "left": false,
    "right": false
  }
}
