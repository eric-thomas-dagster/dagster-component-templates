{
  "component_type": "dagster_component_templates.DbtCloudJobSensorComponent",
  "description": "Trigger a Dagster job when a dbt Cloud job run completes.",
  "category": "sensor",
  "icon": "si:dbt",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "account_id": {
      "type": "integer",
      "label": "Account Id",
      "description": "dbt Cloud account ID",
      "required": true
    },
    "job_id": {
      "type": "integer",
      "label": "Job Id",
      "description": "dbt Cloud job ID to monitor",
      "required": true
    },
    "api_token_env_var": {
      "type": "string",
      "label": "Api Token Env Var",
      "description": "Env var containing the dbt Cloud API token",
      "required": true,
      "ui:widget": "password"
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Dagster job to trigger when dbt run completes",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Seconds between polls",
      "required": false,
      "default": 60
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "running or stopped",
      "required": false,
      "default": "running"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "sensor",
    "dbt",
    "cloud",
    "job"
  ]
}