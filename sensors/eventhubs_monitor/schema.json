  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique name for this sensor",
      "required": true
    },
    "eventhub_name": {
      "type": "string",
      "label": "Eventhub Name",
      "description": "Name of the Event Hub to monitor",
      "required": true
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Name of the job to trigger when events are detected",
      "required": true
    },
    "fully_qualified_namespace": {
      "type": "string",
      "label": "Fully Qualified Namespace",
      "description": "Event Hubs namespace hostname (e.g., ",
      "required": false,
      "default": null
    },
    "connection_string_env_var": {
      "type": "string",
