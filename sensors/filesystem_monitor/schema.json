{
  "component_type": "dagster_component_templates.FilesystemMonitorSensorComponent",
  "description": "Component for monitoring filesystem directories for new files.",
  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique name for this sensor",
      "required": true
    },
    "directory_path": {
      "type": "string",
      "label": "Directory Path",
      "description": "Path to the directory to monitor for new files",
      "required": true
    },
    "file_pattern": {
      "type": "string",
      "label": "File Pattern",
      "description": "Regex pattern to match files (e.g., ",
      "required": false,
      "default": ".*"
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Name of the job to trigger when files are detected",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Minimum Interval Seconds",
      "required": false,
      "default": 30
    },
    "recursive": {
      "type": "boolean",
      "label": "Recursive",
      "description": "Whether to recursively search subdirectories",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "Default Status",
      "required": false,
      "default": "running"
    }
  },
  "tags": [
    "sensor",
    "filesystem",
    "monitor"
  ],
  "name": "Filesystem Monitor"
}