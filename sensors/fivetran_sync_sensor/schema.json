{
  "type": "dagster_component_templates.FivetranSyncSensorComponent",
  "name": "Fivetran Sync Sensor",
  "category": "sensors",
  "description": "Trigger a Dagster job when a Fivetran connector sync completes",
  "icon": "Activity",
  "attributes": {
    "sensor_name": {
      "type": "string",
      "required": true,
      "label": "Sensor Name",
      "placeholder": "fivetran_orders_done"
    },
    "connector_id": {
      "type": "string",
      "required": true,
      "label": "Connector ID",
      "placeholder": "abc123xyz"
    },
    "api_key_env_var": {
      "type": "string",
      "required": true,
      "label": "API Key Env Var",
      "placeholder": "FIVETRAN_API_KEY"
    },
    "api_secret_env_var": {
      "type": "string",
      "required": true,
      "label": "API Secret Env Var",
      "placeholder": "FIVETRAN_API_SECRET"
    },
    "job_name": {
      "type": "string",
      "required": true,
      "label": "Job Name",
      "placeholder": "process_synced_data_job"
    },
    "minimum_interval_seconds": {
      "type": "number",
      "required": false,
      "label": "Poll Interval (s)",
      "default": 60
    },
    "default_status": {
      "type": "string",
      "required": false,
      "label": "Default Status",
      "default": "running",
      "enum": [
        "running",
        "stopped"
      ]
    },
    "resource_key": {
      "type": "string",
      "required": false,
      "label": "Resource Key"
    }
  },
  "dependencies": {
    "pip": [
      "requests>=2.28.0"
    ]
  },
  "tags": [
    "sensors",
    "fivetran",
    "integration",
    "etl",
    "automation"
  ]
}
