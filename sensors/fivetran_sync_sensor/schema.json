{
  "component_type": "dagster_component_templates.FivetranSyncSensorComponent",
  "description": "Trigger a job when a Fivetran connector sync completes.",
  "category": "sensor",
  "icon": "si:fivetran",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "connector_id": {
      "type": "string",
      "label": "Connector Id",
      "description": "Fivetran connector ID",
      "required": true
    },
    "api_key_env_var": {
      "type": "string",
      "label": "Api Key Env Var",
      "description": "Env var containing the Fivetran API key",
      "required": true
    },
    "api_secret_env_var": {
      "type": "string",
      "label": "Api Secret Env Var",
      "description": "Env var containing the Fivetran API secret",
      "required": true,
      "ui:widget": "password"
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Job to trigger when sync completes",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Seconds between polls",
      "required": false,
      "default": 60
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "running or stopped",
      "required": false,
      "default": "running"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "sensor",
    "fivetran",
    "sync"
  ],
  "connectors": {
    "left": false,
    "right": false
  }
}
