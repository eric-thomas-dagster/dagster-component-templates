{
  "component_type": "dagster_component_templates.GCSMonitorSensorComponent",
  "description": "Component for monitoring a Google Cloud Storage bucket prefix for new objects.",
  "category": "sensor",
  "icon": "si:googlecloud",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique name for this sensor",
      "required": true
    },
    "bucket_name": {
      "type": "string",
      "label": "Bucket Name",
      "description": "Name of the GCS bucket to monitor",
      "required": true
    },
    "prefix": {
      "type": "string",
      "label": "Prefix",
      "description": "Object prefix to scope monitoring (e.g., ",
      "required": false,
      "default": ""
    },
    "blob_pattern": {
      "type": "string",
      "label": "Blob Pattern",
      "description": "Regex pattern to match object names relative to the prefix (e.g., ",
      "required": false,
      "default": ".*"
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Name of the job to trigger when objects are detected",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Minimum Interval Seconds",
      "required": false,
      "default": 30
    },
    "project": {
      "type": "string",
      "label": "Project",
      "description": "GCP project ID. Uses the project from ADC if not set.",
      "required": false,
      "default": null
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key providing a pre-configured client. ",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "Default Status",
      "required": false,
      "default": "running"
    }
  },
  "tags": [
    "sensor",
    "gcs",
    "monitor"
  ]
}