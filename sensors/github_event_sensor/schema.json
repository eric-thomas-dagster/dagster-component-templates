{
  "component_type": "dagster_component_templates.GithubEventSensorComponent",
  "description": "Trigger a run when a GitHub repo has new events (PRs opened/merged, pushes, issues).",
  "category": "sensor",
  "icon": "Bell",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "RunRequest per new event"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "required": true
    },
    "asset_keys": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Asset Keys",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "default": 60,
      "required": false
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "default": "STOPPED",
      "enum": [
        "RUNNING",
        "STOPPED"
      ],
      "required": false
    },
    "repo": {
      "type": "string",
      "label": "Repo",
      "required": true
    },
    "token_env_var": {
      "type": "string",
      "label": "Token Env Var",
      "required": true
    },
    "event_types": {
      "type": "array",
      "label": "Event Types",
      "required": true
    }
  },
  "tags": [
    "sensor",
    "github",
    "vcs",
    "ci"
  ],
  "name": "GithubEventSensor"
}
