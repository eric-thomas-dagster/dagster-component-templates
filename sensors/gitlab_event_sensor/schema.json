{
  "component_type": "dagster_component_templates.GitlabEventSensorComponent",
  "description": "Trigger a run when a GitLab project has new events (push, merge, issue, comment).",
  "category": "sensor",
  "icon": "Bell",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "RunRequest per new event"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "required": true
    },
    "asset_keys": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Asset Keys",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "default": 60,
      "required": false
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "default": "STOPPED",
      "enum": [
        "RUNNING",
        "STOPPED"
      ],
      "required": false
    },
    "project_id": {
      "type": "string",
      "label": "Project Id",
      "required": true
    },
    "token_env_var": {
      "type": "string",
      "label": "Token Env Var",
      "required": true
    },
    "base_url": {
      "type": "string",
      "label": "Base Url",
      "required": true
    },
    "actions": {
      "type": "array",
      "label": "Actions",
      "required": true
    }
  },
  "tags": [
    "sensor",
    "gitlab",
    "vcs",
    "ci"
  ],
  "name": "GitlabEventSensor"
}
