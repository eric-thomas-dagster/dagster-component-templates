{
  "component_type": "dagster_component_templates.LineageToAlationComponent",
  "description": "Sensor that exports the Dagster asset lineage graph to Alation Data Catalog. Hashes graph and only pushes on change.",
  "category": "sensor",
  "icon": "ArrowRightLeft",
  "x-dagster-io": {"supports_partitions": false},
  "attributes": {
    "catalog_url": {"type": "string", "label": "Catalog URL", "required": false, "default": "https://alation.example.com"},
    "api_token_env": {"type": "string", "label": "API Token Env Var", "required": false, "default": "ALATION_API_TOKEN"},
    "scope": {"type": "string", "label": "Scope", "required": false, "default": "code_location", "enum": ["code_location", "deployment"]},
    "dagster_plus_token_env": {"type": "string", "label": "Dagster+ Token Env Var", "required": false, "default": "DAGSTER_PLUS_TOKEN"},
    "sensor_interval_seconds": {"type": "integer", "label": "Sensor Interval", "required": false, "default": 3600},
    "sensor_name": {"type": "string", "label": "Sensor Name", "required": false, "default": "lineage_to_alation_sync"},
    "sensor_default_status": {"type": "string", "label": "Sensor Default Status", "required": false, "default": "STOPPED", "enum": ["STOPPED", "RUNNING"]},
    "demo_mode": {"type": "boolean", "label": "Demo Mode", "required": false, "default": false, "description": "Write JSON locally instead of POSTing"},
    "demo_export_path": {"type": "string", "label": "Demo Export Path", "required": false, "default": "data/exports/lineage_to_alation.json"},
    "platform_name": {"type": "string", "label": "Platform Name", "required": false, "default": "dagster"},
    "platform_display_name": {"type": "string", "label": "Platform Display Name", "required": false, "default": "Dagster"},
    "deployment_name": {"type": "string", "label": "Deployment Name", "required": false, "default": ""},
    "dagster_ui_url": {"type": "string", "label": "Dagster UI URL", "required": false, "default": ""},
    "organization": {"type": "string", "label": "Organization", "required": false, "default": ""},
    "code_location_name": {"type": "string", "label": "Code Location Name", "required": false, "default": ""}
  }
}
