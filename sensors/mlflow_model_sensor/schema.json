{
  "component_type": "dagster_component_templates.MLflowModelSensor",
  "description": "Component that fires a RunRequest when an MLflow model transitions to a",
  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique name for this sensor.",
      "required": true
    },
    "tracking_uri_env_var": {
      "type": "string",
      "label": "Tracking Uri Env Var",
      "description": "Tracking Uri Env Var",
      "required": true
    },
    "model_name": {
      "type": "string",
      "label": "Model Name",
      "description": "Registered model name to watch in the MLflow Model Registry.",
      "required": true
    },
    "target_stage": {
      "type": "string",
      "label": "Target Stage",
      "description": "Target Stage",
      "required": false,
      "default": "Production"
    },
    "target_job": {
      "type": "string",
      "label": "Target Job",
      "description": "Name of the Dagster job to trigger when a new version is detected.",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Minimum Interval Seconds",
      "required": false,
      "default": 60
    },
    "run_config": {
      "type": "object",
      "label": "Run Config",
      "description": "Run Config",
      "required": false,
      "default": null,
      "ui:widget": "key-value"
    }
  },
  "tags": [
    "sensor",
    "mlflow",
    "model"
  ]
}