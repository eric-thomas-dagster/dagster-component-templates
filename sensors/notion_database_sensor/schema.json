{
  "component_type": "dagster_component_templates.NotionDatabaseSensorComponent",
  "description": "Trigger a run when a Notion database has new or updated rows.",
  "category": "sensor",
  "icon": "Bell",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "RunRequest per new event"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "required": true
    },
    "asset_keys": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Asset Keys",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "default": 60,
      "required": false
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "default": "STOPPED",
      "enum": [
        "RUNNING",
        "STOPPED"
      ],
      "required": false
    },
    "database_id": {
      "type": "string",
      "label": "Database Id",
      "required": true
    },
    "api_key_env_var": {
      "type": "string",
      "label": "Api Key Env Var",
      "required": true
    },
    "page_size": {
      "type": "integer",
      "label": "Page Size",
      "required": true
    }
  },
  "tags": [
    "sensor",
    "notion",
    "knowledge-base"
  ],
  "name": "NotionDatabaseSensor"
}
