{
  "component_type": "dagster_component_templates.PubSubMonitorSensorComponent",
  "description": "Component for pulling messages from a Google Cloud Pub/Sub subscription.",
  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique name for this sensor",
      "required": true
    },
    "project": {
      "type": "string",
      "label": "Project",
      "description": "GCP project ID",
      "required": true
    },
    "subscription": {
      "type": "string",
      "label": "Subscription",
      "description": "Subscription",
      "required": true,
      "ui:widget": "code"
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Name of the job to trigger when messages are received",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Minimum Interval Seconds",
      "required": false,
      "default": 30
    },
    "max_messages_per_pull": {
      "type": "integer",
      "label": "Max Messages Per Pull",
      "description": "Maximum number of messages to pull per evaluation",
      "required": false,
      "default": 100
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key providing a pre-configured client. ",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "Default Status",
      "required": false,
      "default": "running"
    }
  },
  "tags": [
    "sensor",
    "pubsub",
    "monitor"
  ]
}