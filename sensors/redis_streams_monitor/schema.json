{
  "component_type": "dagster_component_templates.RedisStreamsMonitorSensorComponent",
  "description": "Component for monitoring a Redis Stream for new entries.",
  "category": "sensor",
  "icon": "si:redis",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique name for this sensor",
      "required": true
    },
    "stream_name": {
      "type": "string",
      "label": "Stream Name",
      "description": "Name of the Redis Stream to monitor (e.g., ",
      "required": true
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Name of the job to trigger when entries are detected",
      "required": true
    },
    "host": {
      "type": "string",
      "label": "Host",
      "description": "Redis host",
      "required": false,
      "default": "localhost"
    },
    "port": {
      "type": "integer",
      "label": "Port",
      "description": "Redis port",
      "required": false,
      "default": 6379
    },
    "db": {
      "type": "integer",
      "label": "Db",
      "description": "Redis database index",
      "required": false,
      "default": 0
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Name of the environment variable containing the Redis password",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "use_tls": {
      "type": "boolean",
      "label": "Use Tls",
      "description": "Whether to use TLS for the Redis connection",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "max_entries_per_poll": {
      "type": "integer",
      "label": "Max Entries Per Poll",
      "description": "Maximum number of stream entries to read per evaluation",
      "required": false,
      "default": 100
    },
    "start_from_beginning": {
      "type": "boolean",
      "label": "Start From Beginning",
      "description": "On first run, read from the beginning of the stream. ",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Minimum Interval Seconds",
      "required": false,
      "default": 30
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key providing a pre-configured client. ",
      "required": false,
      "default": null
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "Default Status",
      "required": false,
      "default": "running"
    }
  },
  "tags": [
    "sensor",
    "redis",
    "streams",
    "monitor"
  ],
  "connectors": {
    "left": false,
    "right": false
  }
}
