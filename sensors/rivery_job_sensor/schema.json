{
  "component_type": "dagster_component_templates.RiveryJobSensorComponent",
  "description": "Trigger a Dagster job when a Rivery river run completes.",
  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "river_id": {
      "type": "string",
      "label": "River Id",
      "description": "River Id",
      "required": true
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Dagster job to trigger when river run completes",
      "required": true
    },
    "api_token_env_var": {
      "type": "string",
      "label": "Api Token Env Var",
      "description": "Env var with Rivery API token",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "region": {
      "type": "string",
      "label": "Region",
      "description": "Region",
      "required": false,
      "default": "us2"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Key of a RiveryResource",
      "required": false,
      "default": null
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Seconds between polls",
      "required": false,
      "default": 60
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "running or stopped",
      "required": false,
      "default": "running"
    }
  },
  "tags": [
    "sensor",
    "rivery",
    "job"
  ]
}