{
  "component_type": "dagster_component_templates.ServiceNowSensorComponent",
  "description": "Trigger a job when ServiceNow records match a target state.",
  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "instance_env_var": {
      "type": "string",
      "label": "Instance Env Var",
      "description": "Instance Env Var",
      "required": true
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "description": "Env var with ServiceNow username",
      "required": true
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var with ServiceNow password",
      "required": true,
      "ui:widget": "password"
    },
    "table": {
      "type": "string",
      "label": "Table",
      "description": "Table",
      "required": true
    },
    "sysparm_query": {
      "type": "string",
      "label": "Sysparm Query",
      "description": "ServiceNow encoded query string to filter records",
      "required": true,
      "ui:widget": "code"
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Job to trigger when matching records are found",
      "required": true
    },
    "sysparm_fields": {
      "type": "string",
      "label": "Sysparm Fields",
      "description": "Comma-separated fields to return",
      "required": false,
      "default": "sys_id"
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Seconds between polls",
      "required": false,
      "default": 120
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "running or stopped",
      "required": false,
      "default": "running"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null,
      "ui:widget": "resource-picker"
    }
  },
  "tags": [
    "sensor",
    "servicenow"
  ]
}