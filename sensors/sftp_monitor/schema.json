{
  "type": "dagster_component_templates.SftpMonitorSensorComponent",
  "name": "SFTP Monitor",
  "category": "sensors",
  "description": "Monitor an SFTP directory for new files \u2014 essential for regulated industry file-based integrations",
  "icon": "Activity",
  "attributes": {
    "sensor_name": {
      "type": "string",
      "required": true,
      "label": "Sensor Name",
      "placeholder": "sftp_drop_zone_monitor"
    },
    "host": {
      "type": "string",
      "required": true,
      "label": "Host",
      "placeholder": "sftp.partner.com"
    },
    "port": {
      "type": "number",
      "required": false,
      "label": "Port",
      "default": 22
    },
    "username_env_var": {
      "type": "string",
      "required": true,
      "label": "Username Env Var",
      "placeholder": "SFTP_USERNAME"
    },
    "password_env_var": {
      "type": "string",
      "required": false,
      "label": "Password Env Var"
    },
    "private_key_env_var": {
      "type": "string",
      "required": false,
      "label": "Private Key Path Env Var"
    },
    "remote_path": {
      "type": "string",
      "required": true,
      "label": "Remote Path",
      "placeholder": "/incoming/orders"
    },
    "file_pattern": {
      "type": "string",
      "required": false,
      "label": "File Pattern",
      "default": "*",
      "placeholder": "*.csv"
    },
    "job_name": {
      "type": "string",
      "required": true,
      "label": "Job Name"
    },
    "minimum_interval_seconds": {
      "type": "number",
      "required": false,
      "label": "Poll Interval (s)",
      "default": 300
    },
    "default_status": {
      "type": "string",
      "required": false,
      "label": "Default Status",
      "default": "running",
      "enum": [
        "running",
        "stopped"
      ]
    },
    "resource_key": {
      "type": "string",
      "required": false,
      "label": "Resource Key"
    }
  },
  "dependencies": {
    "pip": [
      "paramiko>=3.0.0"
    ]
  },
  "tags": [
    "sensors",
    "sftp",
    "ssh",
    "files",
    "finance",
    "healthcare",
    "regulated",
    "automation"
  ]
}
