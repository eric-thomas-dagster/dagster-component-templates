{
  "component_type": "dagster_component_templates.SftpMonitorSensorComponent",
  "description": "Monitor an SFTP directory for new files.",
  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "host": {
      "type": "string",
      "label": "Host",
      "description": "SFTP host",
      "required": true
    },
    "port": {
      "type": "integer",
      "label": "Port",
      "description": "SFTP port",
      "required": false,
      "default": 22
    },
    "username_env_var": {
      "type": "string",
      "label": "Username Env Var",
      "description": "Env var with SFTP username",
      "required": true
    },
    "password_env_var": {
      "type": "string",
      "label": "Password Env Var",
      "description": "Env var with SFTP password",
      "required": false,
      "default": null,
      "ui:widget": "password"
    },
    "private_key_env_var": {
      "type": "string",
      "label": "Private Key Env Var",
      "description": "Env var with path to SSH private key file",
      "required": false,
      "default": null
    },
    "remote_path": {
      "type": "string",
      "label": "Remote Path",
      "description": "Remote directory path to monitor",
      "required": true
    },
    "file_pattern": {
      "type": "string",
      "label": "File Pattern",
      "description": "Glob-style filename filter (e.g. ",
      "required": false,
      "default": "*"
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Job to trigger when new files are detected",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Seconds between polls",
      "required": false,
      "default": 300
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "running or stopped",
      "required": false,
      "default": "running"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "sensor",
    "sftp",
    "monitor"
  ]
}