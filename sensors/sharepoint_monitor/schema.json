{
  "component_type": "dagster_component_templates.SharePointMonitorSensorComponent",
  "description": "Monitor a SharePoint document library for new or modified files.",
  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique sensor name",
      "required": true
    },
    "site_url": {
      "type": "string",
      "label": "Site Url",
      "description": "SharePoint site URL",
      "required": true
    },
    "library_name": {
      "type": "string",
      "label": "Library Name",
      "description": "Document library name (e.g. ",
      "required": true
    },
    "tenant_id_env_var": {
      "type": "string",
      "label": "Tenant Id Env Var",
      "description": "Env var with Azure tenant ID",
      "required": true
    },
    "client_id_env_var": {
      "type": "string",
      "label": "Client Id Env Var",
      "description": "Env var with Azure app client ID",
      "required": true
    },
    "client_secret_env_var": {
      "type": "string",
      "label": "Client Secret Env Var",
      "description": "Env var with Azure app client secret",
      "required": true,
      "ui:widget": "password"
    },
    "folder_path": {
      "type": "string",
      "label": "Folder Path",
      "description": "Optional subfolder path within the library",
      "required": false,
      "default": ""
    },
    "file_extension_filter": {
      "type": "string",
      "label": "File Extension Filter",
      "description": "Filter by extension e.g. ",
      "required": false,
      "default": ""
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Job to trigger when new/modified files are detected",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Seconds between polls",
      "required": false,
      "default": 300
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "running or stopped",
      "required": false,
      "default": "running"
    },
    "resource_key": {
      "type": "string",
      "label": "Resource Key",
      "description": "Optional Dagster resource key.",
      "required": false,
      "default": null
    }
  },
  "tags": [
    "sensor",
    "sharepoint",
    "monitor"
  ]
}