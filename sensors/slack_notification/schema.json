{
  "component_type": "dagster_component_templates.SlackNotificationSensorComponent",
  "description": "Monitor Slack channels for new messages and trigger jobs.",
  "category": "sensor",
  "icon": "Radar",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Name of the sensor",
      "required": true
    },
    "slack_token": {
      "type": "string",
      "label": "Slack Token",
      "description": "Slack Token",
      "required": true,
      "ui:widget": "password"
    },
    "channel_id": {
      "type": "string",
      "label": "Channel Id",
      "description": "Slack channel ID to monitor",
      "required": true
    },
    "job_name": {
      "type": "string",
      "label": "Job Name",
      "description": "Name of the job to trigger",
      "required": true
    },
    "keyword_filter": {
      "type": "string",
      "label": "Keyword Filter",
      "description": "Only trigger on messages containing this keyword",
      "required": false,
      "default": ""
    },
    "user_filter": {
      "type": "string",
      "label": "User Filter",
      "description": "Only trigger on messages from this user ID",
      "required": false,
      "default": ""
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "How often to check for new messages",
      "required": false,
      "default": 60
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "description": "Default Status",
      "required": false,
      "default": "RUNNING"
    }
  },
  "tags": [
    "sensor",
    "slack",
    "notification"
  ]
}