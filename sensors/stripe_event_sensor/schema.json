{
  "component_type": "dagster_component_templates.StripeEventSensorComponent",
  "description": "Trigger a run when Stripe emits new events (charges, subscriptions, invoices, etc).",
  "category": "sensor",
  "icon": "Bell",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "RunRequest per new event"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "required": true
    },
    "asset_keys": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Asset Keys",
      "required": true
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "default": 60,
      "required": false
    },
    "default_status": {
      "type": "string",
      "label": "Default Status",
      "default": "STOPPED",
      "enum": [
        "RUNNING",
        "STOPPED"
      ],
      "required": false
    },
    "api_key_env_var": {
      "type": "string",
      "label": "Api Key Env Var",
      "required": true
    },
    "event_types": {
      "type": "array",
      "label": "Event Types",
      "required": true
    },
    "limit_per_tick": {
      "type": "integer",
      "label": "Limit Per Tick",
      "required": true
    }
  },
  "tags": [
    "sensor",
    "stripe",
    "billing"
  ],
  "name": "StripeEventSensor"
}
