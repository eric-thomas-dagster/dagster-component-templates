{
  "component_type": "dagster_community_components.TM1ProcessStatusSensorComponent",
  "description": "Poll a TM1 TI process's execution status via the TM1 REST API; trigger a Dagster job on transitions into a target status set (CompletedSuccessfully / HasMinorErrors / Aborted / QuitCalled). Event-driven pattern for chaining downstream work off process completion or failure. Cursor-deduped so downstream job fires once per execution.",
  "category": "sensor",
  "icon": "Bolt",
  "attributes": {
    "sensor_name": {"type": "string", "label": "Sensor Name", "required": true, "description": "Unique sensor name."},
    "process_name": {"type": "string", "label": "TI Process Name", "required": true, "description": "TM1 process to watch."},
    "target_statuses": {"type": "array", "label": "Target Statuses", "required": false, "default": ["CompletedSuccessfully"], "description": "Statuses that should trigger the job."},
    "job_name": {"type": "string", "label": "Job Name", "required": true, "description": "Job to trigger."},
    "resource_key": {"type": "string", "label": "Resource Key", "required": false, "default": "tm1_resource", "description": "Resource key to look up."},
    "minimum_interval_seconds": {"type": "integer", "label": "Poll Interval (s)", "required": false, "default": 60, "description": "Seconds between polls."},
    "default_status": {"type": "string", "label": "Default Sensor Status", "required": false, "default": "running", "description": "running | stopped", "ui:widget": "select", "enum": ["running", "stopped"]}
  }
}
