{
  "component_type": "dagster_component_templates.TwilioNotificationSensor",
  "description": "Component that sends SMS or WhatsApp notifications when Dagster assets",
  "category": "sensor",
  "icon": "si:twilio",
  "x-dagster-io": {
    "outputs": {
      "type": "RunRequest",
      "description": "Sensor run requests"
    }
  },
  "attributes": {
    "sensor_name": {
      "type": "string",
      "label": "Sensor Name",
      "description": "Unique name for this sensor.",
      "required": true
    },
    "account_sid_env_var": {
      "type": "string",
      "label": "Account Sid Env Var",
      "description": "Account Sid Env Var",
      "required": true
    },
    "auth_token_env_var": {
      "type": "string",
      "label": "Auth Token Env Var",
      "description": "Auth Token Env Var",
      "required": true,
      "ui:widget": "password"
    },
    "from_number": {
      "type": "string",
      "label": "From Number",
      "description": "From Number",
      "required": true
    },
    "to_numbers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "To Numbers",
      "description": "List of recipient phone numbers in E.164 format (e.g., ",
      "required": true,
      "ui:widget": "list"
    },
    "channel": {
      "type": "string",
      "label": "Channel",
      "description": "Channel",
      "required": false,
      "default": "sms"
    },
    "message_template": {
      "type": "string",
      "label": "Message Template",
      "description": "Message Template",
      "required": false,
      "default": "Dagster alert: {asset_key} {event_type} at {timestamp}",
      "ui:widget": "textarea"
    },
    "monitored_assets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "label": "Monitored Assets",
      "description": "Monitored Assets",
      "required": false,
      "default": null,
      "ui:widget": "list"
    },
    "on_failure": {
      "type": "boolean",
      "label": "On Failure",
      "description": "Send a notification when an asset materialization fails.",
      "required": false,
      "default": true,
      "ui:widget": "checkbox"
    },
    "on_success": {
      "type": "boolean",
      "label": "On Success",
      "description": "Send a notification when an asset materialization succeeds.",
      "required": false,
      "default": false,
      "ui:widget": "checkbox"
    },
    "minimum_interval_seconds": {
      "type": "integer",
      "label": "Minimum Interval Seconds",
      "description": "Minimum Interval Seconds",
      "required": false,
      "default": 30
    }
  },
  "tags": [
    "sensor",
    "twilio",
    "notification"
  ],
  "connectors": {
    "left": false,
    "right": false
  }
}
