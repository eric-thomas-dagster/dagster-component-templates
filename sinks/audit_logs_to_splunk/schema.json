{
  "component_type": "dagster_component_templates.AuditLogsToSplunkComponent",
  "description": "Ship audit-log DataFrame to Splunk via the HTTP Event Collector (HEC).",
  "category": "security",
  "icon": "Shield",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream DataFrame asset key \u2014 events to ship",
      "required": true
    },
    "hec_url": {
      "type": "string",
      "label": "Hec Url",
      "description": "Splunk HEC endpoint (e.g. 'https://splunk.acme.com:8088/services/collector')",
      "required": true
    },
    "hec_token_env": {
      "type": "string",
      "label": "Hec Token Env",
      "description": "Env var with HEC token",
      "required": false,
      "default": "SPLUNK_HEC_TOKEN"
    },
    "index": {
      "type": "string",
      "label": "Index",
      "description": "Splunk index (overrides token's default)",
      "required": false
    },
    "sourcetype": {
      "type": "string",
      "label": "Sourcetype",
      "description": "sourcetype",
      "required": false
    },
    "source": {
      "type": "string",
      "label": "Source",
      "description": "source",
      "required": false
    },
    "host": {
      "type": "string",
      "label": "Host",
      "description": "host field",
      "required": false
    },
    "batch_size": {
      "type": "integer",
      "label": "Batch Size",
      "description": "Events per HTTP POST",
      "required": false,
      "default": 500
    },
    "verify_ssl": {
      "type": "boolean",
      "label": "Verify Ssl",
      "description": "Verify TLS cert (set false for self-signed dev splunk)",
      "required": false,
      "default": true
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Dagster asset group",
      "required": false,
      "default": "security_sink"
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "description": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "description": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "description": "Retry Policy Backoff",
      "required": false,
      "default": "exponential"
    }
  }
}