{
  "component_type": "dagster_component_templates.AuditLogsToSumoLogicComponent",
  "description": "Ship audit-log DataFrame to Sumo Logic via an HTTP Hosted Collector.",
  "category": "security",
  "icon": "Shield",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream DataFrame asset key \u2014 events to ship",
      "required": true
    },
    "collector_url_env": {
      "type": "string",
      "label": "Collector Url Env",
      "description": "Env var with the full HTTP Source URL",
      "required": false,
      "default": "SUMO_HTTP_URL"
    },
    "source_category": {
      "type": "string",
      "label": "Source Category",
      "description": "Override X-Sumo-Category",
      "required": false
    },
    "source_name": {
      "type": "string",
      "label": "Source Name",
      "description": "Override X-Sumo-Name",
      "required": false
    },
    "source_host": {
      "type": "string",
      "label": "Source Host",
      "description": "Override X-Sumo-Host",
      "required": false
    },
    "batch_size": {
      "type": "integer",
      "label": "Batch Size",
      "description": "Batch Size",
      "required": false,
      "default": 1000
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Dagster asset group",
      "required": false,
      "default": "security_sink"
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "retry_policy_max_retries": {
      "type": "integer",
      "label": "Retry Policy Max Retries",
      "description": "Retry Policy Max Retries",
      "required": false
    },
    "retry_policy_delay_seconds": {
      "type": "integer",
      "label": "Retry Policy Delay Seconds",
      "description": "Retry Policy Delay Seconds",
      "required": false
    },
    "retry_policy_backoff": {
      "type": "string",
      "label": "Retry Policy Backoff",
      "description": "Retry Policy Backoff",
      "required": false,
      "default": "exponential",
      "enum": [
        "exponential",
        "linear",
        "fixed"
      ],
      "ui:widget": "select"
    }
  }
}
