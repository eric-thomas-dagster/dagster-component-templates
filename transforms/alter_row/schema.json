{
  "component_type": "dagster_component_templates.AlterRowComponent",
  "description": "Mark each row with a CDC operation (insert / update / delete / upsert) based on conditions \u2014 same semantics as ADF Alter Row.",
  "category": "transformation",
  "icon": "ArrowsRightLeft",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream DataFrame asset key",
      "required": true
    },
    "rules": {
      "type": "array",
      "label": "Rules",
      "description": "Ordered list of {operation, condition} \u2014 first matching rule wins. operation: insert | update | delete | upsert",
      "required": true
    },
    "default_operation": {
      "type": "string",
      "label": "Default Operation",
      "description": "Operation when no rule matches",
      "required": false,
      "default": "insert"
    },
    "operation_column": {
      "type": "string",
      "label": "Operation Column",
      "description": "Output column holding the operation marker",
      "required": false,
      "default": "cdc_op",
      "x-dagster-widget": "column"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Group Name",
      "required": false,
      "default": "transforms"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Include Preview Metadata",
      "required": false,
      "default": true
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Preview Rows",
      "required": false,
      "default": 20
    }
  }
}
