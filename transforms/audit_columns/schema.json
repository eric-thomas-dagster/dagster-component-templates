{
  "component_type": "dagster_component_templates.AuditColumnsComponent",
  "description": "Add system-audit columns to every row \u2014 run_id, dagster_run_id, asset_key, materialization_time, optional username/git_sha.",
  "category": "transformation",
  "icon": "ArrowsRightLeft",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream DataFrame asset key",
      "required": true
    },
    "include_run_id": {
      "type": "boolean",
      "label": "Include Run Id",
      "description": "Include Run Id",
      "required": false,
      "default": true
    },
    "include_asset_key": {
      "type": "boolean",
      "label": "Include Asset Key",
      "description": "Include Asset Key",
      "required": false,
      "default": true
    },
    "include_materialization_time": {
      "type": "boolean",
      "label": "Include Materialization Time",
      "description": "Include Materialization Time",
      "required": false,
      "default": true
    },
    "include_run_partition": {
      "type": "boolean",
      "label": "Include Run Partition",
      "description": "Include Run Partition",
      "required": false,
      "default": false
    },
    "static_columns": {
      "type": "object",
      "label": "Static Columns",
      "description": "Constant columns to add: {col: value} (e.g. {'source_system': 'salesforce'})",
      "required": false,
      "x-dagster-widget": "column"
    },
    "git_sha_env": {
      "type": "string",
      "label": "Git Sha Env",
      "description": "If set, attaches the git SHA from this env var",
      "required": false
    },
    "user_env": {
      "type": "string",
      "label": "User Env",
      "description": "If set, attaches the username from this env var (default USER)",
      "required": false
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Group Name",
      "required": false,
      "default": "transforms"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Include Preview Metadata",
      "required": false,
      "default": true
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Preview Rows",
      "required": false,
      "default": 20
    }
  }
