{
  "component_type": "dagster_component_templates.DetectChangesComponent",
  "description": "Diff incoming DataFrame against a prior snapshot \u2014 emit rows with a change_type column (insert/update/delete/unchanged).",
  "category": "transformation",
  "icon": "ArrowsRightLeft",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream DataFrame asset key",
      "required": true
    },
    "upstream_prior_key": {
      "type": "string",
      "label": "Upstream Prior Key",
      "description": "Prior-snapshot DataFrame asset to diff against",
      "required": true
    },
    "business_key_columns": {
      "type": "array",
      "label": "Business Key Columns",
      "description": "Natural-key columns",
      "required": true,
      "x-dagster-widget": "columns"
    },
    "compare_columns": {
      "type": "array",
      "label": "Compare Columns",
      "description": "Columns whose values are compared for 'update' (None = all non-key)",
      "required": false,
      "x-dagster-widget": "columns"
    },
    "include_unchanged": {
      "type": "boolean",
      "label": "Include Unchanged",
      "description": "Include unchanged rows in the output",
      "required": false,
      "default": false
    },
    "change_type_column": {
      "type": "string",
      "label": "Change Type Column",
      "description": "Change Type Column",
      "required": false,
      "default": "change_type",
      "x-dagster-widget": "column"
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Group Name",
      "required": false,
      "default": "transforms"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Include Preview Metadata",
      "required": false,
      "default": true
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Preview Rows",
      "required": false,
      "default": 20
    }
  }
}
