{
  "component_type": "dagster_component_templates.LookupComponent",
  "description": "Inline lookup \u2014 left-join an upstream DataFrame against a smaller reference DataFrame, optionally caching the reference per run.",
  "category": "transformation",
  "icon": "ArrowsRightLeft",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream DataFrame asset key",
      "required": true
    },
    "upstream_lookup_key": {
      "type": "string",
      "label": "Upstream Lookup Key",
      "description": "Reference (small) DataFrame asset key",
      "required": true
    },
    "on": {
      "type": "array",
      "label": "On",
      "description": "Columns used for the join (must exist in both)",
      "required": true
    },
    "columns_to_add": {
      "type": "array",
      "label": "Columns To Add",
      "description": "Columns from the lookup to attach (None = all non-join columns)",
      "required": false
    },
    "multiple_match": {
      "type": "string",
      "label": "Multiple Match",
      "description": "When the lookup has multiple matches: 'first' | 'last' | 'all' (cartesian)",
      "required": false,
      "default": "first"
    },
    "rename": {
      "type": "object",
      "label": "Rename",
      "description": "Rename added columns: {original: new}",
      "required": false
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Group Name",
      "required": false,
      "default": "transforms"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Include Preview Metadata",
      "required": false,
      "default": true
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Preview Rows",
      "required": false,
      "default": 20
    }
  }
}