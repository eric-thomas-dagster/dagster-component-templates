{
  "component_type": "dagster_component_templates.MapValuesComponent",
  "description": "Replace values in a column according to a lookup dict \u2014 country code \u2192 country name, status code \u2192 status text, etc.",
  "category": "transformation",
  "icon": "ArrowsRightLeft",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream DataFrame asset key",
      "required": true
    },
    "column": {
      "type": "string",
      "label": "Column",
      "description": "Column whose values to remap",
      "required": true
    },
    "mapping": {
      "type": "object",
      "label": "Mapping",
      "description": "{old: new} value mapping",
      "required": true
    },
    "output_column": {
      "type": "string",
      "label": "Output Column",
      "description": "Write to a new column (None = overwrite)",
      "required": false,
      "x-dagster-widget": "column"
    },
    "default_value": {
      "type": "string",
      "label": "Default Value",
      "description": "Use this when no mapping match (None = keep original)",
      "required": false
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Group Name",
      "required": false,
      "default": "transforms"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Include Preview Metadata",
      "required": false,
      "default": true
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Preview Rows",
      "required": false,
      "default": 20
    }
  }
}
