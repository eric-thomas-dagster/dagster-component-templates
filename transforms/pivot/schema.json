{
  "component_type": "dagster_component_templates.PivotComponent",
  "description": "Pivot a DataFrame from long to wide \u2014 rotate row values into column headers with a chosen aggregation.",
  "category": "transformation",
  "icon": "ArrowsRightLeft",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream DataFrame asset key",
      "required": true
    },
    "index_columns": {
      "type": "array",
      "label": "Index Columns",
      "description": "Columns that stay as rows (group keys)",
      "required": true,
      "x-dagster-widget": "columns"
    },
    "pivot_column": {
      "type": "string",
      "label": "Pivot Column",
      "description": "Column whose values become new column headers",
      "required": true,
      "x-dagster-widget": "column"
    },
    "value_column": {
      "type": "string",
      "label": "Value Column",
      "description": "Column whose values fill the pivoted cells",
      "required": true,
      "x-dagster-widget": "column"
    },
    "agg_func": {
      "type": "string",
      "label": "Agg Func",
      "description": "Aggregation when (index, pivot) collides: sum | mean | count | min | max | first | last",
      "required": false,
      "default": "sum"
    },
    "fill_value": {
      "type": "number",
      "label": "Fill Value",
      "description": "Fill NaN cells with this value",
      "required": false
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Group Name",
      "required": false,
      "default": "transforms"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Include Preview Metadata",
      "required": false,
      "default": true
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Preview Rows",
      "required": false,
      "default": 20
    }
  }
}
