{
  "component_type": "dagster_component_templates.SurrogateKeyComponent",
  "description": "Generate stable surrogate keys \u2014 deterministic SHA-256 hash of business-key columns, or sequential integers.",
  "category": "transformation",
  "icon": "ArrowsRightLeft",
  "attributes": {
    "asset_name": {
      "type": "string",
      "label": "Asset Name",
      "description": "Dagster asset name",
      "required": true
    },
    "upstream_asset_key": {
      "type": "string",
      "label": "Upstream Asset Key",
      "description": "Upstream DataFrame asset key",
      "required": true
    },
    "business_key_columns": {
      "type": "array",
      "label": "Business Key Columns",
      "description": "Columns that uniquely identify a record",
      "required": true,
      "x-dagster-widget": "columns"
    },
    "output_column": {
      "type": "string",
      "label": "Output Column",
      "description": "Name for the generated surrogate key column",
      "required": false,
      "default": "sk_id",
      "x-dagster-widget": "column"
    },
    "method": {
      "type": "string",
      "label": "Method",
      "description": "'sha256' (deterministic) | 'md5' | 'sequential' (1..N)",
      "required": false,
      "default": "sha256"
    },
    "sequential_start": {
      "type": "integer",
      "label": "Sequential Start",
      "description": "Start value for sequential mode",
      "required": false,
      "default": 1
    },
    "truncate_chars": {
      "type": "integer",
      "label": "Truncate Chars",
      "description": "Truncate hash to this many hex chars (e.g. 16)",
      "required": false
    },
    "description": {
      "type": "string",
      "label": "Description",
      "description": "Description",
      "required": false
    },
    "group_name": {
      "type": "string",
      "label": "Group Name",
      "description": "Group Name",
      "required": false,
      "default": "transforms"
    },
    "deps": {
      "type": "array",
      "label": "Deps",
      "description": "Deps",
      "required": false
    },
    "owners": {
      "type": "array",
      "label": "Owners",
      "description": "Owners",
      "required": false
    },
    "asset_tags": {
      "type": "object",
      "label": "Asset Tags",
      "description": "Asset Tags",
      "required": false
    },
    "kinds": {
      "type": "array",
      "label": "Kinds",
      "description": "Kinds",
      "required": false
    },
    "include_preview_metadata": {
      "type": "boolean",
      "label": "Include Preview Metadata",
      "description": "Include Preview Metadata",
      "required": false,
      "default": true
    },
    "preview_rows": {
      "type": "integer",
      "label": "Preview Rows",
      "description": "Preview Rows",
      "required": false,
      "default": 20
    }
  }
}
